[
  {
    "verse_id": 5552,
    "text_uthmani": "لَا أُقْسِمُ بِيَوْمِ الْقِيَامَةِ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 1,
    "chapter_id": 75,
    "name_arabic": "القيامة"
  },
  {
    "verse_id": 5553,
    "text_uthmani": "وَلَا أُقْسِمُ بِالنَّفْسِ اللَّوَّامَةِ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 2,
    "chapter_id": 75,
    "name_arabic": "القيامة"
  },
  {
    "verse_id": 5554,
    "text_uthmani": "أَيَحْسَبُ الْإِنسَانُ أَلَّن نَجْمَعَ عِظَامَهُ",
    "source": "الاستيعاب في بيان الأسباب",
    "reason": "قَوْلُهُ عَزَّ وجَلَّ: ﴿أيَحْسَبُ الإنسانُ ألَّن نَّجْمَعَ عِظامَهُ﴾ نَزَلَتْ في عَدِيِّ بْنِ رَبِيعَةَ، وذَلِكَ أنَّهُ أتى النَّبِيَّ ﷺ فَقالَ: حَدِّثْنِي عَنْ يَوْمِ القِيامَةِ مَتى يَكُونُ ؟ وكَيْفَ أمْرُها وحالُها ؟ فَأخْبَرَهُ النَّبِيُّ ﷺ بِذَلِكَ، فَقالَ: لَوْ عايَنْتُ ذَلِكَ اليَوْمَ لَمْ أُصَدِّقْكَ يا مُحَمَّدُ، ولَمْ أُومِن بِهِ، أوَيَجْمَعُ اللَّهُ هَذِهِ العِظامَ ؟ فَأنْزَلَ اللَّهُ تَعالى هَذِهِ الآيَةَ.  '",
    "verse_number": 3,
    "chapter_id": 75,
    "name_arabic": "القيامة"
  },
  {
    "verse_id": 5555,
    "text_uthmani": "بَلَى قَادِرِينَ عَلَى أَن نُّسَوِّيَ بَنَانَهُ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 4,
    "chapter_id": 75,
    "name_arabic": "القيامة"
  },
  {
    "verse_id": 5556,
