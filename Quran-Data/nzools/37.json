    "reason": " لم نقف على شيء",
    "verse_number": 44,
    "chapter_id": 37,
    "name_arabic": "الصافات"
  },
  {
    "verse_id": 3833,
    "text_uthmani": "يُطَافُ عَلَيْهِم بِكَأْسٍ مِن مَّعِينٍ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 45,
    "chapter_id": 37,
    "name_arabic": "الصافات"
  },
  {
    "verse_id": 3834,
    "text_uthmani": "بَيْضَاء لَذَّةٍ لِّلشَّارِبِينَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 46,
    "chapter_id": 37,
    "name_arabic": "الصافات"
  },
  {
    "verse_id": 3835,
    "text_uthmani": "لَا فِيهَا غَوْلٌ وَلَا هُمْ عَنْهَا يُنزَفُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 47,
    "chapter_id": 37,
    "name_arabic": "الصافات"
  },
  {
    "verse_id": 3836,
    "text_uthmani": "وَعِنْدَهُمْ قَاصِرَاتُ الطَّرْفِ عِينٌ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 48,
    "chapter_id": 37,
    "name_arabic": "الصافات"
  },
  {
    "verse_id": 3837,
    "text_uthmani": "كَأَنَّهُنَّ بَيْضٌ مَّكْنُونٌ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 49,
    "chapter_id": 37,
    "name_arabic": "الصافات"
  },
  {
    "verse_id": 3838,
    "text_uthmani": "فَأَقْبَلَ بَعْضُهُمْ عَلَى بَعْضٍ يَتَسَاءلُونَ",
