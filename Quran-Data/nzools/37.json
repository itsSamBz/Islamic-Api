[
  {
    "verse_id": 3789,
    "text_uthmani": "وَالصَّافَّاتِ صَفًّا",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 1,
    "chapter_id": 37,
    "name_arabic": "الصافات"
  },
  {
    "verse_id": 3790,
    "text_uthmani": "فَالزَّاجِرَاتِ زَجْرًا",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 2,
    "chapter_id": 37,
    "name_arabic": "الصافات"
  },
  {
    "verse_id": 3791,
    "text_uthmani": "فَالتَّالِيَاتِ ذِكْرًا",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 3,
    "chapter_id": 37,
    "name_arabic": "الصافات"
  },
  {
    "verse_id": 3792,
    "text_uthmani": "إِنَّ إِلَهَكُمْ لَوَاحِدٌ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 4,
    "chapter_id": 37,
    "name_arabic": "الصافات"
  },
  {
    "verse_id": 3793,
    "text_uthmani": "رَبُّ السَّمَاوَاتِ وَالْأَرْضِ وَمَا بَيْنَهُمَا وَرَبُّ الْمَشَارِقِ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 5,
    "chapter_id": 37,
    "name_arabic": "الصافات"
  },
  {
    "verse_id": 3794,
    "text_uthmani": "إِنَّا زَيَّنَّا السَّمَاء الدُّنْيَا بِزِينَةٍ الْكَوَاكِبِ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 6,
    "chapter_id": 37,
    "name_arabic": "الصافات"
  },
  {
    "verse_id": 3795,
    "text_uthmani": "وَحِفْظًا مِّن كُلِّ شَيْطَانٍ مَّارِدٍ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 7,
    "chapter_id": 37,
    "name_arabic": "الصافات"
  },
  {
    "verse_id": 3796,
    "text_uthmani": "لَا يَسَّمَّعُونَ إِلَى الْمَلَإِ الْأَعْلَى وَيُقْذَفُونَ مِن كُلِّ جَانِبٍ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 8,
    "chapter_id": 37,
    "name_arabic": "الصافات"
  },
  {
    "verse_id": 3797,
    "text_uthmani": "دُحُورًا وَلَهُمْ عَذَابٌ وَاصِبٌ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 9,
    "chapter_id": 37,
    "name_arabic": "الصافات"
  },
  {
    "verse_id": 3798,
    "text_uthmani": "إِلَّا مَنْ خَطِفَ الْخَطْفَةَ فَأَتْبَعَهُ شِهَابٌ ثَاقِبٌ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 10,
    "chapter_id": 37,
    "name_arabic": "الصافات"
  },
  {
    "verse_id": 3799,
    "text_uthmani": "فَاسْتَفْتِهِمْ أَهُمْ أَشَدُّ خَلْقًا أَم مَّنْ خَلَقْنَا إِنَّا خَلَقْنَاهُم مِّن طِينٍ لَّازِبٍ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 11,
    "chapter_id": 37,
    "name_arabic": "الصافات"
  },
  {
    "verse_id": 3800,
    "text_uthmani": "بَلْ عَجِبْتَ وَيَسْخَرُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 12,
    "chapter_id": 37,
    "name_arabic": "الصافات"
  },
  {
    "verse_id": 3801,
    "text_uthmani": "وَإِذَا ذُكِّرُوا لَا يَذْكُرُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 13,
    "chapter_id": 37,
    "name_arabic": "الصافات"
  },
  {
    "verse_id": 3802,
    "text_uthmani": "وَإِذَا رَأَوْا آيَةً يَسْتَسْخِرُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 14,
    "chapter_id": 37,
    "name_arabic": "الصافات"
  },
  {
    "verse_id": 3803,
    "text_uthmani": "وَقَالُوا إِنْ هَذَا إِلَّا سِحْرٌ مُّبِينٌ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 15,
    "chapter_id": 37,
    "name_arabic": "الصافات"
  },
  {
    "verse_id": 3804,
    "text_uthmani": "أَئِذَا مِتْنَا وَكُنَّا تُرَابًا وَعِظَامًا أَئِنَّا لَمَبْعُوثُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 16,
    "chapter_id": 37,
    "name_arabic": "الصافات"
  },
  {
    "verse_id": 3805,
    "text_uthmani": "أَوَآبَاؤُنَا الْأَوَّلُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 17,
    "chapter_id": 37,
    "name_arabic": "الصافات"
  },
  {
    "verse_id": 3806,
    "text_uthmani": "قُلْ نَعَمْ وَأَنتُمْ دَاخِرُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 18,
    "chapter_id": 37,
    "name_arabic": "الصافات"
  },
  {
    "verse_id": 3807,
    "text_uthmani": "فَإِنَّمَا هِيَ زَجْرَةٌ وَاحِدَةٌ فَإِذَا هُمْ يَنظُرُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 19,
    "chapter_id": 37,
    "name_arabic": "الصافات"
  },
  {
    "verse_id": 3808,
    "text_uthmani": "وَقَالُوا يَا وَيْلَنَا هَذَا يَوْمُ الدِّينِ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 20,
    "chapter_id": 37,
    "name_arabic": "الصافات"
  },
  {
    "verse_id": 3809,
    "text_uthmani": "هَذَا يَوْمُ الْفَصْلِ الَّذِي كُنتُمْ بِهِ تُكَذِّبُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 21,
    "chapter_id": 37,
    "name_arabic": "الصافات"
  },
  {
    "verse_id": 3810,
    "text_uthmani": "احْشُرُوا الَّذِينَ ظَلَمُوا وَأَزْوَاجَهُمْ وَمَا كَانُوا يَعْبُدُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 22,
    "chapter_id": 37,
    "name_arabic": "الصافات"
  },
  {
    "verse_id": 3811,
    "text_uthmani": "مِن دُونِ اللَّهِ فَاهْدُوهُمْ إِلَى صِرَاطِ الْجَحِيمِ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 23,
    "chapter_id": 37,
    "name_arabic": "الصافات"
  },
  {
    "verse_id": 3812,
    "text_uthmani": "وَقِفُوهُمْ إِنَّهُم مَّسْئُولُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 24,
    "chapter_id": 37,
    "name_arabic": "الصافات"
  },
  {
    "verse_id": 3813,
    "text_uthmani": "مَا لَكُمْ لَا تَنَاصَرُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 25,
    "chapter_id": 37,
    "name_arabic": "الصافات"
  },
  {
    "verse_id": 3814,
    "text_uthmani": "بَلْ هُمُ الْيَوْمَ مُسْتَسْلِمُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 26,
    "chapter_id": 37,
    "name_arabic": "الصافات"
  },
  {
    "verse_id": 3815,
    "text_uthmani": "وَأَقْبَلَ بَعْضُهُمْ عَلَى بَعْضٍ يَتَسَاءلُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 27,
    "chapter_id": 37,
    "name_arabic": "الصافات"
  },
  {
    "verse_id": 3816,
    "text_uthmani": "قَالُوا إِنَّكُمْ كُنتُمْ تَأْتُونَنَا عَنِ الْيَمِينِ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 28,
    "chapter_id": 37,
    "name_arabic": "الصافات"
  },
  {
    "verse_id": 3817,
    "text_uthmani": "قَالُوا بَل لَّمْ تَكُونُوا مُؤْمِنِينَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 29,
    "chapter_id": 37,
    "name_arabic": "الصافات"
  },
  {
    "verse_id": 3818,
    "text_uthmani": "وَمَا كَانَ لَنَا عَلَيْكُم مِّن سُلْطَانٍ بَلْ كُنتُمْ قَوْمًا طَاغِينَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 30,
    "chapter_id": 37,
    "name_arabic": "الصافات"
  },
  {
    "verse_id": 3819,
    "text_uthmani": "فَحَقَّ عَلَيْنَا قَوْلُ رَبِّنَا إِنَّا لَذَائِقُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 31,
    "chapter_id": 37,
    "name_arabic": "الصافات"
  },
  {
    "verse_id": 3820,
    "text_uthmani": "فَأَغْوَيْنَاكُمْ إِنَّا كُنَّا غَاوِينَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 32,
    "chapter_id": 37,
    "name_arabic": "الصافات"
  },
  {
    "verse_id": 3821,
    "text_uthmani": "فَإِنَّهُمْ يَوْمَئِذٍ فِي الْعَذَابِ مُشْتَرِكُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 33,
    "chapter_id": 37,
    "name_arabic": "الصافات"
  },
  {
    "verse_id": 3822,
    "text_uthmani": "إِنَّا كَذَلِكَ نَفْعَلُ بِالْمُجْرِمِينَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 34,
    "chapter_id": 37,
    "name_arabic": "الصافات"
  },
  {
    "verse_id": 3823,
    "text_uthmani": "إِنَّهُمْ كَانُوا إِذَا قِيلَ لَهُمْ لَا إِلَهَ إِلَّا اللَّهُ يَسْتَكْبِرُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 35,
    "chapter_id": 37,
    "name_arabic": "الصافات"
  },
  {
    "verse_id": 3824,
    "text_uthmani": "وَيَقُولُونَ أَئِنَّا لَتَارِكُوا آلِهَتِنَا لِشَاعِرٍ مَّجْنُونٍ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 36,
    "chapter_id": 37,
    "name_arabic": "الصافات"
  },
  {
    "verse_id": 3825,
    "text_uthmani": "بَلْ جَاء بِالْحَقِّ وَصَدَّقَ الْمُرْسَلِينَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 37,
    "chapter_id": 37,
    "name_arabic": "الصافات"
  },
  {
    "verse_id": 3826,
    "text_uthmani": "إِنَّكُمْ لَذَائِقُو الْعَذَابِ الْأَلِيمِ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 38,
    "chapter_id": 37,
    "name_arabic": "الصافات"
  },
  {
    "verse_id": 3827,
    "text_uthmani": "وَمَا تُجْزَوْنَ إِلَّا مَا كُنتُمْ تَعْمَلُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 39,
    "chapter_id": 37,
    "name_arabic": "الصافات"
  },
  {
    "verse_id": 3828,
    "text_uthmani": "إِلَّا عِبَادَ اللَّهِ الْمُخْلَصِينَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 40,
    "chapter_id": 37,
    "name_arabic": "الصافات"
  },
  {
    "verse_id": 3829,
    "text_uthmani": "أُوْلَئِكَ لَهُمْ رِزْقٌ مَّعْلُومٌ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 41,
    "chapter_id": 37,
    "name_arabic": "الصافات"
  },
  {
    "verse_id": 3830,
    "text_uthmani": "فَوَاكِهُ وَهُم مُّكْرَمُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 42,
    "chapter_id": 37,
    "name_arabic": "الصافات"
  },
  {
    "verse_id": 3831,
    "text_uthmani": "فِي جَنَّاتِ النَّعِيمِ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 43,
    "chapter_id": 37,
    "name_arabic": "الصافات"
  },
  {
    "verse_id": 3832,
