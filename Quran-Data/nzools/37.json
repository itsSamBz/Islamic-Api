    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 51,
    "chapter_id": 37,
    "name_arabic": "الصافات"
  },
  {
    "verse_id": 3840,
    "text_uthmani": "يَقُولُ أَئِنَّكَ لَمِنْ الْمُصَدِّقِينَ",
