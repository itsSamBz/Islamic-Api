    "reason": " لم نقف على شيء",
    "verse_number": 52,
    "chapter_id": 37,
    "name_arabic": "الصافات"
  },
  {
    "verse_id": 3841,
    "text_uthmani": "أَئِذَا مِتْنَا وَكُنَّا تُرَابًا وَعِظَامًا أَئِنَّا لَمَدِينُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 53,
    "chapter_id": 37,
    "name_arabic": "الصافات"
  },
  {
