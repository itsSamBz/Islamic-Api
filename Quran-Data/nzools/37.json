    "reason": " لم نقف على شيء",
    "verse_number": 56,
    "chapter_id": 37,
    "name_arabic": "الصافات"
  },
  {
    "verse_id": 3845,
    "text_uthmani": "وَلَوْلَا نِعْمَةُ رَبِّي لَكُنتُ مِنَ الْمُحْضَرِينَ",
