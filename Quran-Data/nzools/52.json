    "verse_number": 1,
    "chapter_id": 52,
    "name_arabic": "الطور"
  },
  {
    "verse_id": 4737,
    "text_uthmani": "وَكِتَابٍ مَّسْطُورٍ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 2,
    "chapter_id": 52,
    "name_arabic": "الطور"
  },
  {
    "verse_id": 4738,
    "text_uthmani": "فِي رَقٍّ مَّنشُورٍ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 3,
    "chapter_id": 52,
    "name_arabic": "الطور"
  },
  {
    "verse_id": 4739,
    "text_uthmani": "وَالْبَيْتِ الْمَعْمُورِ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 4,
    "chapter_id": 52,
    "name_arabic": "الطور"
  },
  {
    "verse_id": 4740,
    "text_uthmani": "وَالسَّقْفِ الْمَرْفُوعِ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 5,
    "chapter_id": 52,
    "name_arabic": "الطور"
  },
  {
    "verse_id": 4741,
    "text_uthmani": "وَالْبَحْرِ الْمَسْجُورِ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 6,
    "chapter_id": 52,
    "name_arabic": "الطور"
  },
  {
    "verse_id": 4742,
    "text_uthmani": "إِنَّ عَذَابَ رَبِّكَ لَوَاقِعٌ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 7,
    "chapter_id": 52,
    "name_arabic": "الطور"
  },
  {
    "verse_id": 4743,
    "text_uthmani": "مَا لَهُ مِن دَافِعٍ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 8,
    "chapter_id": 52,
    "name_arabic": "الطور"
  },
  {
    "verse_id": 4744,
    "text_uthmani": "يَوْمَ تَمُورُ السَّمَاء مَوْرًا",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 9,
    "chapter_id": 52,
    "name_arabic": "الطور"
  },
  {
    "verse_id": 4745,
    "text_uthmani": "وَتَسِيرُ الْجِبَالُ سَيْرًا",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 10,
    "chapter_id": 52,
    "name_arabic": "الطور"
  },
  {
    "verse_id": 4746,
    "text_uthmani": "فَوَيْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 11,
    "chapter_id": 52,
    "name_arabic": "الطور"
  },
  {
    "verse_id": 4747,
    "text_uthmani": "الَّذِينَ هُمْ فِي خَوْضٍ يَلْعَبُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 12,
    "chapter_id": 52,
    "name_arabic": "الطور"
  },
  {
    "verse_id": 4748,
    "text_uthmani": "يَوْمَ يُدَعُّونَ إِلَى نَارِ جَهَنَّمَ دَعًّا",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 13,
    "chapter_id": 52,
    "name_arabic": "الطور"
  },
  {
    "verse_id": 4749,
    "text_uthmani": "هَذِهِ النَّارُ الَّتِي كُنتُم بِهَا تُكَذِّبُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 14,
    "chapter_id": 52,
    "name_arabic": "الطور"
  },
  {
    "verse_id": 4750,
    "text_uthmani": "أَفَسِحْرٌ هَذَا أَمْ أَنتُمْ لَا تُبْصِرُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 15,
    "chapter_id": 52,
    "name_arabic": "الطور"
  },
  {
    "verse_id": 4751,
    "text_uthmani": "اصْلَوْهَا فَاصْبِرُوا أَوْ لَا تَصْبِرُوا سَوَاء عَلَيْكُمْ إِنَّمَا تُجْزَوْنَ مَا كُنتُمْ تَعْمَلُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 16,
    "chapter_id": 52,
    "name_arabic": "الطور"
  },
  {
    "verse_id": 4752,
    "text_uthmani": "إِنَّ الْمُتَّقِينَ فِي جَنَّاتٍ وَنَعِيمٍ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 17,
    "chapter_id": 52,
    "name_arabic": "الطور"
  },
  {
    "verse_id": 4753,
    "text_uthmani": "فَاكِهِينَ بِمَا آتَاهُمْ رَبُّهُمْ وَوَقَاهُمْ رَبُّهُمْ عَذَابَ الْجَحِيمِ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 18,
    "chapter_id": 52,
    "name_arabic": "الطور"
  },
  {
    "verse_id": 4754,
    "text_uthmani": "كُلُوا وَاشْرَبُوا هَنِيئًا بِمَا كُنتُمْ تَعْمَلُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 19,
    "chapter_id": 52,
    "name_arabic": "الطور"
  },
  {
    "verse_id": 4755,
    "text_uthmani": "مُتَّكِئِينَ عَلَى سُرُرٍ مَّصْفُوفَةٍ وَزَوَّجْنَاهُم بِحُورٍ عِينٍ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 20,
    "chapter_id": 52,
    "name_arabic": "الطور"
  },
  {
    "verse_id": 4756,
    "text_uthmani": "وَالَّذِينَ آمَنُوا وَاتَّبَعَتْهُمْ ذُرِّيَّتُهُم بِإِيمَانٍ أَلْحَقْنَا بِهِمْ ذُرِّيَّتَهُمْ وَمَا أَلَتْنَاهُم مِّنْ عَمَلِهِم مِّن شَيْءٍ كُلُّ امْرِئٍ بِمَا كَسَبَ رَهِينٌ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 21,
    "chapter_id": 52,
    "name_arabic": "الطور"
  },
  {
    "verse_id": 4757,
    "text_uthmani": "وَأَمْدَدْنَاهُم بِفَاكِهَةٍ وَلَحْمٍ مِّمَّا يَشْتَهُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 22,
    "chapter_id": 52,
    "name_arabic": "الطور"
  },
  {
    "verse_id": 4758,
    "text_uthmani": "يَتَنَازَعُونَ فِيهَا كَأْسًا لَّا لَغْوٌ فِيهَا وَلَا تَأْثِيمٌ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 23,
    "chapter_id": 52,
    "name_arabic": "الطور"
  },
  {
    "verse_id": 4759,
    "text_uthmani": "وَيَطُوفُ عَلَيْهِمْ غِلْمَانٌ لَّهُمْ كَأَنَّهُمْ لُؤْلُؤٌ مَّكْنُونٌ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 24,
    "chapter_id": 52,
    "name_arabic": "الطور"
  },
  {
    "verse_id": 4760,
    "text_uthmani": "وَأَقْبَلَ بَعْضُهُمْ عَلَى بَعْضٍ يَتَسَاءلُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 25,
    "chapter_id": 52,
    "name_arabic": "الطور"
  },
  {
    "verse_id": 4761,
    "text_uthmani": "قَالُوا إِنَّا كُنَّا قَبْلُ فِي أَهْلِنَا مُشْفِقِينَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 26,
    "chapter_id": 52,
    "name_arabic": "الطور"
  },
  {
    "verse_id": 4762,
    "text_uthmani": "فَمَنَّ اللَّهُ عَلَيْنَا وَوَقَانَا عَذَابَ السَّمُومِ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 27,
    "chapter_id": 52,
    "name_arabic": "الطور"
  },
  {
    "verse_id": 4763,
    "text_uthmani": "إِنَّا كُنَّا مِن قَبْلُ نَدْعُوهُ إِنَّهُ هُوَ الْبَرُّ الرَّحِيمُ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 28,
    "chapter_id": 52,
    "name_arabic": "الطور"
  },
  {
    "verse_id": 4764,
    "text_uthmani": "فَذَكِّرْ فَمَا أَنتَ بِنِعْمَتِ رَبِّكَ بِكَاهِنٍ وَلَا مَجْنُونٍ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 29,
    "chapter_id": 52,
    "name_arabic": "الطور"
  },
  {
    "verse_id": 4765,
    "text_uthmani": "أَمْ يَقُولُونَ شَاعِرٌ نَّتَرَبَّصُ بِهِ رَيْبَ الْمَنُونِ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 30,
    "chapter_id": 52,
    "name_arabic": "الطور"
  },
  {
    "verse_id": 4766,
    "text_uthmani": "قُلْ تَرَبَّصُوا فَإِنِّي مَعَكُم مِّنَ الْمُتَرَبِّصِينَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 31,
    "chapter_id": 52,
    "name_arabic": "الطور"
  },
  {
    "verse_id": 4767,
    "text_uthmani": "أَمْ تَأْمُرُهُمْ أَحْلَامُهُم بِهَذَا أَمْ هُمْ قَوْمٌ طَاغُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 32,
    "chapter_id": 52,
    "name_arabic": "الطور"
  },
  {
    "verse_id": 4768,
    "text_uthmani": "أَمْ يَقُولُونَ تَقَوَّلَهُ بَل لَّا يُؤْمِنُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 33,
    "chapter_id": 52,
    "name_arabic": "الطور"
  },
  {
    "verse_id": 4769,
    "text_uthmani": "فَلْيَأْتُوا بِحَدِيثٍ مِّثْلِهِ إِن كَانُوا صَادِقِينَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 34,
    "chapter_id": 52,
    "name_arabic": "الطور"
  },
  {
    "verse_id": 4770,
    "text_uthmani": "أَمْ خُلِقُوا مِنْ غَيْرِ شَيْءٍ أَمْ هُمُ الْخَالِقُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 35,
    "chapter_id": 52,
    "name_arabic": "الطور"
  },
  {
    "verse_id": 4771,
    "text_uthmani": "أَمْ خَلَقُوا السَّمَاوَاتِ وَالْأَرْضَ بَل لَّا يُوقِنُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 36,
    "chapter_id": 52,
    "name_arabic": "الطور"
  },
  {
    "verse_id": 4772,
    "text_uthmani": "أَمْ عِندَهُمْ خَزَائِنُ رَبِّكَ أَمْ هُمُ الْمُصَيْطِرُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 37,
    "chapter_id": 52,
    "name_arabic": "الطور"
  },
  {
    "verse_id": 4773,
    "text_uthmani": "أَمْ لَهُمْ سُلَّمٌ يَسْتَمِعُونَ فِيهِ فَلْيَأْتِ مُسْتَمِعُهُم بِسُلْطَانٍ مُّبِينٍ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 38,
    "chapter_id": 52,
    "name_arabic": "الطور"
  },
  {
    "verse_id": 4774,
    "text_uthmani": "أَمْ لَهُ الْبَنَاتُ وَلَكُمُ الْبَنُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 39,
    "chapter_id": 52,
    "name_arabic": "الطور"
  },
  {
    "verse_id": 4775,
    "text_uthmani": "أَمْ تَسْأَلُهُمْ أَجْرًا فَهُم مِّن مَّغْرَمٍ مُّثْقَلُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 40,
    "chapter_id": 52,
    "name_arabic": "الطور"
  },
  {
    "verse_id": 4776,
    "text_uthmani": "أَمْ عِندَهُمُ الْغَيْبُ فَهُمْ يَكْتُبُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 41,
    "chapter_id": 52,
    "name_arabic": "الطور"
  },
  {
    "verse_id": 4777,
    "text_uthmani": "أَمْ يُرِيدُونَ كَيْدًا فَالَّذِينَ كَفَرُوا هُمُ الْمَكِيدُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 42,
    "chapter_id": 52,
    "name_arabic": "الطور"
  },
  {
    "verse_id": 4778,
    "text_uthmani": "أَمْ لَهُمْ إِلَهٌ غَيْرُ اللَّهِ سُبْحَانَ اللَّهِ عَمَّا يُشْرِكُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 43,
    "chapter_id": 52,
    "name_arabic": "الطور"
  },
  {
    "verse_id": 4779,
    "text_uthmani": "وَإِن يَرَوْا كِسْفًا مِّنَ السَّمَاء سَاقِطًا يَقُولُوا سَحَابٌ مَّرْكُومٌ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 44,
    "chapter_id": 52,
    "name_arabic": "الطور"
  },
  {
    "verse_id": 4780,
    "text_uthmani": "فَذَرْهُمْ حَتَّى يُلَاقُوا يَوْمَهُمُ الَّذِي فِيهِ يُصْعَقُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 45,
    "chapter_id": 52,
    "name_arabic": "الطور"
  },
  {
    "verse_id": 4781,
    "text_uthmani": "يَوْمَ لَا يُغْنِي عَنْهُمْ كَيْدُهُمْ شَيْئًا وَلَا هُمْ يُنصَرُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 46,
    "chapter_id": 52,
    "name_arabic": "الطور"
  },
  {
    "verse_id": 4782,
    "text_uthmani": "وَإِنَّ لِلَّذِينَ ظَلَمُوا عَذَابًا دُونَ ذَلِكَ وَلَكِنَّ أَكْثَرَهُمْ لَا يَعْلَمُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 47,
    "chapter_id": 52,
    "name_arabic": "الطور"
  },
  {
    "verse_id": 4783,
    "text_uthmani": "وَاصْبِرْ لِحُكْمِ رَبِّكَ فَإِنَّكَ بِأَعْيُنِنَا وَسَبِّحْ بِحَمْدِ رَبِّكَ حِينَ تَقُومُ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 48,
    "chapter_id": 52,
    "name_arabic": "الطور"
  },
  {
    "verse_id": 4784,
    "text_uthmani": "وَمِنَ اللَّيْلِ فَسَبِّحْهُ وَإِدْبَارَ النُّجُومِ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 49,
    "chapter_id": 52,
    "name_arabic": "الطور"
  }
]