    "reason": " لم نقف على شيء",
    "verse_number": 4,
    "chapter_id": 44,
    "name_arabic": "الدخان"
  },
  {
    "verse_id": 4419,
    "text_uthmani": "أَمْرًا مِّنْ عِندِنَا إِنَّا كُنَّا مُرْسِلِينَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 5,
    "chapter_id": 44,
    "name_arabic": "الدخان"
  },
  {
    "verse_id": 4420,
    "text_uthmani": "رَحْمَةً مِّن رَّبِّكَ إِنَّهُ هُوَ السَّمِيعُ الْعَلِيمُ",
