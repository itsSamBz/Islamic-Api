[
  {
    "verse_id": 5272,
    "text_uthmani": "ن وَالْقَلَمِ وَمَا يَسْطُرُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 1,
    "chapter_id": 68,
    "name_arabic": "القلم"
  },
  {
    "verse_id": 5273,
    "text_uthmani": "مَا أَنتَ بِنِعْمَةِ رَبِّكَ بِمَجْنُونٍ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 2,
    "chapter_id": 68,
    "name_arabic": "القلم"
  },
  {
    "verse_id": 5274,
    "text_uthmani": "وَإِنَّ لَكَ لَأَجْرًا غَيْرَ مَمْنُونٍ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 3,
    "chapter_id": 68,
    "name_arabic": "القلم"
  },
  {
    "verse_id": 5275,
    "text_uthmani": "وَإِنَّكَ لَعَلى خُلُقٍ عَظِيمٍ",
    "source": "الاستيعاب في بيان الأسباب",
    "reason": "أخْبَرَنا أبُو بَكْرٍ الحارِثِيُّ، قالَ: أخْبَرَنا عَبْدُ اللَّهِ بْنُ مُحَمَّدِ بْنِ حَيّانَ، قالَ: حَدَّثَنا أحْمَدُ بْنُ جَعْفَرِ بْنِ نَصْرٍ الجَمّالُ، قالَ: حَدَّثَنا جَرِيرُ بْنُ يَحْيى، قالَ: حَدَّثَنا حُسَيْنُ بْنُ عُلْوانَ الكُوفِيُّ، قالَ: حَدَّثَنا هِشامُ بْنُ عُرْوَةَ، عَنْ أبِيهِ، عَنْ عائِشَةَ قالَتْ:  ما كانَ أحَدٌ أحْسَنَ خُلُقًا مِن رَسُولِ اللَّهِ ﷺ، ما دَعاهُ أحَدٌ مِن أصْحابِهِ ولا مِن أهْلِ بَيْتِهِ إلّا قالَ: ”لَبَّيْكَ“ . ولِذَلِكَ أنْزَلَ اللَّهُ عَزَّ وجَلَّ: ﴿وإنَّكَ لَعَلى خُلُقٍ عَظِيمٍ﴾ .  '",
    "verse_number": 4,
    "chapter_id": 68,
    "name_arabic": "القلم"
  },
  {
    "verse_id": 5276,
    "text_uthmani": "فَسَتُبْصِرُ وَيُبْصِرُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 5,
    "chapter_id": 68,
    "name_arabic": "القلم"
  },
  {
    "verse_id": 5277,
    "text_uthmani": "بِأَييِّكُمُ الْمَفْتُونُ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 6,
    "chapter_id": 68,
    "name_arabic": "القلم"
  },
  {
    "verse_id": 5278,
    "text_uthmani": "إِنَّ رَبَّكَ هُوَ أَعْلَمُ بِمَن ضَلَّ عَن سَبِيلِهِ وَهُوَ أَعْلَمُ بِالْمُهْتَدِينَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 7,
    "chapter_id": 68,
    "name_arabic": "القلم"
  },
  {
    "verse_id": 5279,
    "text_uthmani": "فَلَا تُطِعِ الْمُكَذِّبِينَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 8,
    "chapter_id": 68,
    "name_arabic": "القلم"
  },
  {
    "verse_id": 5280,
    "text_uthmani": "وَدُّوا لَوْ تُدْهِنُ فَيُدْهِنُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 9,
    "chapter_id": 68,
    "name_arabic": "القلم"
  },
  {
    "verse_id": 5281,
    "text_uthmani": "وَلَا تُطِعْ كُلَّ حَلَّافٍ مَّهِينٍ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 10,
    "chapter_id": 68,
    "name_arabic": "القلم"
  },
  {
    "verse_id": 5282,
    "text_uthmani": "هَمَّازٍ مَّشَّاء بِنَمِيمٍ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 11,
    "chapter_id": 68,
    "name_arabic": "القلم"
  },
  {
    "verse_id": 5283,
    "text_uthmani": "مَنَّاعٍ لِّلْخَيْرِ مُعْتَدٍ أَثِيمٍ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 12,
    "chapter_id": 68,
    "name_arabic": "القلم"
  },
  {
    "verse_id": 5284,
    "text_uthmani": "عُتُلٍّ بَعْدَ ذَلِكَ زَنِيمٍ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 13,
    "chapter_id": 68,
    "name_arabic": "القلم"
  },
  {
    "verse_id": 5285,
    "text_uthmani": "أَن كَانَ ذَا مَالٍ وَبَنِينَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 14,
    "chapter_id": 68,
    "name_arabic": "القلم"
  },
  {
    "verse_id": 5286,
    "text_uthmani": "إِذَا تُتْلَى عَلَيْهِ آيَاتُنَا قَالَ أَسَاطِيرُ الْأَوَّلِينَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 15,
    "chapter_id": 68,
    "name_arabic": "القلم"
  },
  {
    "verse_id": 5287,
    "text_uthmani": "سَنَسِمُهُ عَلَى الْخُرْطُومِ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 16,
    "chapter_id": 68,
    "name_arabic": "القلم"
  },
  {
    "verse_id": 5288,
    "text_uthmani": "إِنَّا بَلَوْنَاهُمْ كَمَا بَلَوْنَا أَصْحَابَ الْجَنَّةِ إِذْ أَقْسَمُوا لَيَصْرِمُنَّهَا مُصْبِحِينَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 17,
    "chapter_id": 68,
    "name_arabic": "القلم"
  },
  {
    "verse_id": 5289,
    "text_uthmani": "وَلَا يَسْتَثْنُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 18,
    "chapter_id": 68,
    "name_arabic": "القلم"
  },
  {
    "verse_id": 5290,
    "text_uthmani": "فَطَافَ عَلَيْهَا طَائِفٌ مِّن رَّبِّكَ وَهُمْ نَائِمُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 19,
    "chapter_id": 68,
    "name_arabic": "القلم"
  },
  {
    "verse_id": 5291,
    "text_uthmani": "فَأَصْبَحَتْ كَالصَّرِيمِ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 20,
    "chapter_id": 68,
    "name_arabic": "القلم"
  },
  {
    "verse_id": 5292,
    "text_uthmani": "فَتَنَادَوا مُصْبِحِينَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 21,
    "chapter_id": 68,
    "name_arabic": "القلم"
  },
  {
    "verse_id": 5293,
    "text_uthmani": "أَنِ اغْدُوا عَلَى حَرْثِكُمْ إِن كُنتُمْ صَارِمِينَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 22,
    "chapter_id": 68,
    "name_arabic": "القلم"
  },
  {
    "verse_id": 5294,
    "text_uthmani": "فَانطَلَقُوا وَهُمْ يَتَخَافَتُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 23,
    "chapter_id": 68,
    "name_arabic": "القلم"
  },
  {
    "verse_id": 5295,
    "text_uthmani": "أَن لَّا يَدْخُلَنَّهَا الْيَوْمَ عَلَيْكُم مِّسْكِينٌ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 24,
    "chapter_id": 68,
    "name_arabic": "القلم"
  },
  {
    "verse_id": 5296,
    "text_uthmani": "وَغَدَوْا عَلَى حَرْدٍ قَادِرِينَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 25,
    "chapter_id": 68,
    "name_arabic": "القلم"
  },
  {
    "verse_id": 5297,
    "text_uthmani": "فَلَمَّا رَأَوْهَا قَالُوا إِنَّا لَضَالُّونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 26,
    "chapter_id": 68,
    "name_arabic": "القلم"
  },
  {
    "verse_id": 5298,
    "text_uthmani": "بَلْ نَحْنُ مَحْرُومُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 27,
    "chapter_id": 68,
    "name_arabic": "القلم"
  },
  {
    "verse_id": 5299,
    "text_uthmani": "قَالَ أَوْسَطُهُمْ أَلَمْ أَقُل لَّكُمْ لَوْلَا تُسَبِّحُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 28,
    "chapter_id": 68,
    "name_arabic": "القلم"
  },
  {
    "verse_id": 5300,
    "text_uthmani": "قَالُوا سُبْحَانَ رَبِّنَا إِنَّا كُنَّا ظَالِمِينَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 29,
    "chapter_id": 68,
    "name_arabic": "القلم"
  },
  {
    "verse_id": 5301,
    "text_uthmani": "فَأَقْبَلَ بَعْضُهُمْ عَلَى بَعْضٍ يَتَلَاوَمُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 30,
    "chapter_id": 68,
    "name_arabic": "القلم"
  },
  {
    "verse_id": 5302,
    "text_uthmani": "قَالُوا يَا وَيْلَنَا إِنَّا كُنَّا طَاغِينَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 31,
    "chapter_id": 68,
    "name_arabic": "القلم"
  },
  {
    "verse_id": 5303,
    "text_uthmani": "عَسَى رَبُّنَا أَن يُبْدِلَنَا خَيْرًا مِّنْهَا إِنَّا إِلَى رَبِّنَا رَاغِبُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 32,
    "chapter_id": 68,
    "name_arabic": "القلم"
  },
  {
    "verse_id": 5304,
    "text_uthmani": "كَذَلِكَ الْعَذَابُ وَلَعَذَابُ الْآخِرَةِ أَكْبَرُ لَوْ كَانُوا يَعْلَمُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 33,
    "chapter_id": 68,
    "name_arabic": "القلم"
  },
  {
    "verse_id": 5305,
    "text_uthmani": "إِنَّ لِلْمُتَّقِينَ عِندَ رَبِّهِمْ جَنَّاتِ النَّعِيمِ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 34,
    "chapter_id": 68,
    "name_arabic": "القلم"
  },
  {
    "verse_id": 5306,
    "text_uthmani": "أَفَنَجْعَلُ الْمُسْلِمِينَ كَالْمُجْرِمِينَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 35,
    "chapter_id": 68,
    "name_arabic": "القلم"
  },
  {
    "verse_id": 5307,
    "text_uthmani": "مَا لَكُمْ كَيْفَ تَحْكُمُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 36,
    "chapter_id": 68,
    "name_arabic": "القلم"
  },
  {
    "verse_id": 5308,
    "text_uthmani": "أَمْ لَكُمْ كِتَابٌ فِيهِ تَدْرُسُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 37,
    "chapter_id": 68,
    "name_arabic": "القلم"
  },
  {
    "verse_id": 5309,
    "text_uthmani": "إِنَّ لَكُمْ فِيهِ لَمَا يَتَخَيَّرُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 38,
    "chapter_id": 68,
    "name_arabic": "القلم"
  },
  {
    "verse_id": 5310,
    "text_uthmani": "أَمْ لَكُمْ أَيْمَانٌ عَلَيْنَا بَالِغَةٌ إِلَى يَوْمِ الْقِيَامَةِ إِنَّ لَكُمْ لَمَا تَحْكُمُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 39,
    "chapter_id": 68,
    "name_arabic": "القلم"
  },
  {
    "verse_id": 5311,
    "text_uthmani": "سَلْهُم أَيُّهُم بِذَلِكَ زَعِيمٌ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 40,
    "chapter_id": 68,
    "name_arabic": "القلم"
  },
  {
    "verse_id": 5312,
    "text_uthmani": "أَمْ لَهُمْ شُرَكَاء فَلْيَأْتُوا بِشُرَكَائِهِمْ إِن كَانُوا صَادِقِينَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 41,
    "chapter_id": 68,
    "name_arabic": "القلم"
  },
  {
    "verse_id": 5313,
    "text_uthmani": "يَوْمَ يُكْشَفُ عَن سَاقٍ وَيُدْعَوْنَ إِلَى السُّجُودِ فَلَا يَسْتَطِيعُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 42,
    "chapter_id": 68,
    "name_arabic": "القلم"
  },
  {
    "verse_id": 5314,
    "text_uthmani": "خَاشِعَةً أَبْصَارُهُمْ تَرْهَقُهُمْ ذِلَّةٌ وَقَدْ كَانُوا يُدْعَوْنَ إِلَى السُّجُودِ وَهُمْ سَالِمُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 43,
    "chapter_id": 68,
    "name_arabic": "القلم"
  },
  {
    "verse_id": 5315,
    "text_uthmani": "فَذَرْنِي وَمَن يُكَذِّبُ بِهَذَا الْحَدِيثِ سَنَسْتَدْرِجُهُم مِّنْ حَيْثُ لَا يَعْلَمُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 44,
    "chapter_id": 68,
    "name_arabic": "القلم"
  },
  {
    "verse_id": 5316,
    "text_uthmani": "وَأُمْلِي لَهُمْ إِنَّ كَيْدِي مَتِينٌ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 45,
    "chapter_id": 68,
    "name_arabic": "القلم"
  },
  {
    "verse_id": 5317,
    "text_uthmani": "أَمْ تَسْأَلُهُمْ أَجْرًا فَهُم مِّن مَّغْرَمٍ مُّثْقَلُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 46,
    "chapter_id": 68,
    "name_arabic": "القلم"
  },
  {
    "verse_id": 5318,
    "text_uthmani": "أَمْ عِندَهُمُ الْغَيْبُ فَهُمْ يَكْتُبُونَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 47,
    "chapter_id": 68,
    "name_arabic": "القلم"
  },
  {
    "verse_id": 5319,
    "text_uthmani": "فَاصْبِرْ لِحُكْمِ رَبِّكَ وَلَا تَكُن كَصَاحِبِ الْحُوتِ إِذْ نَادَى وَهُوَ مَكْظُومٌ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 48,
    "chapter_id": 68,
    "name_arabic": "القلم"
  },
  {
    "verse_id": 5320,
    "text_uthmani": "لَوْلَا أَن تَدَارَكَهُ نِعْمَةٌ مِّن رَّبِّهِ لَنُبِذَ بِالْعَرَاء وَهُوَ مَذْمُومٌ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 49,
    "chapter_id": 68,
    "name_arabic": "القلم"
  },
  {
    "verse_id": 5321,
    "text_uthmani": "فَاجْتَبَاهُ رَبُّهُ فَجَعَلَهُ مِنَ الصَّالِحِينَ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 50,
    "chapter_id": 68,
    "name_arabic": "القلم"
  },
  {
    "verse_id": 5322,
