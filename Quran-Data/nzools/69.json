    "verse_number": 23,
    "chapter_id": 69,
    "name_arabic": "الحاقة"
  },
  {
    "verse_id": 5347,
    "text_uthmani": "كُلُوا وَاشْرَبُوا هَنِيئًا بِمَا أَسْلَفْتُمْ فِي الْأَيَّامِ الْخَالِيَةِ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 24,
    "chapter_id": 69,
    "name_arabic": "الحاقة"
  },
  {
    "verse_id": 5348,
    "text_uthmani": "وَأَمَّا مَنْ أُوتِيَ كِتَابَهُ بِشِمَالِهِ فَيَقُولُ يَا لَيْتَنِي لَمْ أُوتَ كِتَابِيهْ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 25,
    "chapter_id": 69,
    "name_arabic": "الحاقة"
  },
  {
    "verse_id": 5349,
    "text_uthmani": "وَلَمْ أَدْرِ مَا حِسَابِيهْ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 26,
    "chapter_id": 69,
    "name_arabic": "الحاقة"
  },
  {
    "verse_id": 5350,
