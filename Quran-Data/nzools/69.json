  },
  {
    "verse_id": 5325,
    "text_uthmani": "مَا الْحَاقَّةُ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 2,
    "chapter_id": 69,
    "name_arabic": "الحاقة"
  },
  {
    "verse_id": 5326,
    "text_uthmani": "وَمَا أَدْرَاكَ مَا الْحَاقَّةُ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 3,
    "chapter_id": 69,
    "name_arabic": "الحاقة"
  },
  {
    "verse_id": 5327,
    "text_uthmani": "كَذَّبَتْ ثَمُودُ وَعَادٌ بِالْقَارِعَةِ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 4,
    "chapter_id": 69,
    "name_arabic": "الحاقة"
  },
  {
    "verse_id": 5328,
    "text_uthmani": "فَأَمَّا ثَمُودُ فَأُهْلِكُوا بِالطَّاغِيَةِ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 5,
    "chapter_id": 69,
    "name_arabic": "الحاقة"
  },
  {
    "verse_id": 5329,
    "text_uthmani": "وَأَمَّا عَادٌ فَأُهْلِكُوا بِرِيحٍ صَرْصَرٍ عَاتِيَةٍ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 6,
    "chapter_id": 69,
    "name_arabic": "الحاقة"
  },
  {
    "verse_id": 5330,
    "text_uthmani": "سَخَّرَهَا عَلَيْهِمْ سَبْعَ لَيَالٍ وَثَمَانِيَةَ أَيَّامٍ حُسُومًا فَتَرَى الْقَوْمَ فِيهَا صَرْعَى كَأَنَّهُمْ أَعْجَازُ نَخْلٍ خَاوِيَةٍ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 7,
    "chapter_id": 69,
    "name_arabic": "الحاقة"
  },
  {
    "verse_id": 5331,
    "text_uthmani": "فَهَلْ تَرَى لَهُم مِّن بَاقِيَةٍ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 8,
    "chapter_id": 69,
    "name_arabic": "الحاقة"
  },
  {
    "verse_id": 5332,
    "text_uthmani": "وَجَاء فِرْعَوْنُ وَمَن قَبْلَهُ وَالْمُؤْتَفِكَاتُ بِالْخَاطِئَةِ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 9,
    "chapter_id": 69,
    "name_arabic": "الحاقة"
  },
  {
    "verse_id": 5333,
    "text_uthmani": "فَعَصَوْا رَسُولَ رَبِّهِمْ فَأَخَذَهُمْ أَخْذَةً رَّابِيَةً",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 10,
    "chapter_id": 69,
    "name_arabic": "الحاقة"
  },
  {
    "verse_id": 5334,
    "text_uthmani": "إِنَّا لَمَّا طَغَى الْمَاء حَمَلْنَاكُمْ فِي الْجَارِيَةِ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 11,
    "chapter_id": 69,
    "name_arabic": "الحاقة"
  },
  {
    "verse_id": 5335,
    "text_uthmani": "لِنَجْعَلَهَا لَكُمْ تَذْكِرَةً وَتَعِيَهَا أُذُنٌ وَاعِيَةٌ",
    "source": "الاستيعاب في بيان الأسباب",
    "reason": "أخْبَرَنا أبُو بَكْرٍ التَّمِيمِيُّ، قالَ: أخْبَرَنا عَبْدُ اللَّهِ بْنُ مُحَمَّدِ بْنِ جَعْفَرٍ، قالَ: حَدَّثَنا الوَلِيدُ بْنُ أبانٍ، قالَ: حَدَّثَنا العَبّاسُ الدُّورِيُّ، قالَ: حَدَّثَنا بِشْرُ بْنُ آدَمَ، قالَ: حَدَّثَنا عَبْدُ اللَّهِ بْنُ الزُّبَيْرِ، قالَ: سَمِعْتُ صالِحَ بْنَ هَيْثَمٍ يَقُولُ: سَمِعْتُ بُرَيْدَةَ يَقُولُ:  قالَ رَسُولُ اللَّهِ ﷺ لِعَلِيٍّ: ”إنَّ اللَّهَ أمَرَنِي أنْ أُدْنِيَكَ ولا أُقْصِيَكَ، وأنْ أُعَلِّمَكَ وتَعِيَ، وحَقٌّ عَلى اللَّهِ أنْ تَعِيَ“ . فَنَزَلَتْ: ﴿وتَعِيَها أُذُنٌ واعِيَةٌ﴾ . '",
    "verse_number": 12,
    "chapter_id": 69,
    "name_arabic": "الحاقة"
  },
  {
    "verse_id": 5336,
    "text_uthmani": "فَإِذَا نُفِخَ فِي الصُّورِ نَفْخَةٌ وَاحِدَةٌ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 13,
    "chapter_id": 69,
    "name_arabic": "الحاقة"
  },
  {
    "verse_id": 5337,
    "text_uthmani": "وَحُمِلَتِ الْأَرْضُ وَالْجِبَالُ فَدُكَّتَا دَكَّةً وَاحِدَةً",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 14,
    "chapter_id": 69,
    "name_arabic": "الحاقة"
  },
  {
    "verse_id": 5338,
    "text_uthmani": "فَيَوْمَئِذٍ وَقَعَتِ الْوَاقِعَةُ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 15,
    "chapter_id": 69,
    "name_arabic": "الحاقة"
  },
  {
    "verse_id": 5339,
    "text_uthmani": "وَانشَقَّتِ السَّمَاء فَهِيَ يَوْمَئِذٍ وَاهِيَةٌ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 16,
    "chapter_id": 69,
    "name_arabic": "الحاقة"
  },
  {
    "verse_id": 5340,
    "text_uthmani": "وَالْمَلَكُ عَلَى أَرْجَائِهَا وَيَحْمِلُ عَرْشَ رَبِّكَ فَوْقَهُمْ يَوْمَئِذٍ ثَمَانِيَةٌ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 17,
    "chapter_id": 69,
    "name_arabic": "الحاقة"
  },
  {
    "verse_id": 5341,
    "text_uthmani": "يَوْمَئِذٍ تُعْرَضُونَ لَا تَخْفَى مِنكُمْ خَافِيَةٌ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 18,
    "chapter_id": 69,
    "name_arabic": "الحاقة"
  },
  {
    "verse_id": 5342,
    "text_uthmani": "فَأَمَّا مَنْ أُوتِيَ كِتَابَهُ بِيَمِينِهِ فَيَقُولُ هَاؤُمُ اقْرَؤُوا كِتَابِيهْ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 19,
    "chapter_id": 69,
    "name_arabic": "الحاقة"
  },
  {
    "verse_id": 5343,
    "text_uthmani": "إِنِّي ظَنَنتُ أَنِّي مُلَاقٍ حِسَابِيهْ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 20,
    "chapter_id": 69,
    "name_arabic": "الحاقة"
  },
  {
    "verse_id": 5344,
    "text_uthmani": "فَهُوَ فِي عِيشَةٍ رَّاضِيَةٍ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 21,
    "chapter_id": 69,
    "name_arabic": "الحاقة"
  },
  {
    "verse_id": 5345,
    "text_uthmani": "فِي جَنَّةٍ عَالِيَةٍ",
    "source": "____",
    "reason": " لم نقف على شيء",
    "verse_number": 22,
    "chapter_id": 69,
    "name_arabic": "الحاقة"
  },
  {
    "verse_id": 5346,
