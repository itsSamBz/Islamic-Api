        "chapter_id": 89,
        "name_arabic": "الفجر"
      }
    ]
  },
  {
    "verse_id": 6013,
    "elements": [
      {
        "text_uthmani": "وَتُحِبُّونَ الْمَالَ حُبًّا جَمًّا",
