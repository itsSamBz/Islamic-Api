  },
  {
    "verse_id": 6017,
    "elements": [
      {
        "text_uthmani": "يَقُولُ يَا لَيْتَنِي قَدَّمْتُ لِحَيَاتِي",
        "verse_number": 24,
        "chapter_id": 89,
        "name_arabic": "الفجر"
      }
    ]
  },
  {
    "verse_id": 6018,
    "elements": [
