        "chapter_id": 89,
        "name_arabic": "الفجر"
      }
    ]
  },
  {
    "verse_id": 6006,
    "elements": [
      {
        "text_uthmani": "فَصَبَّ عَلَيْهِمْ رَبُّكَ سَوْطَ عَذَابٍ",
        "verse_number": 13,
        "chapter_id": 89,
        "name_arabic": "الفجر"
      }
    ]
  },
  {
    "verse_id": 6007,
    "elements": [
      {
        "text_uthmani": "إِنَّ رَبَّكَ لَبِالْمِرْصَادِ",
