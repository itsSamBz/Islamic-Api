        "chapter_id": 89,
        "name_arabic": "الفجر"
      }
    ]
  },
  {
    "verse_id": 6011,
    "elements": [
      {
        "text_uthmani": "وَلَا تَحَاضُّونَ عَلَى طَعَامِ الْمِسْكِينِ",
        "verse_number": 18,
        "chapter_id": 89,
        "name_arabic": "الفجر"
      }
    ]
  },
  {
    "verse_id": 6012,
    "elements": [
