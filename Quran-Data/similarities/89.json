        "chapter_id": 89,
        "name_arabic": "الفجر"
      }
    ]
  },
  {
    "verse_id": 6003,
    "elements": [
      {
        "text_uthmani": "وَفِرْعَوْنَ ذِي الْأَوْتَادِ",
