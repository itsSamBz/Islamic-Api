        "name_arabic": "الفجر"
      }
    ]
  },
  {
    "verse_id": 6001,
    "elements": [
      {
        "text_uthmani": "الَّتِي لَمْ يُخْلَقْ مِثْلُهَا فِي الْبِلَادِ",
        "verse_number": 8,
        "chapter_id": 89,
        "name_arabic": "الفجر"
      }
    ]
  },
  {
    "verse_id": 6002,
    "elements": [
      {
        "text_uthmani": "وَثَمُودَ الَّذِينَ جَابُوا الصَّخْرَ بِالْوَادِ",
