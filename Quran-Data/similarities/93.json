  {
    "verse_id": 6082,
    "elements": [
      {
        "text_uthmani": "مَا وَدَّعَكَ رَبُّكَ وَمَا قَلَى",
        "verse_number": 3,
        "chapter_id": 93,
        "name_arabic": "الضحى"
      }
    ]
  },
  {
    "verse_id": 6083,
    "elements": [
      {
        "text_uthmani": "وَلَلْآخِرَةُ خَيْرٌ لَّكَ مِنَ الْأُولَى",
        "verse_number": 4,
        "chapter_id": 93,
        "name_arabic": "الضحى"
      }
    ]
  },
  {
    "verse_id": 6084,
    "elements": [
      {
        "text_uthmani": "وَلَسَوْفَ يُعْطِيكَ رَبُّكَ فَتَرْضَى",
        "verse_number": 5,
        "chapter_id": 93,
        "name_arabic": "الضحى"
      }
    ]
  },
  {
    "verse_id": 6085,
    "elements": [
      {
        "text_uthmani": "أَلَمْ يَجِدْكَ يَتِيمًا فَآوَى",
        "verse_number": 6,
        "chapter_id": 93,
        "name_arabic": "الضحى"
      }
    ]
  },
  {
    "verse_id": 6086,
    "elements": [
      {
        "text_uthmani": "وَوَجَدَكَ ضَالًّا فَهَدَى",
        "verse_number": 7,
        "chapter_id": 93,
        "name_arabic": "الضحى"
      }
    ]
  },
  {
    "verse_id": 6087,
    "elements": [
      {
        "text_uthmani": "وَوَجَدَكَ عَائِلًا فَأَغْنَى",
        "verse_number": 8,
        "chapter_id": 93,
        "name_arabic": "الضحى"
      }
    ]
  },
  {
    "verse_id": 6088,
    "elements": [
      {
        "text_uthmani": "فَأَمَّا الْيَتِيمَ فَلَا تَقْهَرْ",
        "verse_number": 9,
        "chapter_id": 93,
        "name_arabic": "الضحى"
      }
    ]
  },
  {
    "verse_id": 6089,
    "elements": [
      {
        "text_uthmani": "وَأَمَّا السَّائِلَ فَلَا تَنْهَرْ",
        "verse_number": 10,
        "chapter_id": 93,
        "name_arabic": "الضحى"
      }
    ]
  },
  {
    "verse_id": 6090,
    "elements": [
      {
        "text_uthmani": "وَأَمَّا بِنِعْمَةِ رَبِّكَ فَحَدِّثْ",
        "verse_number": 11,
        "chapter_id": 93,
        "name_arabic": "الضحى"
      }
    ]
  }
