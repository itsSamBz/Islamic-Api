  {
    "verse_id": 5554,
    "elements": [
      {
        "text_uthmani": "أَيَحْسَبُ الْإِنسَانُ أَلَّن نَجْمَعَ عِظَامَهُ",
        "name_arabic": "القيامة",
        "chapter_id": 75,
        "verse_number": 3,
        "content": [
          {
            "red": "أَيَحْسَبُ الْإِنسَانُ"
          },
          {
            "black": "أَلَّن نَّجْمَعَ عِظَامَهُ"
          }
        ]
      },
      {
        "sim_chapter_name": "القيامة",
        "sim_chapter_id": 75,
        "sim_verse_number": 36,
        "content": [
          {
            "red": "أَيَحْسَبُ الْإِنسَانُ"
          },
          {
            "black": "أَن يُتْرَكَ سُدًى"
          }
        ]
      }
    ]
  },
  {
    "verse_id": 5555,
    "elements": [
      {
        "text_uthmani": "بَلَى قَادِرِينَ عَلَى أَن نُّسَوِّيَ بَنَانَهُ",
        "verse_number": 4,
        "chapter_id": 75,
        "name_arabic": "القيامة"
      }
    ]
  },
  {
    "verse_id": 5556,
    "elements": [
      {
        "text_uthmani": "بَلْ يُرِيدُ الْإِنسَانُ لِيَفْجُرَ أَمَامَهُ",
        "verse_number": 5,
        "chapter_id": 75,
        "name_arabic": "القيامة"
      }
    ]
  },
  {
    "verse_id": 5557,
    "elements": [
      {
        "text_uthmani": "يَسْأَلُ أَيَّانَ يَوْمُ الْقِيَامَةِ",
        "name_arabic": "القيامة",
        "chapter_id": 75,
        "verse_number": 6,
        "content": [
          {
            "red": "يَسْأَلُ أَيَّانَ يَوْمُ"
          },
          {
            "black": "الْقِيَامَةِ"
          }
        ]
      },
      {
        "sim_chapter_name": "الذاريات",
        "sim_chapter_id": 51,
        "sim_verse_number": 12,
        "content": [
          {
            "red": "يَسْأَلُ"
          },
          {
            "dimgray": "ونَ"
          },
          {
            "red": "أَيَّانَ يَوْمُ"
          },
          {
            "black": "الدِّينِ"
          }
        ]
      }
    ]
  },
  {
    "verse_id": 5558,
    "elements": [
      {
        "text_uthmani": "فَإِذَا بَرِقَ الْبَصَرُ",
        "verse_number": 7,
        "chapter_id": 75,
        "name_arabic": "القيامة"
      }
    ]
  },
  {
    "verse_id": 5559,
    "elements": [
      {
        "text_uthmani": "وَخَسَفَ الْقَمَرُ",
        "verse_number": 8,
        "chapter_id": 75,
        "name_arabic": "القيامة"
      }
    ]
  },
  {
    "verse_id": 5560,
    "elements": [
      {
        "text_uthmani": "وَجُمِعَ الشَّمْسُ وَالْقَمَرُ",
        "verse_number": 9,
        "chapter_id": 75,
        "name_arabic": "القيامة"
      }
    ]
  },
  {
    "verse_id": 5561,
    "elements": [
      {
        "text_uthmani": "يَقُولُ الْإِنسَانُ يَوْمَئِذٍ أَيْنَ الْمَفَرُّ",
        "verse_number": 10,
        "chapter_id": 75,
        "name_arabic": "القيامة"
      }
    ]
  },
  {
    "verse_id": 5562,
    "elements": [
      {
        "text_uthmani": "كَلَّا لَا وَزَرَ",
        "verse_number": 11,
        "chapter_id": 75,
        "name_arabic": "القيامة"
      }
    ]
  },
  {
    "verse_id": 5563,
    "elements": [
      {
        "text_uthmani": "إِلَى رَبِّكَ يَوْمَئِذٍ الْمُسْتَقَرُّ",
        "verse_number": 12,
        "chapter_id": 75,
        "name_arabic": "القيامة"
      }
    ]
  },
  {
    "verse_id": 5564,
    "elements": [
      {
        "text_uthmani": "يُنَبَّأُ الْإِنسَانُ يَوْمَئِذٍ بِمَا قَدَّمَ وَأَخَّرَ",
        "verse_number": 13,
        "chapter_id": 75,
        "name_arabic": "القيامة"
      }
    ]
  },
  {
    "verse_id": 5565,
    "elements": [
      {
        "text_uthmani": "بَلِ الْإِنسَانُ عَلَى نَفْسِهِ بَصِيرَةٌ",
        "verse_number": 14,
        "chapter_id": 75,
        "name_arabic": "القيامة"
      }
    ]
  },
  {
    "verse_id": 5566,
    "elements": [
      {
        "text_uthmani": "وَلَوْ أَلْقَى مَعَاذِيرَهُ",
        "verse_number": 15,
        "chapter_id": 75,
        "name_arabic": "القيامة"
      }
    ]
  },
  {
    "verse_id": 5567,
    "elements": [
      {
        "text_uthmani": "لَا تُحَرِّكْ بِهِ لِسَانَكَ لِتَعْجَلَ بِهِ",
        "verse_number": 16,
        "chapter_id": 75,
        "name_arabic": "القيامة"
      }
    ]
  },
  {
    "verse_id": 5568,
    "elements": [
      {
        "text_uthmani": "إِنَّ عَلَيْنَا جَمْعَهُ وَقُرْآنَهُ",
        "verse_number": 17,
        "chapter_id": 75,
        "name_arabic": "القيامة"
      }
    ]
  },
  {
    "verse_id": 5569,
    "elements": [
      {
        "text_uthmani": "فَإِذَا قَرَأْنَاهُ فَاتَّبِعْ قُرْآنَهُ",
        "verse_number": 18,
        "chapter_id": 75,
        "name_arabic": "القيامة"
      }
    ]
  },
  {
    "verse_id": 5570,
    "elements": [
      {
        "text_uthmani": "ثُمَّ إِنَّ عَلَيْنَا بَيَانَهُ",
        "verse_number": 19,
        "chapter_id": 75,
        "name_arabic": "القيامة"
      }
    ]
  },
  {
    "verse_id": 5571,
    "elements": [
      {
        "text_uthmani": "كَلَّا بَلْ تُحِبُّونَ الْعَاجِلَةَ",
        "verse_number": 20,
        "chapter_id": 75,
        "name_arabic": "القيامة"
      }
    ]
  },
