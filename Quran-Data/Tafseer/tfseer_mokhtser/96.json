[
  {
    "verse_id": 6107,
    "text_uthmani": "اقْرَأْ بِاسْمِ رَبِّكَ الَّذِي خَلَقَ",
    "tafseer": "اقرأ - أيها الرسول - ما يوحيه الله إليك، مفتتحًا باسم ربك الذي خلق جميع الخلائق.",
    "t_verse_number": 1,
    "t_chapter_id": 96,
    "t_name_arabic": "العلق"
  },
  {
    "verse_id": 6108,
    "text_uthmani": "خَلَقَ الْإِنسَانَ مِنْ عَلَقٍ",
    "tafseer": "خلق الإنسان من قطعة دم متجمدة بعد أن كانت نطفة.",
    "t_verse_number": 2,
    "t_chapter_id": 96,
    "t_name_arabic": "العلق"
  },
  {
    "verse_id": 6109,
    "text_uthmani": "اقْرَأْ وَرَبُّكَ الْأَكْرَمُ",
    "tafseer": "اقرأ - أيها الرسول - ما يوحيه الله إليك، وربك الأكرم الذي لا يداني كرمه كريم، فهو كثير الجود والإحسان.",
    "t_verse_number": 3,
    "t_chapter_id": 96,
    "t_name_arabic": "العلق"
  },
  {
    "verse_id": 6110,
    "text_uthmani": "الَّذِي عَلَّمَ بِالْقَلَمِ",
    "tafseer": "الذي علّم الخط والكتابة بالقلم.",
    "t_verse_number": 4,
    "t_chapter_id": 96,
    "t_name_arabic": "العلق"
  },
  {
    "verse_id": 6111,
    "text_uthmani": "عَلَّمَ الْإِنسَانَ مَا لَمْ يَعْلَمْ",
    "tafseer": "علم الإنسان ما لم يكن يعلمه.",
    "t_verse_number": 5,
    "t_chapter_id": 96,
    "t_name_arabic": "العلق"
  },
  {
    "verse_id": 6112,
    "text_uthmani": "كَلَّا إِنَّ الْإِنسَانَ لَيَطْغَى",
    "tafseer": "حقًّا إن الإنسان الفاجر مثل أبي جهل ليتجاوز الحدّ في تعدّي حدود الله.",
    "t_verse_number": 6,
    "t_chapter_id": 96,
    "t_name_arabic": "العلق"
  },
  {
    "verse_id": 6113,
    "text_uthmani": "أَن رَّآهُ اسْتَغْنَى",
    "tafseer": "لأجل أن رآه استغنى بما لديه من الجاه والمال.",
    "t_verse_number": 7,
    "t_chapter_id": 96,
    "t_name_arabic": "العلق"
  },
  {
    "verse_id": 6114,
    "text_uthmani": "إِنَّ إِلَى رَبِّكَ الرُّجْعَى",
    "tafseer": "إنّ إلى ربك - أيها الإنسان - الرجوع يوم القيامة فيجازي كلًّا بما يستحقه.",
    "t_verse_number": 8,
    "t_chapter_id": 96,
    "t_name_arabic": "العلق"
  },
  {
    "verse_id": 6115,
    "text_uthmani": "أَرَأَيْتَ الَّذِي يَنْهَى",
    "tafseer": "أرأيت أعجب من أمر أبي جهل الذي ينهى.",
    "t_verse_number": 9,
    "t_chapter_id": 96,
    "t_name_arabic": "العلق"
  },
  {
    "verse_id": 6116,
    "text_uthmani": "عَبْدًا إِذَا صَلَّى",
    "tafseer": "عبدنا محمدًا ﷺ إذا صلّى عند الكعبة.",
    "t_verse_number": 10,
    "t_chapter_id": 96,
    "t_name_arabic": "العلق"
  },
  {
    "verse_id": 6117,
    "text_uthmani": "أَرَأَيْتَ إِن كَانَ عَلَى الْهُدَى",
    "tafseer": "أرأيت إن كان هذا المنهي على هدى وبصيرة من ربه؟!",
    "t_verse_number": 11,
    "t_chapter_id": 96,
    "t_name_arabic": "العلق"
  },
  {
    "verse_id": 6118,
    "text_uthmani": "أَوْ أَمَرَ بِالتَّقْوَى",
    "tafseer": "أو كان يأمر الناس بتقوى الله بامتثال أوامره واجتناب نواهيه، أيُنْهى من كان هذا شأنه؟!",
    "t_verse_number": 12,
    "t_chapter_id": 96,
    "t_name_arabic": "العلق"
  },
  {
    "verse_id": 6119,
    "text_uthmani": "أَرَأَيْتَ إِن كَذَّبَ وَتَوَلَّى",
    "tafseer": "أرأيت إن كذّب هذا الناهي بما جاء به الرسول، وأعرض عنه، ألا يخشى الله؟!",
    "t_verse_number": 13,
    "t_chapter_id": 96,
    "t_name_arabic": "العلق"
  },
  {
    "verse_id": 6120,
    "text_uthmani": "أَلَمْ يَعْلَمْ بِأَنَّ اللَّهَ يَرَى",
    "tafseer": "ألم يعلم ناهي هذا العبد عن الصلاة أنّ الله يرى ما يصنع، لا يخفى عليه منه شيء؟!",
    "t_verse_number": 14,
    "t_chapter_id": 96,
    "t_name_arabic": "العلق"
  },
  {
    "verse_id": 6121,
    "text_uthmani": "كَلَّا لَئِن لَّمْ يَنتَهِ لَنَسْفَعًا بِالنَّاصِيَةِ",
    "tafseer": "ليس الأمر كما تصور هذا الجاهل، لئن لم يكفّ عن أذاه لعبدنا وتكذيبه له، لنأخذنّه مجذوبًا إلى النار بمقدم رأسه بعنف.",
    "t_verse_number": 15,
    "t_chapter_id": 96,
    "t_name_arabic": "العلق"
  },
  {
    "verse_id": 6122,
    "text_uthmani": "نَاصِيَةٍ كَاذِبَةٍ خَاطِئَةٍ",
    "tafseer": "صاحب تلك الناصية كاذب في القول، خاطئ في الفعل.",
    "t_verse_number": 16,
    "t_chapter_id": 96,
    "t_name_arabic": "العلق"
  },
  {
    "verse_id": 6123,
    "text_uthmani": "فَلْيَدْعُ نَادِيَه",
    "tafseer": "فليدع حين يؤخذ بمقدم رأسه إلى النار أصحابه وأهل مجلسه يستعين بهم لينقذوه من العذاب.",
    "t_verse_number": 17,
    "t_chapter_id": 96,
    "t_name_arabic": "العلق"
  },
  {
    "verse_id": 6124,
    "text_uthmani": "سَنَدْعُ الزَّبَانِيَةَ",
    "tafseer": "سندعو نحن خَزَنة جهنم من الملائكة الغلاظ الذين لا يعصون الله ما أمرهم، ويفعلون ما يؤمرون، فلينظر أي الفريقين أقوى وأقدر.",
    "t_verse_number": 18,
    "t_chapter_id": 96,
    "t_name_arabic": "العلق"
  },
  {
    "verse_id": 6125,
    "text_uthmani": "كَلَّا لَا تُطِعْهُ وَاسْجُدْ وَاقْتَرِبْ",
    "tafseer": "ليس الأمر كما توهم هذا الظالم أن يصل إليك بسوء، فلا تطعه في أمر ولا نهي، واسجد لله، واقترب منه بالطاعات، فإنها تقرّب إليه.",
    "t_verse_number": 19,
    "t_chapter_id": 96,
    "t_name_arabic": "العلق"
  }
]