[
  {
    "verse_id": 6169,
    "text_uthmani": "أَلْهَاكُمُ التَّكَاثُرُ",
    "tafseer": "شغلكم - أيها الناس - التفاخر بالأموال والأولاد عن طاعة الله.",
    "t_verse_number": 1,
    "t_chapter_id": 102,
    "t_name_arabic": "التكاثر"
  },
  {
    "verse_id": 6170,
    "text_uthmani": "حَتَّى زُرْتُمُ الْمَقَابِرَ",
    "tafseer": "حتى متُّم ودخلتم قبوركم.",
    "t_verse_number": 2,
    "t_chapter_id": 102,
    "t_name_arabic": "التكاثر"
  },
  {
    "verse_id": 6171,
    "text_uthmani": "كَلَّا سَوْفَ تَعْلَمُونَ",
    "tafseer": "ما كان لكم أن يشغلكم التفاخر بها عن طاعة الله، سوف تعلمون عاقبة ذلك الانشغال.",
    "t_verse_number": 3,
    "t_chapter_id": 102,
    "t_name_arabic": "التكاثر"
  },
  {
    "verse_id": 6172,
    "text_uthmani": "ثُمَّ كَلَّا سَوْفَ تَعْلَمُونَ",
    "tafseer": "ثم سوف تعلمون عاقبته.",
    "t_verse_number": 4,
    "t_chapter_id": 102,
    "t_name_arabic": "التكاثر"
  },
  {
    "verse_id": 6173,
    "text_uthmani": "كَلَّا لَوْ تَعْلَمُونَ عِلْمَ الْيَقِينِ",
    "tafseer": "حقًّا لو أنكم تعلمون يقينًا أنكم مبعوثون إلى الله، وأنه سيجازيكم على أعمالكم، لما انشغلتم بالتفاخر بالأموال والأولاد.",
    "t_verse_number": 5,
    "t_chapter_id": 102,
    "t_name_arabic": "التكاثر"
  },
  {
    "verse_id": 6174,
    "text_uthmani": "لَتَرَوُنَّ الْجَحِيمَ",
    "tafseer": "والله لتشاهدنّ النار يوم القيامة.",
    "t_verse_number": 6,
    "t_chapter_id": 102,
    "t_name_arabic": "التكاثر"
  },
  {
    "verse_id": 6175,
    "text_uthmani": "ثُمَّ لَتَرَوُنَّهَا عَيْنَ الْيَقِينِ",
    "tafseer": "ثم لتشاهدنها مشاهدة يقين لا شك فيه.",
    "t_verse_number": 7,
    "t_chapter_id": 102,
    "t_name_arabic": "التكاثر"
  },
  {
    "verse_id": 6176,
    "text_uthmani": "ثُمَّ لَتُسْأَلُنَّ يَوْمَئِذٍ عَنِ النَّعِيمِ",
    "tafseer": "ثم ليسألنّكم الله في ذلك اليوم عما أنعم به عليكم من الصحة والغنى وغيرهما.",
    "t_verse_number": 8,
    "t_chapter_id": 102,
    "t_name_arabic": "التكاثر"
  }
]