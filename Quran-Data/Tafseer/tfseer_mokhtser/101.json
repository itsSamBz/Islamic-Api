[
  {
    "verse_id": 6158,
    "text_uthmani": "الْقَارِعَةُ",
    "tafseer": "الساعة التي تقرع قلوب الناس لعظم هولها.",
    "t_verse_number": 1,
    "t_chapter_id": 101,
    "t_name_arabic": "القارعة"
  },
  {
    "verse_id": 6159,
    "text_uthmani": "مَا الْقَارِعَةُ",
    "tafseer": "ما هذه الساعة التي تقرع قلوب الناس لعظم هولها؟!",
    "t_verse_number": 2,
    "t_chapter_id": 101,
    "t_name_arabic": "القارعة"
  },
  {
    "verse_id": 6160,
    "text_uthmani": "وَمَا أَدْرَاكَ مَا الْقَارِعَةُ",
    "tafseer": "وما أعلمك - أيها الرسول - ما هذه الساعة التي تقرع قلوب الناس لعظم هولها؟! إنها يوم القيامة.",
    "t_verse_number": 3,
    "t_chapter_id": 101,
    "t_name_arabic": "القارعة"
  },
  {
    "verse_id": 6161,
    "text_uthmani": "يَوْمَ يَكُونُ النَّاسُ كَالْفَرَاشِ الْمَبْثُوثِ",
    "tafseer": "يوم تقرع قلوب الناس يكونون كالفراش المُنْتَشِر المتناثر هنا وهناك.",
    "t_verse_number": 4,
    "t_chapter_id": 101,
    "t_name_arabic": "القارعة"
  },
  {
    "verse_id": 6162,
    "text_uthmani": "وَتَكُونُ الْجِبَالُ كَالْعِهْنِ الْمَنفُوشِ",
    "tafseer": "وتكون الجبال مثل الصوف المَندُوف في خفة سيرها وحركتها.",
    "t_verse_number": 5,
    "t_chapter_id": 101,
    "t_name_arabic": "القارعة"
  },
  {
    "verse_id": 6163,
    "text_uthmani": "فَأَمَّا مَن ثَقُلَتْ مَوَازِينُهُ",
    "tafseer": "فأما من رجحت أعماله الصالحة على أعماله السيئة.",
    "t_verse_number": 6,
    "t_chapter_id": 101,
    "t_name_arabic": "القارعة"
  },
  {
    "verse_id": 6164,
    "text_uthmani": "فَهُوَ فِي عِيشَةٍ رَّاضِيَةٍ",
    "tafseer": "فهو في عيشة مرضية ينالها في الجنة.",
    "t_verse_number": 7,
    "t_chapter_id": 101,
    "t_name_arabic": "القارعة"
  },
  {
    "verse_id": 6165,
    "text_uthmani": "وَأَمَّا مَنْ خَفَّتْ مَوَازِينُهُ",
    "tafseer": "وأما من رجحت أعماله السيئة على أعماله الصالحة.",
    "t_verse_number": 8,
    "t_chapter_id": 101,
    "t_name_arabic": "القارعة"
  },
  {
    "verse_id": 6166,
    "text_uthmani": "فَأُمُّهُ هَاوِيَةٌ",
    "tafseer": "فمسكنه ومستقرّه يوم القيامة هو جهنم.",
    "t_verse_number": 9,
    "t_chapter_id": 101,
    "t_name_arabic": "القارعة"
  },
  {
    "verse_id": 6167,
    "text_uthmani": "وَمَا أَدْرَاكَ مَا هِيَهْ",
    "tafseer": "وما أعلمك - أيها الرسول - ما هي؟!",
    "t_verse_number": 10,
    "t_chapter_id": 101,
    "t_name_arabic": "القارعة"
  },
  {
    "verse_id": 6168,
    "text_uthmani": "نَارٌ حَامِيَةٌ",
    "tafseer": "هي نار شديدة الحرارة.",
    "t_verse_number": 11,
    "t_chapter_id": 101,
    "t_name_arabic": "القارعة"
  }
]