[
  {
    "verse_id": 5801,
    "text_uthmani": "إِذَا الشَّمْسُ كُوِّرَتْ",
    "tafseer": "إذا الشمس جُمِع جِرْمها، وذهب ضوؤها.",
    "t_verse_number": 1,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  },
  {
    "verse_id": 5802,
    "text_uthmani": "وَإِذَا النُّجُومُ انكَدَرَتْ",
    "tafseer": "وإذا الكواكب تساقطت ومُحِي ضوؤها.",
    "t_verse_number": 2,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  },
  {
    "verse_id": 5803,
    "text_uthmani": "وَإِذَا الْجِبَالُ سُيِّرَتْ",
    "tafseer": "وإذا الجبال حُرِّكت من مكانها.",
    "t_verse_number": 3,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  },
  {
    "verse_id": 5804,
    "text_uthmani": "وَإِذَا الْعِشَارُ عُطِّلَتْ",
    "tafseer": "وإذا النُّوق الحوامل التي هي أنْفَسُ أموالهم أُهْمِلت بترك أهلها لها.",
    "t_verse_number": 4,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  },
  {
    "verse_id": 5805,
    "text_uthmani": "وَإِذَا الْوُحُوشُ حُشِرَتْ",
    "tafseer": "وإذا الوحوش جُمِعت مع البشر في صعيد واحد.",
    "t_verse_number": 5,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  },
  {
    "verse_id": 5806,
    "text_uthmani": "وَإِذَا الْبِحَارُ سُجِّرَتْ",
    "tafseer": "وإذا البحار أُوقِدت حتى تصير نارًا.",
    "t_verse_number": 6,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  },
  {
    "verse_id": 5807,
    "text_uthmani": "وَإِذَا النُّفُوسُ زُوِّجَتْ",
    "tafseer": "وإذا النفوس قُرِنت بمن يماثلها، فَيُقْرن الفاجر بالفاجر، والتقي بالتقي.",
    "t_verse_number": 7,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  },
  {
    "verse_id": 5808,
    "text_uthmani": "وَإِذَا الْمَوْؤُودَةُ سُئِلَتْ",
    "tafseer": "وإذا الطفلة المدفونة وهي حيّة سألها الله.",
    "t_verse_number": 8,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  },
  {
    "verse_id": 5809,
    "text_uthmani": "بِأَيِّ ذَنبٍ قُتِلَتْ",
    "tafseer": "بأي جريمة قتلك من قتلك؟!",
    "t_verse_number": 9,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  },
  {
    "verse_id": 5810,
    "text_uthmani": "وَإِذَا الصُّحُفُ نُشِرَتْ",
    "tafseer": "وإذا صحف أعمال العباد نُشِرت، ليقرأ كل واحد صحيفة أعماله.",
    "t_verse_number": 10,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  },
  {
    "verse_id": 5811,
    "text_uthmani": "وَإِذَا السَّمَاء كُشِطَتْ",
    "tafseer": "وإذا السماء نُزِعت كما يُنْزَع الجلد عن الشاة.",
    "t_verse_number": 11,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  },
  {
    "verse_id": 5812,
    "text_uthmani": "وَإِذَا الْجَحِيمُ سُعِّرَتْ",
    "tafseer": "وإذا النار أُوقِدت.",
    "t_verse_number": 12,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  },
  {
    "verse_id": 5813,
    "text_uthmani": "وَإِذَا الْجَنَّةُ أُزْلِفَتْ",
    "tafseer": "وإذا الجنة قُرِّبت للمتقين.",
    "t_verse_number": 13,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  },
  {
    "verse_id": 5814,
    "text_uthmani": "عَلِمَتْ نَفْسٌ مَّا أَحْضَرَتْ",
    "tafseer": "عندما يحصل ذلك تعلم كل نفس ما قدمت من الأعمال لذلك اليوم.",
    "t_verse_number": 14,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  },
  {
    "verse_id": 5815,
    "text_uthmani": "فَلَا أُقْسِمُ بِالْخُنَّسِ",
    "tafseer": "أقسم الله بالنجوم الخفية قبل بزوغها في الليل.",
    "t_verse_number": 15,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  },
  {
    "verse_id": 5816,
    "text_uthmani": "الْجَوَارِ الْكُنَّسِ",
    "tafseer": "الجاريات في أفلاكها التي تغيب عند بزوغ الصبح مثل الظباء تدخل كِناسها، أي:بيتها.",
    "t_verse_number": 16,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  },
  {
    "verse_id": 5817,
    "text_uthmani": "وَاللَّيْلِ إِذَا عَسْعَسَ",
    "tafseer": "وأقسم بأول الليل إذا أقبل، وبآخره إذا أدبر.",
    "t_verse_number": 17,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  },
  {
    "verse_id": 5818,
    "text_uthmani": "وَالصُّبْحِ إِذَا تَنَفَّسَ",
    "tafseer": "وأقسم بالصبح إذا بزغ نوره.",
    "t_verse_number": 18,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  },
  {
    "verse_id": 5819,
    "text_uthmani": "إِنَّهُ لَقَوْلُ رَسُولٍ كَرِيمٍ",
    "tafseer": "إن القرآن المنزل على محمد ﷺ لكلام الله بلّغه ملك أمين، وهو جبريل عليه السلام، ائتمنه الله عليه.",
    "t_verse_number": 19,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  },
  {
    "verse_id": 5820,
    "text_uthmani": "ذِي قُوَّةٍ عِندَ ذِي الْعَرْشِ مَكِينٍ",
    "tafseer": "صاحب قوة، ذي منزلة عظيمة عند رب العرش سبحانه.",
    "t_verse_number": 20,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  },
  {
    "verse_id": 5821,
    "text_uthmani": "مُطَاعٍ ثَمَّ أَمِينٍ",
    "tafseer": "يطيعه أهل السماء، مُؤْتَمن على ما يبلغه من الوحي.",
    "t_verse_number": 21,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  },
  {
    "verse_id": 5822,
    "text_uthmani": "وَمَا صَاحِبُكُم بِمَجْنُونٍ",
    "tafseer": "وما محمد ﷺ الملازم لكم الذي تعرفون عقله وأمانته وصدقه بمجنون كما تدّعون بهتانًا.",
    "t_verse_number": 22,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  },
  {
    "verse_id": 5823,
    "text_uthmani": "وَلَقَدْ رَآهُ بِالْأُفُقِ الْمُبِينِ",
    "tafseer": "ولقد رأى صاحبكم جبريل على صورته التي خُلِقَ عليها بأفق السماء الواضح.",
    "t_verse_number": 23,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  },
  {
    "verse_id": 5824,
    "text_uthmani": "وَمَا هُوَ عَلَى الْغَيْبِ بِضَنِينٍ",
    "tafseer": "وليس صاحبكم ببخيل عليكم يبخل أن يبلغكم ما أُمِر بتبلغيه إليكم، ولا يأخذ أجرًا كما يأخذه الكهنة.",
    "t_verse_number": 24,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  },
  {
    "verse_id": 5825,
    "text_uthmani": "وَمَا هُوَ بِقَوْلِ شَيْطَانٍ رَجِيمٍ",
    "tafseer": "وليس هذا القرآن من كلام شيطان مطرود من رحمة الله.",
    "t_verse_number": 25,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  },
  {
    "verse_id": 5826,
    "text_uthmani": "فَأَيْنَ تَذْهَبُونَ",
    "tafseer": "فأي طريق تسلكونها لإنكار أنه من الله بعد هذه الحجج؟!",
    "t_verse_number": 26,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  },
  {
    "verse_id": 5827,
    "text_uthmani": "إِنْ هُوَ إِلَّا ذِكْرٌ لِّلْعَالَمِينَ",
    "tafseer": "ليس القرآن إلا تذكيرًا وموعظة للجن والإنس.",
    "t_verse_number": 27,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  },
  {
    "verse_id": 5828,
    "text_uthmani": "لِمَن شَاء مِنكُمْ أَن يَسْتَقِيمَ",
    "tafseer": "لمن شاء منكم أن يستقيم على طريق الحق.",
    "t_verse_number": 28,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  },
  {
    "verse_id": 5829,
    "text_uthmani": "وَمَا تَشَاؤُونَ إِلَّا أَن يَشَاء اللَّهُ رَبُّ الْعَالَمِينَ",
    "tafseer": "وما تشاؤون استقامة ولا غيرها إلا أن يشاء الله ذلك، رب الخلائق كلها.",
    "t_verse_number": 29,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  }
]