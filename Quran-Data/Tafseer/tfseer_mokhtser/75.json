[
  {
    "verse_id": 5552,
    "text_uthmani": "لَا أُقْسِمُ بِيَوْمِ الْقِيَامَةِ",
    "tafseer": "أقسم الله بيوم القيامة يوم يقوم الناس لرب العالمين.",
    "t_verse_number": 1,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5553,
    "text_uthmani": "وَلَا أُقْسِمُ بِالنَّفْسِ اللَّوَّامَةِ",
    "tafseer": "وأقسم بالنفس الطيبة التي تلوم صاحبها على التقصير في الأعمال الصالحة، وعلى فعل السيئات، أقسم بهذين الأمرين ليبعثنّ الناس للحساب والجزاء.",
    "t_verse_number": 2,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5554,
    "text_uthmani": "أَيَحْسَبُ الْإِنسَانُ أَلَّن نَجْمَعَ عِظَامَهُ",
    "tafseer": "أيظنّ الإنسان أن لن نجمع عظامه بعد موته للبعث؟!",
    "t_verse_number": 3,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5555,
    "text_uthmani": "بَلَى قَادِرِينَ عَلَى أَن نُّسَوِّيَ بَنَانَهُ",
    "tafseer": "بلى، نقدر مع جمعها على إعادة أطراف أصابعه خلْقًا سويًّا كما كانت.",
    "t_verse_number": 4,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5556,
    "text_uthmani": "بَلْ يُرِيدُ الْإِنسَانُ لِيَفْجُرَ أَمَامَهُ",
    "tafseer": "بل يريد الإنسان بإنكاره البعث أن يستمرّ على فجوره مستقبلًا دون رادع.",
    "t_verse_number": 5,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5557,
    "text_uthmani": "يَسْأَلُ أَيَّانَ يَوْمُ الْقِيَامَةِ",
    "tafseer": "يسأل على وجه الاستبعاد عن يوم القيامة:متى يقع؟",
    "t_verse_number": 6,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5558,
    "text_uthmani": "فَإِذَا بَرِقَ الْبَصَرُ",
    "tafseer": "فإذا تحيّر البصر واندهش حين يرى ما كان يكذّب به.",
    "t_verse_number": 7,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5559,
    "text_uthmani": "وَخَسَفَ الْقَمَرُ",
    "tafseer": "وذهب ضوء القمر.",
    "t_verse_number": 8,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5560,
    "text_uthmani": "وَجُمِعَ الشَّمْسُ وَالْقَمَرُ",
    "tafseer": "وجمع جرم الشمس والقمر.",
    "t_verse_number": 9,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5561,
    "text_uthmani": "يَقُولُ الْإِنسَانُ يَوْمَئِذٍ أَيْنَ الْمَفَرُّ",
    "tafseer": "يقول الإنسان الفاجر في ذلك اليوم:أين الفرار؟!",
    "t_verse_number": 10,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5562,
    "text_uthmani": "كَلَّا لَا وَزَرَ",
    "tafseer": "لا فرار في ذلك اليوم، ولا مَلْجأ يلجأ إليه الفاجر، ولا مُعْتَصَم يعتصم به.",
    "t_verse_number": 11,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5563,
    "text_uthmani": "إِلَى رَبِّكَ يَوْمَئِذٍ الْمُسْتَقَرُّ",
    "tafseer": "إلى ربك - أيها الرسول - في ذلك اليوم المرجع والمصير للحساب والجزاء",
    "t_verse_number": 12,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5564,
    "text_uthmani": "يُنَبَّأُ الْإِنسَانُ يَوْمَئِذٍ بِمَا قَدَّمَ وَأَخَّرَ",
    "tafseer": "يخبر الإنسان في ذلك اليوم بما قدّم من أعماله، وبما أخّر منها.",
    "t_verse_number": 13,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5565,
    "text_uthmani": "بَلِ الْإِنسَانُ عَلَى نَفْسِهِ بَصِيرَةٌ",
    "tafseer": "بل الإنسان شاهد على نفسه حيث تشهد عليه جوارحه بما اكتسبه من إثم.",
    "t_verse_number": 14,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5566,
    "text_uthmani": "وَلَوْ أَلْقَى مَعَاذِيرَهُ",
    "tafseer": "ولو جاء بأعذار يجادل بها عن نفسه أنه ما عمل سوءًا لم تنفعه.",
    "t_verse_number": 15,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5567,
    "text_uthmani": "لَا تُحَرِّكْ بِهِ لِسَانَكَ لِتَعْجَلَ بِهِ",
    "tafseer": "لا تحرِّك - أيها الرسول - لسانك بالقرآن مُتَعَجِّلًا أن ينفلت منك.",
    "t_verse_number": 16,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5568,
    "text_uthmani": "إِنَّ عَلَيْنَا جَمْعَهُ وَقُرْآنَهُ",
    "tafseer": "إن علينا أن نجمعه لك في صدرك، وإثبات قراءته على لسانك.",
    "t_verse_number": 17,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5569,
    "text_uthmani": "فَإِذَا قَرَأْنَاهُ فَاتَّبِعْ قُرْآنَهُ",
    "tafseer": "فإذا أتمّ جبريل قراءته عليك فأنصت إلى قراءته واستمع.",
    "t_verse_number": 18,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5570,
    "text_uthmani": "ثُمَّ إِنَّ عَلَيْنَا بَيَانَهُ",
    "tafseer": "ثم إن علينا تفسيره لك.",
    "t_verse_number": 19,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5571,
    "text_uthmani": "كَلَّا بَلْ تُحِبُّونَ الْعَاجِلَةَ",
    "tafseer": "كلّا، ليس الأمر كما ادعيتم من استحالة البعث، فأنتم تعلمون أن القادر على خلقكم ابتداءً لا يعجز عن إحيائكم بعد موتكم، لكن سبب تكذيبكم بالبعث هو حبكم للحياة الدنيا سريعة الانقضاء.",
    "t_verse_number": 20,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5572,
    "text_uthmani": "وَتَذَرُونَ الْآخِرَةَ",
    "tafseer": "وترككم للحياة الآخرة التي طريقها القيام بما أمركم الله به من الطاعات، وترك ما نهاكم عنه من المحرمات.",
    "t_verse_number": 21,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5573,
    "text_uthmani": "وُجُوهٌ يَوْمَئِذٍ نَّاضِرَةٌ",
    "tafseer": "وجوه أهل الإيمان والسعادة في ذلك اليوم بَهِيَّة لها نور.",
    "t_verse_number": 22,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5574,
    "text_uthmani": "إِلَى رَبِّهَا نَاظِرَةٌ",
    "tafseer": "ناظرة إلى ربها متمتِّعة بذلك.",
    "t_verse_number": 23,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5575,
    "text_uthmani": "وَوُجُوهٌ يَوْمَئِذٍ بَاسِرَةٌ",
    "tafseer": "ووجوه أهل الكفر والشقاء في ذلك اليوم عابسة.",
    "t_verse_number": 24,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5576,
    "text_uthmani": "تَظُنُّ أَن يُفْعَلَ بِهَا فَاقِرَةٌ",
    "tafseer": "توقن أن ينزل بها عقاب عظيم، وعذاب أليم.",
    "t_verse_number": 25,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5577,
    "text_uthmani": "كَلَّا إِذَا بَلَغَتْ التَّرَاقِيَ",
    "tafseer": "ليس الأمر كما يتصور المشركون من أنهم إذا ماتوا لا يُعَذَّبون، فإذا وصلت نفس أحدهم أعالي صدره.",
    "t_verse_number": 26,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5578,
    "text_uthmani": "وَقِيلَ مَنْ رَاقٍ",
    "tafseer": "وقال بعض الناس لبعض:من يَرْقِي هذا لعله يُشْفى؟!",
    "t_verse_number": 27,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5579,
    "text_uthmani": "وَظَنَّ أَنَّهُ الْفِرَاقُ",
    "tafseer": "وأيقن من في النَّزْع حينئذ أنه فراق الدنيا بالموت.",
    "t_verse_number": 28,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5580,
    "text_uthmani": "وَالْتَفَّتِ السَّاقُ بِالسَّاقِ",
    "tafseer": "واجتمعت الشدائد عند نهاية الدنيا وبداية الآخرة.",
    "t_verse_number": 29,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5581,
    "text_uthmani": "إِلَى رَبِّكَ يَوْمَئِذٍ الْمَسَاقُ",
    "tafseer": "إذا حصل ذلك يُساق الميت إلى ربه.",
    "t_verse_number": 30,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5582,
    "text_uthmani": "فَلَا صَدَّقَ وَلَا صَلَّى",
    "tafseer": "فلا صَدَّق الكافر بما جاء به رسوله، ولا صلى لله سبحانه.",
    "t_verse_number": 31,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5583,
    "text_uthmani": "وَلَكِن كَذَّبَ وَتَوَلَّى",
    "tafseer": "ولكن كذب بما جاءه به رسوله، وأعرض عنه.",
    "t_verse_number": 32,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5584,
    "text_uthmani": "ثُمَّ ذَهَبَ إِلَى أَهْلِهِ يَتَمَطَّى",
    "tafseer": "ثم ذهب هذا الكافر إلى أهله يختال في مشيته من الكبر.",
    "t_verse_number": 33,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5585,
    "text_uthmani": "أَوْلَى لَكَ فَأَوْلَى",
    "tafseer": "فتوعد الله الكافر بأن عذابه قد وليه وقرب منه.",
    "t_verse_number": 34,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5586,
    "text_uthmani": "ثُمَّ أَوْلَى لَكَ فَأَوْلَى",
    "tafseer": "ثم أعاد الجملة على سبيل التأكيد، فقال:﴿ثُمَّ أوْلى لَكَ فَأَوْلى﴾.",
    "t_verse_number": 35,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5587,
    "text_uthmani": "أَيَحْسَبُ الْإِنسَانُ أَن يُتْرَكَ سُدًى",
    "tafseer": "أيظنّ الإنسان أن الله تاركه مُهْمَلًا دون أن يكلفه بشرع؟",
    "t_verse_number": 36,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5588,
    "text_uthmani": "أَلَمْ يَكُ نُطْفَةً مِّن مَّنِيٍّ يُمْنَى",
    "tafseer": "ألم يكن هذا الإنسان يومًا نُطْفة من مني يُصَبّ في الرحم.",
    "t_verse_number": 37,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5589,
    "text_uthmani": "ثُمَّ كَانَ عَلَقَةً فَخَلَقَ فَسَوَّى",
    "tafseer": "ثم كان بعد ذلك قطعة من دم جامد، ثم خلقه الله، وجعل خلقه سويًّا.",
    "t_verse_number": 38,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5590,
    "text_uthmani": "فَجَعَلَ مِنْهُ الزَّوْجَيْنِ الذَّكَرَ وَالْأُنثَى",
    "tafseer": "فجعل من جنسه النوعين:الذكر والأنثى؟!",
    "t_verse_number": 39,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5591,
    "text_uthmani": "أَلَيْسَ ذَلِكَ بِقَادِرٍ عَلَى أَن يُحْيِيَ الْمَوْتَى",
    "tafseer": "أليس الذي خلق الإنسان من نُطْفة فَعَلَقَة بقادر على إحياء الموتى للحساب والجزاء من جديد؟! بلى، إنه لقادر.",
    "t_verse_number": 40,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  }
]