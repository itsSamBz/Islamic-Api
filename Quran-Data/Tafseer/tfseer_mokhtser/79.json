[
  {
    "verse_id": 5713,
    "text_uthmani": "وَالنَّازِعَاتِ غَرْقًا",
    "tafseer": "أقسم الله بالملائكة التي تجذب أرواح الكفار بشدة وعنف.",
    "t_verse_number": 1,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5714,
    "text_uthmani": "وَالنَّاشِطَاتِ نَشْطًا",
    "tafseer": "وأقسم بالملائكة التي تستلُّ أرواح المؤمنين بسهولة ويسر.",
    "t_verse_number": 2,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5715,
    "text_uthmani": "وَالسَّابِحَاتِ سَبْحًا",
    "tafseer": "وأقسم بالملائكة التي تَسْبَح من السماء إلى الأرض بأمر الله.",
    "t_verse_number": 3,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5716,
    "text_uthmani": "فَالسَّابِقَاتِ سَبْقًا",
    "tafseer": "وأقسم بالملائكة التي تسبق بعضها في أداء أمر الله.",
    "t_verse_number": 4,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5717,
    "text_uthmani": "فَالْمُدَبِّرَاتِ أَمْرًا",
    "tafseer": "وأقسم بالملائكة التي تنفذ ما أمرهم الله به من قضائه مثل الملائكة الموكلين بأعمال العباد، أقسم بذلك كله ليبعثنَّهم للحساب والجزاء.",
    "t_verse_number": 5,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5718,
    "text_uthmani": "يَوْمَ تَرْجُفُ الرَّاجِفَةُ",
    "tafseer": "يوم تهتزّ الأرض عند النفخة الأولى.",
    "t_verse_number": 6,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5719,
    "text_uthmani": "تَتْبَعُهَا الرَّادِفَةُ",
    "tafseer": "تتبع هذه النفخة نفخة ثانية.",
    "t_verse_number": 7,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5720,
    "text_uthmani": "قُلُوبٌ يَوْمَئِذٍ وَاجِفَةٌ",
    "tafseer": "قلوب بعض الناس في ذلك اليوم خائفة.",
    "t_verse_number": 8,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5721,
    "text_uthmani": "أَبْصَارُهَا خَاشِعَةٌ",
    "tafseer": "يظهر على أبصارها أثر الذلة.",
    "t_verse_number": 9,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5722,
    "text_uthmani": "يَقُولُونَ أَئِنَّا لَمَرْدُودُونَ فِي الْحَافِرَةِ",
    "tafseer": "وكانوا يقولون:هل نرجع إلى الحياة بعد أن متنا؟!",
    "t_verse_number": 10,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5723,
    "text_uthmani": "أَئِذَا كُنَّا عِظَامًا نَّخِرَةً",
    "tafseer": "أإذا كنا عظامًا بالية فارغة نرجع بعد ذلك؟!",
    "t_verse_number": 11,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5724,
    "text_uthmani": "قَالُوا تِلْكَ إِذًا كَرَّةٌ خَاسِرَةٌ",
    "tafseer": "قالوا:إذا رجعنا تكون تلك الرجعة خاسرة، مغبونًا صاحبها.",
    "t_verse_number": 12,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5725,
    "text_uthmani": "فَإِنَّمَا هِيَ زَجْرَةٌ وَاحِدَةٌ",
    "tafseer": "أمْر البعث يسير، فإنما هي صيحة واحدة من الملك الموكل بالنفخ.",
    "t_verse_number": 13,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5726,
    "text_uthmani": "فَإِذَا هُم بِالسَّاهِرَةِ",
    "tafseer": "فإذا الجميع أحياء على وجه الأرض بعد أن كانوا أمواتًا في بطنها.",
    "t_verse_number": 14,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5727,
    "text_uthmani": "هَلْ أتَاكَ حَدِيثُ مُوسَى",
    "tafseer": "هل جاءك - أيها الرسول - خبر موسى مع ربه ومع عدوّه فرعون؟!",
    "t_verse_number": 15,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5728,
    "text_uthmani": "إِذْ نَادَاهُ رَبُّهُ بِالْوَادِ الْمُقَدَّسِ طُوًى",
    "tafseer": "حين ناداه ربه سبحانه بوادي طُوى المطهر.",
    "t_verse_number": 16,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5729,
    "text_uthmani": "اذْهَبْ إِلَى فِرْعَوْنَ إِنَّهُ طَغَى",
    "tafseer": "قال له فيما قال:سرْ إلى فرعون، إنه تجاوز الحد في الظلم والاستكبار.",
    "t_verse_number": 17,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5730,
    "text_uthmani": "فَقُلْ هَل لَّكَ إِلَى أَن تَزَكَّى",
    "tafseer": "فقل له:هل لك - يا فرعون - أن تتطهر من الكفر والمعاصي؟",
    "t_verse_number": 18,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5731,
    "text_uthmani": "وَأَهْدِيَكَ إِلَى رَبِّكَ فَتَخْشَى",
    "tafseer": "وأرشدك إلى ربك الذي خلقك ورعاك فتخشاه، فتعمل بما يرضيه، وتتجنب ما يسخطه؟",
    "t_verse_number": 19,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5732,
    "text_uthmani": "فَأَرَاهُ الْآيَةَ الْكُبْرَى",
    "tafseer": "فأظهر له موسى عليه السلام العلامة العظمى الدالة على أنه رسول من ربه، وهي اليد والعصا.",
    "t_verse_number": 20,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5733,
    "text_uthmani": "فَكَذَّبَ وَعَصَى",
    "tafseer": "فما كان من فرعون إلا أنه كذّب بهذه العلامة، وعصى ما أمره به موسى عليه السلام.",
    "t_verse_number": 21,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5734,
    "text_uthmani": "ثُمَّ أَدْبَرَ يَسْعَى",
    "tafseer": "ثم أعرض عن الإيمان بما جاء به موسى.",
    "t_verse_number": 22,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5735,
    "text_uthmani": "فَحَشَرَ فَنَادَى",
    "tafseer": "ورجع يجمع جنوده لمغالبة موسى، فنادى قومه قائلًا:",
    "t_verse_number": 23,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5736,
    "text_uthmani": "فَقَالَ أَنَا رَبُّكُمُ الْأَعْلَى",
    "tafseer": "أنا ربكم الأعلى، فلا طاعة لغيري عليكم.",
    "t_verse_number": 24,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5737,
    "text_uthmani": "فَأَخَذَهُ اللَّهُ نَكَالَ الْآخِرَةِ وَالْأُولَى",
    "tafseer": "فأخذه الله فعاقبه في الدنيا بالغرق في البحر، وعاقبه في الآخرة بإدخاله في أشدّ العذاب.",
    "t_verse_number": 25,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5738,
    "text_uthmani": "إِنَّ فِي ذَلِكَ لَعِبْرَةً لِّمَن يَخْشَى",
    "tafseer": "إن فيما عاقبنا به فرعون في الدنيا والآخرة لموعظة لمن يخشى الله، فهو الذي ينتفع بالمواعظ.",
    "t_verse_number": 26,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5739,
    "text_uthmani": "أَأَنتُمْ أَشَدُّ خَلْقًا أَمِ السَّمَاء بَنَاهَا",
    "tafseer": "أإيجادكم على الله - أيها المكذبون بالبعث - أصعب، أم إيجاد السماء التي بناها؟!",
    "t_verse_number": 27,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5740,
    "text_uthmani": "رَفَعَ سَمْكَهَا فَسَوَّاهَا",
    "tafseer": "جعل سَمْتها في جهة العلوّ رفيعًا، فجعلها مستوية، لا فطور فيها ولا شقوق ولا عيب.",
    "t_verse_number": 28,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5741,
    "text_uthmani": "وَأَغْطَشَ لَيْلَهَا وَأَخْرَجَ ضُحَاهَا",
    "tafseer": "وأظلم ليلها إذا غربت شمسها، وأظهر نورها إذا أشرقت.",
    "t_verse_number": 29,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5742,
    "text_uthmani": "وَالْأَرْضَ بَعْدَ ذَلِكَ دَحَاهَا",
    "tafseer": "والأرض بعد أن خلق السماء بسطها، وأودع فيها منافعها.",
    "t_verse_number": 30,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5743,
    "text_uthmani": "أَخْرَجَ مِنْهَا مَاءهَا وَمَرْعَاهَا",
    "tafseer": "أخرج منها ماءها عيونًا تجري، وأنبت فيها من النبات ما ترعاه الدواب.",
    "t_verse_number": 31,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5744,
    "text_uthmani": "وَالْجِبَالَ أَرْسَاهَا",
    "tafseer": "والجبال جعلها ثابتة على الأرض.",
    "t_verse_number": 32,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5745,
    "text_uthmani": "مَتَاعًا لَّكُمْ وَلِأَنْعَامِكُمْ",
    "tafseer": "كل ذلك منافع لكم - أيها الناس - ولأنعامكم، فالذي خلق هذا كله لا يعجز عن إعادة خلقهم من جديد.",
    "t_verse_number": 33,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5746,
    "text_uthmani": "فَإِذَا جَاءتِ الطَّامَّةُ الْكُبْرَى",
    "tafseer": "فإذا جاءت النفخة الثانية التي تغمر كل شيء بهولها، وقامت القيامة.",
    "t_verse_number": 34,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5747,
    "text_uthmani": "يَوْمَ يَتَذَكَّرُ الْإِنسَانُ مَا سَعَى",
    "tafseer": "يوم تجيء يتذكر الإنسان ما قدم من عمل، خيرًا كان أو شرًّا.",
    "t_verse_number": 35,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5748,
    "text_uthmani": "وَبُرِّزَتِ الْجَحِيمُ لِمَن يَرَى",
    "tafseer": "وجيء بجهنم وأُظْهِرت عيانًا لمن يبصرها.",
    "t_verse_number": 36,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5749,
    "text_uthmani": "فَأَمَّا مَن طَغَى",
    "tafseer": "فأما من تجاوز الحدّ في الضلال.",
    "t_verse_number": 37,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5750,
    "text_uthmani": "وَآثَرَ الْحَيَاةَ الدُّنْيَا",
    "tafseer": "وفضّل الحياة الدنيا الفانية على الحياة الأخرى الباقية.",
    "t_verse_number": 38,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5751,
    "text_uthmani": "فَإِنَّ الْجَحِيمَ هِيَ الْمَأْوَى",
    "tafseer": "فإن النار هي مستقرّه الذي يأوي إليه.",
    "t_verse_number": 39,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5752,
    "text_uthmani": "وَأَمَّا مَنْ خَافَ مَقَامَ رَبِّهِ وَنَهَى النَّفْسَ عَنِ الْهَوَى",
    "tafseer": "وأما من خاف قيامه بين يدي ربه، وكفّ نفسه عن اتباع ما تهواه مما حرّمه الله، فإن الجنة هي مستقرّه الذي يأوي إليه.",
    "t_verse_number": 40,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5753,
    "text_uthmani": "فَإِنَّ الْجَنَّةَ هِيَ الْمَأْوَى",
    "tafseer": "وأما من خاف قيامه بين يدي ربه، وكفّ نفسه عن اتباع ما تهواه مما حرّمه الله، فإن الجنة هي مستقرّه الذي يأوي إليه.",
    "t_verse_number": 41,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5754,
    "text_uthmani": "يَسْأَلُونَكَ عَنِ السَّاعَةِ أَيَّانَ مُرْسَاهَا",
    "tafseer": "يسألك - أيها الرسول - هؤلاء المكذبون بالبعث:متى تقع الساعة؟",
    "t_verse_number": 42,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5755,
    "text_uthmani": "فِيمَ أَنتَ مِن ذِكْرَاهَا",
    "tafseer": "ليس لك علم بها حتى تذكرها لهم، وليس من شأنك ذلك، إنما شأنك الاستعداد لها.",
    "t_verse_number": 43,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5756,
    "text_uthmani": "إِلَى رَبِّكَ مُنتَهَاهَا",
    "tafseer": "إلى ربك وحده مُنْتهى علم الساعة.",
    "t_verse_number": 44,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5757,
    "text_uthmani": "إِنَّمَا أَنتَ مُنذِرُ مَن يَخْشَاهَا",
    "tafseer": "إنما أنت منذر من يخشى الساعة، لأنه الذي ينتفع بإنذارك.",
    "t_verse_number": 45,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5758,
    "text_uthmani": "كَأَنَّهُمْ يَوْمَ يَرَوْنَهَا لَمْ يَلْبَثُوا إِلَّا عَشِيَّةً أَوْ ضُحَاهَا",
    "tafseer": "كأنهم يوم يرون الساعة مشاهدة، لم يلبثوا في حياتهم الدنيا إلا عشية يوم واحد أو بكرته.",
    "t_verse_number": 46,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  }
]