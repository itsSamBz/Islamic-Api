[
  {
    "verse_id": 5932,
    "text_uthmani": "وَالسَّمَاء وَالطَّارِقِ",
    "tafseer": "أقسم الله بالسماء، وأقسم بالنجم الذي يَطْرُق ليلًا.",
    "t_verse_number": 1,
    "t_chapter_id": 86,
    "t_name_arabic": "الطارق"
  },
  {
    "verse_id": 5933,
    "text_uthmani": "وَمَا أَدْرَاكَ مَا الطَّارِقُ",
    "tafseer": "وما أعلمك - أيها الرسول - شأن هذا النجم العظيم؟!",
    "t_verse_number": 2,
    "t_chapter_id": 86,
    "t_name_arabic": "الطارق"
  },
  {
    "verse_id": 5934,
    "text_uthmani": "النَّجْمُ الثَّاقِبُ",
    "tafseer": "هو النجم يثقب السماء بضيائه المتوهج.",
    "t_verse_number": 3,
    "t_chapter_id": 86,
    "t_name_arabic": "الطارق"
  },
  {
    "verse_id": 5935,
    "text_uthmani": "إِن كُلُّ نَفْسٍ لَّمَّا عَلَيْهَا حَافِظٌ",
    "tafseer": "ما من نفس إلا وكَّل الله بها ملكًا يحفظ عليها أعمالها للحساب يوم القيامة.",
    "t_verse_number": 4,
    "t_chapter_id": 86,
    "t_name_arabic": "الطارق"
  },
  {
    "verse_id": 5936,
    "text_uthmani": "فَلْيَنظُرِ الْإِنسَانُ مِمَّ خُلِقَ",
    "tafseer": "فليتأمل الإنسان مم خلقه الله، لتتضح له قدرة الله وعجز الإنسان.",
    "t_verse_number": 5,
    "t_chapter_id": 86,
    "t_name_arabic": "الطارق"
  },
  {
    "verse_id": 5937,
    "text_uthmani": "خُلِقَ مِن مَّاء دَافِقٍ",
    "tafseer": "خلقه الله من ماء ذي اندفاق يُصَبّ في الرحم.",
    "t_verse_number": 6,
    "t_chapter_id": 86,
    "t_name_arabic": "الطارق"
  },
  {
    "verse_id": 5938,
    "text_uthmani": "يَخْرُجُ مِن بَيْنِ الصُّلْبِ وَالتَّرَائِبِ",
    "tafseer": "يخرج هذا الماء من بين العمود العظمي الفقري للرجل، وعظام الصدر.",
    "t_verse_number": 7,
    "t_chapter_id": 86,
    "t_name_arabic": "الطارق"
  },
  {
    "verse_id": 5939,
    "text_uthmani": "إِنَّهُ عَلَى رَجْعِهِ لَقَادِرٌ",
    "tafseer": "إنه سبحانه - إذ خلقه من ذلك الماء المَهِين - قادر على بعثه بعد موته حيًّا للحساب والجزاء.",
    "t_verse_number": 8,
    "t_chapter_id": 86,
    "t_name_arabic": "الطارق"
  },
  {
    "verse_id": 5940,
    "text_uthmani": "يَوْمَ تُبْلَى السَّرَائِرُ",
    "tafseer": "يوم تُخْتَبر السرائر، فيُكْشَف عما كانت تضمره القلوب من النيات والعقائد وغيرها، فيتميز الصالح منها والفاسد.",
    "t_verse_number": 9,
    "t_chapter_id": 86,
    "t_name_arabic": "الطارق"
  },
  {
    "verse_id": 5941,
    "text_uthmani": "فَمَا لَهُ مِن قُوَّةٍ وَلَا نَاصِرٍ",
    "tafseer": "فما للإنسان في ذلك اليوم من قوة يمتنع بها من عذاب الله ولا معين يعينه.",
    "t_verse_number": 10,
    "t_chapter_id": 86,
    "t_name_arabic": "الطارق"
  },
  {
    "verse_id": 5942,
    "text_uthmani": "وَالسَّمَاء ذَاتِ الرَّجْعِ",
    "tafseer": "أقسم الله بالسماء ذات المطر، لأنه ينزل من جهتها مرة بعد مرة.",
    "t_verse_number": 11,
    "t_chapter_id": 86,
    "t_name_arabic": "الطارق"
  },
  {
    "verse_id": 5943,
    "text_uthmani": "وَالْأَرْضِ ذَاتِ الصَّدْعِ",
    "tafseer": "وأقسم بالأرض التي تتشقق عما فيها من النبات والثمر والشجر.",
    "t_verse_number": 12,
    "t_chapter_id": 86,
    "t_name_arabic": "الطارق"
  },
  {
    "verse_id": 5944,
    "text_uthmani": "إِنَّهُ لَقَوْلٌ فَصْلٌ",
    "tafseer": "إن هذا القرآن المنزل على محمد ﷺ لقول يفصل بين الحق والباطل، والصدق والكذب.",
    "t_verse_number": 13,
    "t_chapter_id": 86,
    "t_name_arabic": "الطارق"
  },
  {
    "verse_id": 5945,
    "text_uthmani": "وَمَا هُوَ بِالْهَزْلِ",
    "tafseer": "وليس باللعب والباطل، بل هو الجد والحق.",
    "t_verse_number": 14,
    "t_chapter_id": 86,
    "t_name_arabic": "الطارق"
  },
  {
    "verse_id": 5946,
    "text_uthmani": "إِنَّهُمْ يَكِيدُونَ كَيْدًا",
    "tafseer": "إن المكذبين بما جاءهم رسولهم يكيدون كيدًا كثيرًا ليردّوا دعوته، ويبطلوها.",
    "t_verse_number": 15,
    "t_chapter_id": 86,
    "t_name_arabic": "الطارق"
  },
  {
    "verse_id": 5947,
    "text_uthmani": "وَأَكِيدُ كَيْدًا",
    "tafseer": "وأكيد أنا كيدًا لإظهار الدين ودحض الباطل.",
    "t_verse_number": 16,
    "t_chapter_id": 86,
    "t_name_arabic": "الطارق"
  },
  {
    "verse_id": 5948,
    "text_uthmani": "فَمَهِّلِ الْكَافِرِينَ أَمْهِلْهُمْ رُوَيْدًا",
    "tafseer": "فأمهل - أيها الرسول - هؤلاء الكافرين، أمهلهم قليلًا، ولا تستعجل عذابهم وإهلاكهم",
    "t_verse_number": 17,
    "t_chapter_id": 86,
    "t_name_arabic": "الطارق"
  }
]