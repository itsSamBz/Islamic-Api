[
  {
    "verse_id": 6180,
    "text_uthmani": "وَيْلٌ لِّكُلِّ هُمَزَةٍ لُّمَزَةٍ",
    "tafseer": "وبال وشدة عذاب لكثير الاغتياب للناس، والطعن فيهم.",
    "t_verse_number": 1,
    "t_chapter_id": 104,
    "t_name_arabic": "الهمزة"
  },
  {
    "verse_id": 6181,
    "text_uthmani": "الَّذِي جَمَعَ مَالًا وَعَدَّدَهُ",
    "tafseer": "الذي همّه جمع المال وإحصاؤه، لا همَّ له غير ذلك.",
    "t_verse_number": 2,
    "t_chapter_id": 104,
    "t_name_arabic": "الهمزة"
  },
  {
    "verse_id": 6182,
    "text_uthmani": "يَحْسَبُ أَنَّ مَالَهُ أَخْلَدَهُ",
    "tafseer": "يظن أن ماله الذي جمعه سينجيه من الموت، فيبقى خالدًا في الحياة الدنيا.",
    "t_verse_number": 3,
    "t_chapter_id": 104,
    "t_name_arabic": "الهمزة"
  },
  {
    "verse_id": 6183,
    "text_uthmani": "كَلَّا لَيُنبَذَنَّ فِي الْحُطَمَةِ",
    "tafseer": "ليس الأمر كما تصوّر هذا الجاهل، ليطرحنّ في نار جهنم التي تدق وتكسر كل ما طُرِح فيها لشدة بأسها.",
    "t_verse_number": 4,
    "t_chapter_id": 104,
    "t_name_arabic": "الهمزة"
  },
  {
    "verse_id": 6184,
    "text_uthmani": "وَمَا أَدْرَاكَ مَا الْحُطَمَةُ",
    "tafseer": "وما أعلمك - أيها الرسول - ما هذه النار التي تحطم كل ما طُرِح فيها؟!",
    "t_verse_number": 5,
    "t_chapter_id": 104,
    "t_name_arabic": "الهمزة"
  },
  {
    "verse_id": 6185,
    "text_uthmani": "نَارُ اللَّهِ الْمُوقَدَةُ",
    "tafseer": "إنها نار الله المستعرة.",
    "t_verse_number": 6,
    "t_chapter_id": 104,
    "t_name_arabic": "الهمزة"
  },
  {
    "verse_id": 6186,
    "text_uthmani": "الَّتِي تَطَّلِعُ عَلَى الْأَفْئِدَةِ",
    "tafseer": "التي تنفذ من أجسام الناس إلى قلوبهم.",
    "t_verse_number": 7,
    "t_chapter_id": 104,
    "t_name_arabic": "الهمزة"
  },
  {
    "verse_id": 6187,
    "text_uthmani": "إِنَّهَا عَلَيْهِم مُّؤْصَدَةٌ",
    "tafseer": "إنها على المُعَذَّبين فيها مغلقة.",
    "t_verse_number": 8,
    "t_chapter_id": 104,
    "t_name_arabic": "الهمزة"
  },
  {
    "verse_id": 6188,
    "text_uthmani": "فِي عَمَدٍ مُّمَدَّدَةٍ",
    "tafseer": "بعَمَد ممتدة طويلة حتى لا يخرجوا منها.",
    "t_verse_number": 9,
    "t_chapter_id": 104,
    "t_name_arabic": "الهمزة"
  }
]