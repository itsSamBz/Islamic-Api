[
  {
    "verse_id": 5885,
    "text_uthmani": "إِذَا السَّمَاء انشَقَّتْ",
    "tafseer": "إذا السماء تَصَدَّعت لنزول الملائكة منها.",
    "t_verse_number": 1,
    "t_chapter_id": 84,
    "t_name_arabic": "الإنشقاق"
  },
  {
    "verse_id": 5886,
    "text_uthmani": "وَأَذِنَتْ لِرَبِّهَا وَحُقَّتْ",
    "tafseer": "واستمعت لربها منقادة، وحُقَّ لها ذلك.",
    "t_verse_number": 2,
    "t_chapter_id": 84,
    "t_name_arabic": "الإنشقاق"
  },
  {
    "verse_id": 5887,
    "text_uthmani": "وَإِذَا الْأَرْضُ مُدَّتْ",
    "tafseer": "وإذا الأرض مدّها الله كما يمدّ الأديم.",
    "t_verse_number": 3,
    "t_chapter_id": 84,
    "t_name_arabic": "الإنشقاق"
  },
  {
    "verse_id": 5888,
    "text_uthmani": "وَأَلْقَتْ مَا فِيهَا وَتَخَلَّتْ",
    "tafseer": "وألقت ما فيها من الكنوز والأموات، وتخلّت عنهم.",
    "t_verse_number": 4,
    "t_chapter_id": 84,
    "t_name_arabic": "الإنشقاق"
  },
  {
    "verse_id": 5889,
    "text_uthmani": "وَأَذِنَتْ لِرَبِّهَا وَحُقَّتْ",
    "tafseer": "واستمعت لربها منقادة، وحُقَّ لها ذلك.",
    "t_verse_number": 5,
    "t_chapter_id": 84,
    "t_name_arabic": "الإنشقاق"
  },
  {
    "verse_id": 5890,
    "text_uthmani": "يَا أَيُّهَا الْإِنسَانُ إِنَّكَ كَادِحٌ إِلَى رَبِّكَ كَدْحًا فَمُلَاقِيهِ",
    "tafseer": "يا أيها الإنسان، إنك عامل إما خيرًا وإما شرًّا، فملاقيه يوم القيامة، ليجازيك الله عليه.",
    "t_verse_number": 6,
    "t_chapter_id": 84,
    "t_name_arabic": "الإنشقاق"
  },
  {
    "verse_id": 5891,
    "text_uthmani": "فَأَمَّا مَنْ أُوتِيَ كِتَابَهُ بِيَمِينِهِ",
    "tafseer": "ولما ذكر عمل الإنسان مجملًا فصَّل حال العاملين يوم القيامة، فقال:فأما من أُعْطِي صحيفة أعماله بيده اليمنى.",
    "t_verse_number": 7,
    "t_chapter_id": 84,
    "t_name_arabic": "الإنشقاق"
  },
  {
    "verse_id": 5892,
    "text_uthmani": "فَسَوْفَ يُحَاسَبُ حِسَابًا يَسِيرًا",
    "tafseer": "فسوف يحاسبه الله حسابًا سهلًا يعرض عليه عمله دون مؤاخذة به.",
    "t_verse_number": 8,
    "t_chapter_id": 84,
    "t_name_arabic": "الإنشقاق"
  },
  {
    "verse_id": 5893,
    "text_uthmani": "وَيَنقَلِبُ إِلَى أَهْلِهِ مَسْرُورًا",
    "tafseer": "ويرجع إلى أهله مسرورًا.",
    "t_verse_number": 9,
    "t_chapter_id": 84,
    "t_name_arabic": "الإنشقاق"
  },
  {
    "verse_id": 5894,
    "text_uthmani": "وَأَمَّا مَنْ أُوتِيَ كِتَابَهُ وَرَاء ظَهْرِهِ",
    "tafseer": "وأما من أُعْطِي كتابه بشماله من وراء ظهره.",
    "t_verse_number": 10,
    "t_chapter_id": 84,
    "t_name_arabic": "الإنشقاق"
  },
  {
    "verse_id": 5895,
    "text_uthmani": "فَسَوْفَ يَدْعُو ثُبُورًا",
    "tafseer": "فسينادي بالهلاك على نفسه.",
    "t_verse_number": 11,
    "t_chapter_id": 84,
    "t_name_arabic": "الإنشقاق"
  },
  {
    "verse_id": 5896,
    "text_uthmani": "وَيَصْلَى سَعِيرًا",
    "tafseer": "ويدخل نار جهنم يقاسي حرّها.",
    "t_verse_number": 12,
    "t_chapter_id": 84,
    "t_name_arabic": "الإنشقاق"
  },
  {
    "verse_id": 5897,
    "text_uthmani": "إِنَّهُ كَانَ فِي أَهْلِهِ مَسْرُورًا",
    "tafseer": "إنه كان في الدنيا في أهله فرحًا بما هو عليه من الكفر والمعاصي.",
    "t_verse_number": 13,
    "t_chapter_id": 84,
    "t_name_arabic": "الإنشقاق"
  },
  {
    "verse_id": 5898,
    "text_uthmani": "إِنَّهُ ظَنَّ أَن لَّن يَحُورَ",
    "tafseer": "إنه ظنّ أنه لن يرجع إلى الحياة بعد موته.",
    "t_verse_number": 14,
    "t_chapter_id": 84,
    "t_name_arabic": "الإنشقاق"
  },
  {
    "verse_id": 5899,
    "text_uthmani": "بَلَى إِنَّ رَبَّهُ كَانَ بِهِ بَصِيرًا",
    "tafseer": "بلى، ليرجعنَّه الله إلى الحياة كما خلقه أول مرة، إن ربه كان بحاله بصيرًا لا يخفى عليه منه شيء، وسيجازيه على عمله.",
    "t_verse_number": 15,
    "t_chapter_id": 84,
    "t_name_arabic": "الإنشقاق"
  },
  {
    "verse_id": 5900,
    "text_uthmani": "فَلَا أُقْسِمُ بِالشَّفَقِ",
    "tafseer": "أقسم الله بالحُمْرة التي تكون في الأفق بعد غروب الشمس.",
    "t_verse_number": 16,
    "t_chapter_id": 84,
    "t_name_arabic": "الإنشقاق"
  },
  {
    "verse_id": 5901,
    "text_uthmani": "وَاللَّيْلِ وَمَا وَسَقَ",
    "tafseer": "وأقسم بالليل وما جُمِع فيه.",
    "t_verse_number": 17,
    "t_chapter_id": 84,
    "t_name_arabic": "الإنشقاق"
  },
  {
    "verse_id": 5902,
    "text_uthmani": "وَالْقَمَرِ إِذَا اتَّسَقَ",
    "tafseer": "والقمر إذا اجتمع وتمّ وصار بدرًا.",
    "t_verse_number": 18,
    "t_chapter_id": 84,
    "t_name_arabic": "الإنشقاق"
  },
  {
    "verse_id": 5903,
    "text_uthmani": "لَتَرْكَبُنَّ طَبَقًا عَن طَبَقٍ",
    "tafseer": "لتركبّن - أيها الناس - حالًا بعد حال من نُطْفة فَعَلَقة فَمُضْغة، فحياة فموت فبعث.",
    "t_verse_number": 19,
    "t_chapter_id": 84,
    "t_name_arabic": "الإنشقاق"
  },
  {
    "verse_id": 5904,
    "text_uthmani": "فَمَا لَهُمْ لَا يُؤْمِنُونَ",
    "tafseer": "فما لهؤلاء الكفار لا يؤمنون بالله، واليوم الآخر؟!",
    "t_verse_number": 20,
    "t_chapter_id": 84,
    "t_name_arabic": "الإنشقاق"
  },
  {
    "verse_id": 5905,
    "text_uthmani": "وَإِذَا قُرِئَ عَلَيْهِمُ الْقُرْآنُ لَا يَسْجُدُونَ",
    "tafseer": "وإذا قُرِئ عليهم القرآن لا يسجدون لربّهم؟!",
    "t_verse_number": 21,
    "t_chapter_id": 84,
    "t_name_arabic": "الإنشقاق"
  },
  {
    "verse_id": 5906,
    "text_uthmani": "بَلِ الَّذِينَ كَفَرُواْ يُكَذِّبُونَ",
    "tafseer": "بل الذين كفروا يكذبون بما جاءهم به رسولهم.",
    "t_verse_number": 22,
    "t_chapter_id": 84,
    "t_name_arabic": "الإنشقاق"
  },
  {
    "verse_id": 5907,
    "text_uthmani": "وَاللَّهُ أَعْلَمُ بِمَا يُوعُونَ",
    "tafseer": "والله أعلم بما تحويه صدورهم، لا يخفى عليه من أعمالهم شيء.",
    "t_verse_number": 23,
    "t_chapter_id": 84,
    "t_name_arabic": "الإنشقاق"
  },
  {
    "verse_id": 5908,
    "text_uthmani": "فَبَشِّرْهُم بِعَذَابٍ أَلِيمٍ",
    "tafseer": "فأخْبِرْهم - أيها الرسول - بما ينتظرهم من عذاب موجع.",
    "t_verse_number": 24,
    "t_chapter_id": 84,
    "t_name_arabic": "الإنشقاق"
  },
  {
    "verse_id": 5909,
    "text_uthmani": "إِلَّا الَّذِينَ آمَنُواْ وَعَمِلُواْ الصَّالِحَاتِ لَهُمْ أَجْرٌ غَيْرُ مَمْنُونٍ",
    "tafseer": "إلا الذين آمنوا بالله، وعملوا الأعمال الصالحات، لهم ثواب غير مقطوع، وهو الجنة.",
    "t_verse_number": 25,
    "t_chapter_id": 84,
    "t_name_arabic": "الإنشقاق"
  }
]