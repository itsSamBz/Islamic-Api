[
  {
    "verse_id": 6169,
    "text_uthmani": "أَلْهَاكُمُ التَّكَاثُرُ",
    "tafseer": "[1] شغلكم عن طاعة الله التفاخر بكثرة الأموال والأولاد.",
    "t_verse_number": 1,
    "t_chapter_id": 102,
    "t_name_arabic": "التكاثر"
  },
  {
    "verse_id": 6170,
    "text_uthmani": "حَتَّى زُرْتُمُ الْمَقَابِرَ",
    "tafseer": "[2] واستمر اشتغالكم بذلك إلى أن صرتم إلى المقابر، ودُفنتم فيها.",
    "t_verse_number": 2,
    "t_chapter_id": 102,
    "t_name_arabic": "التكاثر"
  },
  {
    "verse_id": 6171,
    "text_uthmani": "كَلَّا سَوْفَ تَعْلَمُونَ",
    "tafseer": "[3] ما هكذا ينبغي أن يُلْهيكم التكاثر بالأموال، سوف تتبيَّنون أن الدار الآخرة خير لكم.",
    "t_verse_number": 3,
    "t_chapter_id": 102,
    "t_name_arabic": "التكاثر"
  },
  {
    "verse_id": 6172,
    "text_uthmani": "ثُمَّ كَلَّا سَوْفَ تَعْلَمُونَ",
    "tafseer": "[4] ثم احذروا سوف تعلمون سوء عاقبة انشغالكم عنها.",
    "t_verse_number": 4,
    "t_chapter_id": 102,
    "t_name_arabic": "التكاثر"
  },
  {
    "verse_id": 6173,
    "text_uthmani": "كَلَّا لَوْ تَعْلَمُونَ عِلْمَ الْيَقِينِ",
    "tafseer": "[5] ما هكذا ينبغي أن يلهيكم التكاثر بالأموال، لو تعلمون حق العلم لانزجرتم، ولبادرتم إلى إنقاذ أنفسكم من الهلاك",
    "t_verse_number": 5,
    "t_chapter_id": 102,
    "t_name_arabic": "التكاثر"
  },
  {
    "verse_id": 6174,
    "text_uthmani": "لَتَرَوُنَّ الْجَحِيمَ",
    "tafseer": "[6]  لتبصرُنَّ الجحيم",
    "t_verse_number": 6,
    "t_chapter_id": 102,
    "t_name_arabic": "التكاثر"
  },
  {
    "verse_id": 6175,
    "text_uthmani": "ثُمَّ لَتَرَوُنَّهَا عَيْنَ الْيَقِينِ",
    "tafseer": "[7]  ثم لتبصرُنَّها دون ريب",
    "t_verse_number": 7,
    "t_chapter_id": 102,
    "t_name_arabic": "التكاثر"
  },
  {
    "verse_id": 6176,
    "text_uthmani": "ثُمَّ لَتُسْأَلُنَّ يَوْمَئِذٍ عَنِ النَّعِيمِ",
    "tafseer": "[8] ثم لتسألُنَّ يوم القيامة عن كل أنواع النعيم.",
    "t_verse_number": 8,
    "t_chapter_id": 102,
    "t_name_arabic": "التكاثر"
  }
]