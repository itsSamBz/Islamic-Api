[
  {
    "verse_id": 5552,
    "text_uthmani": "لَا أُقْسِمُ بِيَوْمِ الْقِيَامَةِ",
    "tafseer": "[1] أقسم الله سبحانه بيوم الحساب والجزاء",
    "t_verse_number": 1,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5553,
    "text_uthmani": "وَلَا أُقْسِمُ بِالنَّفْسِ اللَّوَّامَةِ",
    "tafseer": "[2] وأقسم بالنفس المؤمنة التقية التي تلوم صاحبها على ترك الطاعات وفِعْل الموبقات، إن الناس سيبعثون",
    "t_verse_number": 2,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5554,
    "text_uthmani": "أَيَحْسَبُ الْإِنسَانُ أَلَّن نَجْمَعَ عِظَامَهُ",
    "tafseer": "[3]  أيظنُّ هذا الإنسان الكافر أن لن نقدر على جَمْع عظامه بعد تفرقها؟",
    "t_verse_number": 3,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5555,
    "text_uthmani": "بَلَى قَادِرِينَ عَلَى أَن نُّسَوِّيَ بَنَانَهُ",
    "tafseer": "[4]  بلى سنجمعها، قادرين على أن نجعل أصابعه أو أنامله -بعد جمعها وتأليفها- خَلْقاً سويّاً، كما كانت قبل الموت.",
    "t_verse_number": 4,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5556,
    "text_uthmani": "بَلْ يُرِيدُ الْإِنسَانُ لِيَفْجُرَ أَمَامَهُ",
    "tafseer": "[5] بل ينكر الإنسان البعث، يريد أن يبقى على الفجور فيما يستقبل من أيام عمره",
    "t_verse_number": 5,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5557,
    "text_uthmani": "يَسْأَلُ أَيَّانَ يَوْمُ الْقِيَامَةِ",
    "tafseer": "[6] يسأل هذا الكافر مستبعداً قيام الساعة: متى يكون يوم القيامة؟",
    "t_verse_number": 6,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5558,
    "text_uthmani": "فَإِذَا بَرِقَ الْبَصَرُ",
    "tafseer": "[7] فإذا تحيَّر البصر ودُهش فزعاً مما رأى من أهوال يوم القيامة",
    "t_verse_number": 7,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5559,
    "text_uthmani": "وَخَسَفَ الْقَمَرُ",
    "tafseer": "[8] وذهب نور القمر",
    "t_verse_number": 8,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5560,
    "text_uthmani": "وَجُمِعَ الشَّمْسُ وَالْقَمَرُ",
    "tafseer": "[9] وجُمِع بين الشمس والقمر في ذهاب الضوء، فلا ضوء لواحد منهما",
    "t_verse_number": 9,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5561,
    "text_uthmani": "يَقُولُ الْإِنسَانُ يَوْمَئِذٍ أَيْنَ الْمَفَرُّ",
    "tafseer": "[10]  يقول الإنسان وقتها: أين المهرب من العذاب؟",
    "t_verse_number": 10,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5562,
    "text_uthmani": "كَلَّا لَا وَزَرَ",
    "tafseer": "[11] ليس الأمر كما تتمناه -أيها الإنسان- مِن طلب الفرار، لا ملجأ لك ولا منجى",
    "t_verse_number": 11,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5563,
    "text_uthmani": "إِلَى رَبِّكَ يَوْمَئِذٍ الْمُسْتَقَرُّ",
    "tafseer": "[12] إلى الله وحده مصير الخلائق يوم القيامة ومستقرهم، فيجازي كُلّاً بما يستحق.",
    "t_verse_number": 12,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5564,
    "text_uthmani": "يُنَبَّأُ الْإِنسَانُ يَوْمَئِذٍ بِمَا قَدَّمَ وَأَخَّرَ",
    "tafseer": "[13] يُخَبَّر الإنسان في ذلك اليوم بجميع أعماله: مِن خير وشر، ما قدَّمه منها في حياته وما أخَّره.",
    "t_verse_number": 13,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5565,
    "text_uthmani": "بَلِ الْإِنسَانُ عَلَى نَفْسِهِ بَصِيرَةٌ",
    "tafseer": "[14] بل الإنسان حجة واضحة على نفسه تلزمه بما فعل أو ترك",
    "t_verse_number": 14,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5566,
    "text_uthmani": "وَلَوْ أَلْقَى مَعَاذِيرَهُ",
    "tafseer": "[15]  ولو جاء بكل معذرة يعتذر بها عن إجرامه، فإنه لا ينفعه ذلك.",
    "t_verse_number": 15,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5567,
    "text_uthmani": "لَا تُحَرِّكْ بِهِ لِسَانَكَ لِتَعْجَلَ بِهِ",
    "tafseer": "[16] لا تحرك -أيها النبي- بالقرآن لسانك حين نزول الوحي؛ لأجل أن تتعجل بحفظه، مخافة أن يتفلَّت منك",
    "t_verse_number": 16,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5568,
    "text_uthmani": "إِنَّ عَلَيْنَا جَمْعَهُ وَقُرْآنَهُ",
    "tafseer": "[17] إن علينا جَمْعه في صدرك، ثم أن تقرأه بلسانك متى شئت",
    "t_verse_number": 17,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5569,
    "text_uthmani": "فَإِذَا قَرَأْنَاهُ فَاتَّبِعْ قُرْآنَهُ",
    "tafseer": "[18] فإذا قرأه عليك رسولنا جبريل فاستمِعْ لقراءته وأنصت له، ثم اقرأه كما أقرأك إياه",
    "t_verse_number": 18,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5570,
    "text_uthmani": "ثُمَّ إِنَّ عَلَيْنَا بَيَانَهُ",
    "tafseer": "[19]  ثم إن علينا توضيح ما أشكل عليك فهمه من معانيه وأحكامه.",
    "t_verse_number": 19,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5571,
    "text_uthmani": "كَلَّا بَلْ تُحِبُّونَ الْعَاجِلَةَ",
    "tafseer": "[20] ليس الأمر كما زعمتم -يا معشر المشركين- أن لا بعث ولا جزاء، بل أنتم قوم تحبون الدنيا وزينتها",
    "t_verse_number": 20,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5572,
    "text_uthmani": "وَتَذَرُونَ الْآخِرَةَ",
    "tafseer": "[21]  وتتركون الآخرة ونعيمها.",
    "t_verse_number": 21,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5573,
    "text_uthmani": "وُجُوهٌ يَوْمَئِذٍ نَّاضِرَةٌ",
    "tafseer": "[22] وجوه أهل السعادة يوم القيامة مشرقة حسنة ناعمة",
    "t_verse_number": 22,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5574,
    "text_uthmani": "إِلَى رَبِّهَا نَاظِرَةٌ",
    "tafseer": "[23]  ترى خالقها ومالك أمرها، فتتمتع بذلك.",
    "t_verse_number": 23,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5575,
    "text_uthmani": "وَوُجُوهٌ يَوْمَئِذٍ بَاسِرَةٌ",
    "tafseer": "[24] ووجوه الأشقياء يوم القيامة عابسة كالحة",
    "t_verse_number": 24,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5576,
    "text_uthmani": "تَظُنُّ أَن يُفْعَلَ بِهَا فَاقِرَةٌ",
    "tafseer": "[25]  تتوقع أن تنزل بها مصيبة عظيمة، تقصم فَقَار الظَّهْر.",
    "t_verse_number": 25,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5577,
    "text_uthmani": "كَلَّا إِذَا بَلَغَتْ التَّرَاقِيَ",
    "tafseer": "[26] حقّاً إذا وصلت الروح إلى أعالي الصدر",
    "t_verse_number": 26,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5578,
    "text_uthmani": "وَقِيلَ مَنْ رَاقٍ",
    "tafseer": "[27] وقال بعض الحاضرين لبعض: هل مِن راق يَرْقيه ويَشْفيه مما هو فيه؟",
    "t_verse_number": 27,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5579,
    "text_uthmani": "وَظَنَّ أَنَّهُ الْفِرَاقُ",
    "tafseer": "[28] وأيقن المحتضر أنَّ الذي نزل به هو فراق الدنيا؛ لمعاينته ملائكة الموت",
    "t_verse_number": 28,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5580,
    "text_uthmani": "وَالْتَفَّتِ السَّاقُ بِالسَّاقِ",
    "tafseer": "[29] واتصلت شدة آخر الدنيا بشدة أول الآخرة",
    "t_verse_number": 29,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5581,
    "text_uthmani": "إِلَى رَبِّكَ يَوْمَئِذٍ الْمَسَاقُ",
    "tafseer": "[30] إلى الله تعالى مساق العباد يوم القيامة: إما إلى الجنة وإما إلى النار.",
    "t_verse_number": 30,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5582,
    "text_uthmani": "فَلَا صَدَّقَ وَلَا صَلَّى",
    "tafseer": "[31] فلا آمن الكافر بالرسول والقرآن، ولا أدَّى لله تعالى فرائض الصلاة",
    "t_verse_number": 31,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5583,
    "text_uthmani": "وَلَكِن كَذَّبَ وَتَوَلَّى",
    "tafseer": "[32] ولكن كذَّب بالقرآن، وأعرض عن الإيمان",
    "t_verse_number": 32,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5584,
    "text_uthmani": "ثُمَّ ذَهَبَ إِلَى أَهْلِهِ يَتَمَطَّى",
    "tafseer": "[33] ثم مضى إلى أهله يتبختر مختالاً في مشيته",
    "t_verse_number": 33,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5585,
    "text_uthmani": "أَوْلَى لَكَ فَأَوْلَى",
    "tafseer": "[34] هلاك لك فهلاك",
    "t_verse_number": 34,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5586,
    "text_uthmani": "ثُمَّ أَوْلَى لَكَ فَأَوْلَى",
    "tafseer": "[35]  ثم هلاك لك فهلاك.",
    "t_verse_number": 35,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5587,
    "text_uthmani": "أَيَحْسَبُ الْإِنسَانُ أَن يُتْرَكَ سُدًى",
    "tafseer": "[36] أيظنُّ هذا الإنسان المنكر للبعث أن يُترك هَمَلاً لا يُؤمر ولا يُنْهى، ولا يحاسب ولا يعاقب؟",
    "t_verse_number": 36,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5588,
    "text_uthmani": "أَلَمْ يَكُ نُطْفَةً مِّن مَّنِيٍّ يُمْنَى",
    "tafseer": "[37]  ألم يك هذا الإنسان نطفة ضعيفة من ماء مهين يراق ويصب في الأرحام",
    "t_verse_number": 37,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5589,
    "text_uthmani": "ثُمَّ كَانَ عَلَقَةً فَخَلَقَ فَسَوَّى",
    "tafseer": "[38]  ثم صار قطعة من دم جامد، فخلقه الله بقدرته وسوَّى صورته في أحسن تقويم؟",
    "t_verse_number": 38,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5590,
    "text_uthmani": "فَجَعَلَ مِنْهُ الزَّوْجَيْنِ الذَّكَرَ وَالْأُنثَى",
    "tafseer": "[39]  فجعل من هذا الإنسان الصنفين: الذكر والأنثى",
    "t_verse_number": 39,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  },
  {
    "verse_id": 5591,
    "text_uthmani": "أَلَيْسَ ذَلِكَ بِقَادِرٍ عَلَى أَن يُحْيِيَ الْمَوْتَى",
    "tafseer": "[40] أليس ذلك الإله الخالق لهذه الأشياء بقادر على إعادة الخلق بعد فنائهم؟ بلى إنه -سبحانه وتعالى- لقادر على ذلك.",
    "t_verse_number": 40,
    "t_chapter_id": 75,
    "t_name_arabic": "القيامة"
  }
]