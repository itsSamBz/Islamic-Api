[
  {
    "verse_id": 6059,
    "text_uthmani": "وَاللَّيْلِ إِذَا يَغْشَى",
    "tafseer": "[1] أقسم الله سبحانه بالليل عندما يغطي بظلامه الأرض وما عليها ",
    "t_verse_number": 1,
    "t_chapter_id": 92,
    "t_name_arabic": "الليل"
  },
  {
    "verse_id": 6060,
    "text_uthmani": "وَالنَّهَارِ إِذَا تَجَلَّى",
    "tafseer": "[2] وبالنهار إذا انكشف عن ظلام الليل بضيائه",
    "t_verse_number": 2,
    "t_chapter_id": 92,
    "t_name_arabic": "الليل"
  },
  {
    "verse_id": 6061,
    "text_uthmani": "وَمَا خَلَقَ الذَّكَرَ وَالْأُنثَى",
    "tafseer": "[3] وبخلق الزوجين: الذكر والأنثى",
    "t_verse_number": 3,
    "t_chapter_id": 92,
    "t_name_arabic": "الليل"
  },
  {
    "verse_id": 6062,
    "text_uthmani": "إِنَّ سَعْيَكُمْ لَشَتَّى",
    "tafseer": "[4] إن عملكم لمختلف بين عامل للدنيا وعامل للآخرة.",
    "t_verse_number": 4,
    "t_chapter_id": 92,
    "t_name_arabic": "الليل"
  },
  {
    "verse_id": 6063,
    "text_uthmani": "فَأَمَّا مَن أَعْطَى وَاتَّقَى",
    "tafseer": "[5] فأمَّا مَن بذل مِن ماله واتقى الله في ذلك ",
    "t_verse_number": 5,
    "t_chapter_id": 92,
    "t_name_arabic": "الليل"
  },
  {
    "verse_id": 6064,
    "text_uthmani": "وَصَدَّقَ بِالْحُسْنَى",
    "tafseer": "[6]  وصدَّق  ﺑ«لا إله إلا الله» وما دلت عليه، وما ترتب عليها من الجزاء",
    "t_verse_number": 6,
    "t_chapter_id": 92,
    "t_name_arabic": "الليل"
  },
  {
    "verse_id": 6065,
    "text_uthmani": "فَسَنُيَسِّرُهُ لِلْيُسْرَى",
    "tafseer": "[7] فسنرشده ونوفقه إلى أسباب الخير والصلاح، ونيسِّر له أموره.",
    "t_verse_number": 7,
    "t_chapter_id": 92,
    "t_name_arabic": "الليل"
  },
  {
    "verse_id": 6066,
    "text_uthmani": "وَأَمَّا مَن بَخِلَ وَاسْتَغْنَى",
    "tafseer": "[8] وأما مَن بخل بماله واستغنى عن جزاء ربه ",
    "t_verse_number": 8,
    "t_chapter_id": 92,
    "t_name_arabic": "الليل"
  },
  {
    "verse_id": 6067,
    "text_uthmani": "وَكَذَّبَ بِالْحُسْنَى",
    "tafseer": "[9] وكذَّب  ﺑ«لا إله إلا الله» وما دلت عليه، وما ترتب عليها من الجزاء.",
    "t_verse_number": 9,
    "t_chapter_id": 92,
    "t_name_arabic": "الليل"
  },
  {
    "verse_id": 6068,
    "text_uthmani": "فَسَنُيَسِّرُهُ لِلْعُسْرَى",
    "tafseer": "[10] فسنُيَسِّر له أسباب الشقاء ",
    "t_verse_number": 10,
    "t_chapter_id": 92,
    "t_name_arabic": "الليل"
  },
  {
    "verse_id": 6069,
    "text_uthmani": "وَمَا يُغْنِي عَنْهُ مَالُهُ إِذَا تَرَدَّى",
    "tafseer": "[11] ولا ينفعه ماله الذي بخل به إذا وقع في النار.",
    "t_verse_number": 11,
    "t_chapter_id": 92,
    "t_name_arabic": "الليل"
  },
  {
    "verse_id": 6070,
    "text_uthmani": "إِنَّ عَلَيْنَا لَلْهُدَى",
    "tafseer": "[12] إن علينا بفضلنا وحكمتنا أن نبيِّن طريق الهدى الموصل إلى الله وجنته من طريق الضلال",
    "t_verse_number": 12,
    "t_chapter_id": 92,
    "t_name_arabic": "الليل"
  },
  {
    "verse_id": 6071,
    "text_uthmani": "وَإِنَّ لَنَا لَلْآخِرَةَ وَالْأُولَى",
    "tafseer": "[13]  وإن لنا ملك الحياة الآخرة والحياة الدنيا.",
    "t_verse_number": 13,
    "t_chapter_id": 92,
    "t_name_arabic": "الليل"
  },
  {
    "verse_id": 6072,
    "text_uthmani": "فَأَنذَرْتُكُمْ نَارًا تَلَظَّى",
    "tafseer": "[14] فحذَّرتكم -أيها الناس- وخوَّفتكم ناراً تتوهج، وهي نار جهنم.",
    "t_verse_number": 14,
    "t_chapter_id": 92,
    "t_name_arabic": "الليل"
  },
  {
    "verse_id": 6073,
    "text_uthmani": "لَا يَصْلَاهَا إِلَّا الْأَشْقَى",
    "tafseer": "[15] لا يدخلها إلا مَن كان شديد الشقاء ",
    "t_verse_number": 15,
    "t_chapter_id": 92,
    "t_name_arabic": "الليل"
  },
  {
    "verse_id": 6074,
    "text_uthmani": "الَّذِي كَذَّبَ وَتَوَلَّى",
    "tafseer": "[16] الذي كذَّب نبي الله محمداً -صلى الله عليه وسلم-، وأعرض عن الإيمان بالله ورسوله، وطاعتهما.",
    "t_verse_number": 16,
    "t_chapter_id": 92,
    "t_name_arabic": "الليل"
  },
  {
    "verse_id": 6075,
    "text_uthmani": "وَسَيُجَنَّبُهَا الْأَتْقَى",
    "tafseer": "[17] وسيُزحزَح عنها شديد التقوى",
    "t_verse_number": 17,
    "t_chapter_id": 92,
    "t_name_arabic": "الليل"
  },
  {
    "verse_id": 6076,
    "text_uthmani": "الَّذِي يُؤْتِي مَالَهُ يَتَزَكَّى",
    "tafseer": "[18] الذي يبذل ماله ابتغاء المزيد من الخير",
    "t_verse_number": 18,
    "t_chapter_id": 92,
    "t_name_arabic": "الليل"
  },
  {
    "verse_id": 6077,
    "text_uthmani": "وَمَا لِأَحَدٍ عِندَهُ مِن نِّعْمَةٍ تُجْزَى",
    "tafseer": "[19] وليس إنفاقه ذاك مكافأة لمن أسدى إليه معروفاً",
    "t_verse_number": 19,
    "t_chapter_id": 92,
    "t_name_arabic": "الليل"
  },
  {
    "verse_id": 6078,
    "text_uthmani": "إِلَّا ابْتِغَاء وَجْهِ رَبِّهِ الْأَعْلَى",
    "tafseer": "[20] لكنه يبتغي بذلك وجه ربه الأعلى ورضاه",
    "t_verse_number": 20,
    "t_chapter_id": 92,
    "t_name_arabic": "الليل"
  },
  {
    "verse_id": 6079,
    "text_uthmani": "وَلَسَوْفَ يَرْضَى",
    "tafseer": "[21] ولسوف يعطيه الله في الجنة ما يرضى به.",
    "t_verse_number": 21,
    "t_chapter_id": 92,
    "t_name_arabic": "الليل"
  }
]