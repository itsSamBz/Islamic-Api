[
  {
    "verse_id": 6231,
    "text_uthmani": "قُلْ أَعُوذُ بِرَبِّ النَّاسِ",
    "tafseer": "[1] قل -أيها الرسول-: أعوذ وأعتصم برب الناس، القادر وحده على ردِّ شر الوسواس.",
    "t_verse_number": 1,
    "t_chapter_id": 114,
    "t_name_arabic": "الناس"
  },
  {
    "verse_id": 6232,
    "text_uthmani": "مَلِكِ النَّاسِ",
    "tafseer": "[2] ملك الناس المتصرف في كل شؤونهم، الغنيِّ عنهم.",
    "t_verse_number": 2,
    "t_chapter_id": 114,
    "t_name_arabic": "الناس"
  },
  {
    "verse_id": 6233,
    "text_uthmani": "إِلَهِ النَّاسِ",
    "tafseer": "[3] إله الناس الذي لا معبود بحق سواه.",
    "t_verse_number": 3,
    "t_chapter_id": 114,
    "t_name_arabic": "الناس"
  },
  {
    "verse_id": 6234,
    "text_uthmani": "مِن شَرِّ الْوَسْوَاسِ الْخَنَّاسِ",
    "tafseer": "[4] من أذى الشيطان الذي يوسوس عند الغفلة، ويختفي عند ذكر الله.",
    "t_verse_number": 4,
    "t_chapter_id": 114,
    "t_name_arabic": "الناس"
  },
  {
    "verse_id": 6235,
    "text_uthmani": "الَّذِي يُوَسْوِسُ فِي صُدُورِ النَّاسِ",
    "tafseer": "[5] الذي يبثُّ الشر والشكوك في صدور الناس.",
    "t_verse_number": 5,
    "t_chapter_id": 114,
    "t_name_arabic": "الناس"
  },
  {
    "verse_id": 6236,
    "text_uthmani": "مِنَ الْجِنَّةِ وَ النَّاسِ",
    "tafseer": "[6] من شياطين الجن والإنس.",
    "t_verse_number": 6,
    "t_chapter_id": 114,
    "t_name_arabic": "الناس"
  }
