[
  {
    "verse_id": 6189,
    "text_uthmani": "أَلَمْ تَرَ كَيْفَ فَعَلَ رَبُّكَ بِأَصْحَابِ الْفِيلِ",
    "tafseer": "[1] ألم تعلم -أيها الرسول- كيف فعل ربك بأصحاب الفيل: أبرهةَ الحبشيِّ وجيشِه الذين أرادوا تدمير الكعبة المباركة؟",
    "t_verse_number": 1,
    "t_chapter_id": 105,
    "t_name_arabic": "الفيل"
  },
  {
    "verse_id": 6190,
    "text_uthmani": "أَلَمْ يَجْعَلْ كَيْدَهُمْ فِي تَضْلِيلٍ",
    "tafseer": "[2] ألم يجعل ما دبَّروه من شر في إبطال وتضييع؟",
    "t_verse_number": 2,
    "t_chapter_id": 105,
    "t_name_arabic": "الفيل"
  },
  {
    "verse_id": 6191,
    "text_uthmani": "وَأَرْسَلَ عَلَيْهِمْ طَيْرًا أَبَابِيلَ",
    "tafseer": "[3] وبعث عليهم طيراً في جماعات متتابعة",
    "t_verse_number": 3,
    "t_chapter_id": 105,
    "t_name_arabic": "الفيل"
  },
  {
    "verse_id": 6192,
    "text_uthmani": "تَرْمِيهِم بِحِجَارَةٍ مِّن سِجِّيلٍ",
    "tafseer": "[4]  تقذفهم بحجارة من طين متحجِّر.",
    "t_verse_number": 4,
    "t_chapter_id": 105,
    "t_name_arabic": "الفيل"
  },
  {
    "verse_id": 6193,
    "text_uthmani": "فَجَعَلَهُمْ كَعَصْفٍ مَّأْكُولٍ",
    "tafseer": "[5] فجعلهم به محطمين كأوراق الزرع اليابسة التي أكلتها البهائم ثم رمت بها.",
    "t_verse_number": 5,
    "t_chapter_id": 105,
    "t_name_arabic": "الفيل"
  }
]