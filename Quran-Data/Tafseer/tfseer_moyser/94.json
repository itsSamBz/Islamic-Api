[
  {
    "verse_id": 6091,
    "text_uthmani": "أَلَمْ نَشْرَحْ لَكَ صَدْرَكَ",
    "tafseer": "[1] ألم نوسع -أيها النبي- لك صدرك لشرائع الدين، والدعوة إلى الله، والاتصاف بمكارم الأخلاق",
    "t_verse_number": 1,
    "t_chapter_id": 94,
    "t_name_arabic": "الشرح"
  },
  {
    "verse_id": 6092,
    "text_uthmani": "وَوَضَعْنَا عَنكَ وِزْرَكَ",
    "tafseer": "[2]  وحططنا عنك بذلك حِمْلك.",
    "t_verse_number": 2,
    "t_chapter_id": 94,
    "t_name_arabic": "الشرح"
  },
  {
    "verse_id": 6093,
    "text_uthmani": "الَّذِي أَنقَضَ ظَهْرَكَ",
    "tafseer": "[3] الذي أثقل ظهرك",
    "t_verse_number": 3,
    "t_chapter_id": 94,
    "t_name_arabic": "الشرح"
  },
  {
    "verse_id": 6094,
    "text_uthmani": "وَرَفَعْنَا لَكَ ذِكْرَكَ",
    "tafseer": "[4]  وجعلناك -بما أنعمنا عليك من المكارم- في منزلة رفيعة عالية؟",
    "t_verse_number": 4,
    "t_chapter_id": 94,
    "t_name_arabic": "الشرح"
  },
  {
    "verse_id": 6095,
    "text_uthmani": "فَإِنَّ مَعَ الْعُسْرِ يُسْرًا",
    "tafseer": "[5] فلا يَثْنِكَ أذى أعدائك عن نشر الرسالة؛ فإن مع الضيق فرجاً",
    "t_verse_number": 5,
    "t_chapter_id": 94,
    "t_name_arabic": "الشرح"
  },
  {
    "verse_id": 6096,
    "text_uthmani": "إِنَّ مَعَ الْعُسْرِ يُسْرًا",
    "tafseer": "[6] إن مع الضيق فرجاً.",
    "t_verse_number": 6,
    "t_chapter_id": 94,
    "t_name_arabic": "الشرح"
  },
  {
    "verse_id": 6097,
    "text_uthmani": "فَإِذَا فَرَغْتَ فَانصَبْ",
    "tafseer": "[7] فإذا فرغت من أمور الدنيا وأشغالها فَجِدَّ في العبادة",
    "t_verse_number": 7,
    "t_chapter_id": 94,
    "t_name_arabic": "الشرح"
  },
  {
    "verse_id": 6098,
    "text_uthmani": "وَإِلَى رَبِّكَ فَارْغَبْ",
    "tafseer": "[8] وإلى ربك وحده فارغب فيما عنده.",
    "t_verse_number": 8,
    "t_chapter_id": 94,
    "t_name_arabic": "الشرح"
  }
]