[
  {
    "verse_id": 6226,
    "text_uthmani": "قُلْ أَعُوذُ بِرَبِّ الْفَلَقِ",
    "tafseer": "[1] قل -أيها الرسول-: أعوذ وأعتصم برب الفلق، وهو الصبح.",
    "t_verse_number": 1,
    "t_chapter_id": 113,
    "t_name_arabic": "الفلق"
  },
  {
    "verse_id": 6227,
    "text_uthmani": "مِن شَرِّ مَا خَلَقَ",
    "tafseer": "[2] من شر جميع المخلوقات وأذاها.",
    "t_verse_number": 2,
    "t_chapter_id": 113,
    "t_name_arabic": "الفلق"
  },
  {
    "verse_id": 6228,
    "text_uthmani": "وَمِن شَرِّ غَاسِقٍ إِذَا وَقَبَ",
    "tafseer": "[3] ومن شر ليل شديد الظلمة إذا دخل وتغلغل، وما فيه من الشرور والمؤذيات.",
    "t_verse_number": 3,
    "t_chapter_id": 113,
    "t_name_arabic": "الفلق"
  },
  {
    "verse_id": 6229,
    "text_uthmani": "وَمِن شَرِّ النَّفَّاثَاتِ فِي الْعُقَدِ",
    "tafseer": "[4] ومن شر الساحرات اللاتي ينفخن فيما يعقدن من عُقَد بقصد السحر.",
    "t_verse_number": 4,
    "t_chapter_id": 113,
    "t_name_arabic": "الفلق"
  },
  {
    "verse_id": 6230,
    "text_uthmani": "وَمِن شَرِّ حَاسِدٍ إِذَا حَسَدَ",
    "tafseer": "[5] ومن شر حاسد مبغض للناس إذا حسدهم على ما وهبهم الله من نِعَم، يريد زوالها عنهم وإيقاع الأذى بهم.",
    "t_verse_number": 5,
    "t_chapter_id": 113,
    "t_name_arabic": "الفلق"
  }
]