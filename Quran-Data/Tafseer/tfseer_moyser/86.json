[
  {
    "verse_id": 5932,
    "text_uthmani": "وَالسَّمَاء وَالطَّارِقِ",
    "tafseer": "[1] أقسم الله سبحانه بالسماء والنجم الذي يَظْهر ليلاً",
    "t_verse_number": 1,
    "t_chapter_id": 86,
    "t_name_arabic": "الطارق"
  },
  {
    "verse_id": 5933,
    "text_uthmani": "وَمَا أَدْرَاكَ مَا الطَّارِقُ",
    "tafseer": "[2] وما أدراك ما عِظَمُ هذا النجم؟",
    "t_verse_number": 2,
    "t_chapter_id": 86,
    "t_name_arabic": "الطارق"
  },
  {
    "verse_id": 5934,
    "text_uthmani": "النَّجْمُ الثَّاقِبُ",
    "tafseer": "[3] هو النجم المضيء المتوهِّج",
    "t_verse_number": 3,
    "t_chapter_id": 86,
    "t_name_arabic": "الطارق"
  },
  {
    "verse_id": 5935,
    "text_uthmani": "إِن كُلُّ نَفْسٍ لَّمَّا عَلَيْهَا حَافِظٌ",
    "tafseer": "[4] ما كلُّ نفس إلا أوكل بها مَلَك رقيب يحفظ عليها أعمالها؛ لتحاسَب عليها يوم القيامة.",
    "t_verse_number": 4,
    "t_chapter_id": 86,
    "t_name_arabic": "الطارق"
  },
  {
    "verse_id": 5936,
    "text_uthmani": "فَلْيَنظُرِ الْإِنسَانُ مِمَّ خُلِقَ",
    "tafseer": "[5] فلينظر الإنسان المنكر للبعث مِمَّ خُلِقَ؟ ليعلم أن إعادة خلق الإنسان ليست أصعب مِن خلقه أولاً",
    "t_verse_number": 5,
    "t_chapter_id": 86,
    "t_name_arabic": "الطارق"
  },
  {
    "verse_id": 5937,
    "text_uthmani": "خُلِقَ مِن مَّاء دَافِقٍ",
    "tafseer": "[6] خلق مِن منيٍّ منصبٍّ بسرعة في الرحم",
    "t_verse_number": 6,
    "t_chapter_id": 86,
    "t_name_arabic": "الطارق"
  },
  {
    "verse_id": 5938,
    "text_uthmani": "يَخْرُجُ مِن بَيْنِ الصُّلْبِ وَالتَّرَائِبِ",
    "tafseer": "[7] يخرج من بين صلب الرجل وصدر المرأة",
    "t_verse_number": 7,
    "t_chapter_id": 86,
    "t_name_arabic": "الطارق"
  },
  {
    "verse_id": 5939,
    "text_uthmani": "إِنَّهُ عَلَى رَجْعِهِ لَقَادِرٌ",
    "tafseer": "[8]  إن الذي خلق الإنسان من هذا الماء لَقادر على رجعه إلى الحياة بعد الموت.",
    "t_verse_number": 8,
    "t_chapter_id": 86,
    "t_name_arabic": "الطارق"
  },
  {
    "verse_id": 5940,
    "text_uthmani": "يَوْمَ تُبْلَى السَّرَائِرُ",
    "tafseer": "[9] يوم تُختَبر السرائر فيما أخفته، ويُمَيَّز الصالح منها من الفاسد",
    "t_verse_number": 9,
    "t_chapter_id": 86,
    "t_name_arabic": "الطارق"
  },
  {
    "verse_id": 5941,
    "text_uthmani": "فَمَا لَهُ مِن قُوَّةٍ وَلَا نَاصِرٍ",
    "tafseer": "[10] فما للإنسان من قوة يدفع بها عن نفسه، وما له من ناصر يدفع عنه عذاب الله.",
    "t_verse_number": 10,
    "t_chapter_id": 86,
    "t_name_arabic": "الطارق"
  },
  {
    "verse_id": 5942,
    "text_uthmani": "وَالسَّمَاء ذَاتِ الرَّجْعِ",
    "tafseer": "[11] والسماء ذات المطر المتكرر",
    "t_verse_number": 11,
    "t_chapter_id": 86,
    "t_name_arabic": "الطارق"
  },
  {
    "verse_id": 5943,
    "text_uthmani": "وَالْأَرْضِ ذَاتِ الصَّدْعِ",
    "tafseer": "[12] والأرض ذات التشقق بما يتخللها من نبات",
    "t_verse_number": 12,
    "t_chapter_id": 86,
    "t_name_arabic": "الطارق"
  },
  {
    "verse_id": 5944,
    "text_uthmani": "إِنَّهُ لَقَوْلٌ فَصْلٌ",
    "tafseer": "[13] إن القرآن لقول فصل بَيْنَ الحق والباطل",
    "t_verse_number": 13,
    "t_chapter_id": 86,
    "t_name_arabic": "الطارق"
  },
  {
    "verse_id": 5945,
    "text_uthmani": "وَمَا هُوَ بِالْهَزْلِ",
    "tafseer": "[14] وما هو بالهزل. ولا يجوز للمخلوق أن يقسم بغير الله، وإن فَعل فقد أشرك.",
    "t_verse_number": 14,
    "t_chapter_id": 86,
    "t_name_arabic": "الطارق"
  },
  {
    "verse_id": 5946,
    "text_uthmani": "إِنَّهُمْ يَكِيدُونَ كَيْدًا",
    "tafseer": "[15] إن المكذبين للرسول -صلى الله عليه وسلم-، وللقرآن يكيدون ويدبرون؛ ليدفعوا بكيدهم الحق ويؤيدوا الباطل.",
    "t_verse_number": 15,
    "t_chapter_id": 86,
    "t_name_arabic": "الطارق"
  },
  {
    "verse_id": 5947,
    "text_uthmani": "وَأَكِيدُ كَيْدًا",
    "tafseer": "[16]  وأكيد كيداً لإظهار الحق، ولو كره الكافرون",
    "t_verse_number": 16,
    "t_chapter_id": 86,
    "t_name_arabic": "الطارق"
  },
  {
    "verse_id": 5948,
    "text_uthmani": "فَمَهِّلِ الْكَافِرِينَ أَمْهِلْهُمْ رُوَيْدًا",
    "tafseer": "[17] فلا تستعجل لهم –أيها الرسول- بطلب إنزال العقاب بهم، بل أمهلهم وأنظرهم قليلاً، ولا تستعجل لهم، وسترى ما يحلُّ بهم من العذاب والنكال والعقوبة والهلاك ",
    "t_verse_number": 17,
    "t_chapter_id": 86,
    "t_name_arabic": "الطارق"
  }
]