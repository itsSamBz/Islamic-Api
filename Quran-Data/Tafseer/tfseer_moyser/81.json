[
  {
    "verse_id": 5801,
    "text_uthmani": "إِذَا الشَّمْسُ كُوِّرَتْ",
    "tafseer": "[1] إذا الشمس لُفَّت وذهب ضوْءُها",
    "t_verse_number": 1,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  },
  {
    "verse_id": 5802,
    "text_uthmani": "وَإِذَا النُّجُومُ انكَدَرَتْ",
    "tafseer": "[2] وإذا النجوم تناثرت، فذهب نورها",
    "t_verse_number": 2,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  },
  {
    "verse_id": 5803,
    "text_uthmani": "وَإِذَا الْجِبَالُ سُيِّرَتْ",
    "tafseer": "[3] وإذا الجبال سيِّرت عن وجه الأرض فصارت غُباراً مُتطايراً",
    "t_verse_number": 3,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  },
  {
    "verse_id": 5804,
    "text_uthmani": "وَإِذَا الْعِشَارُ عُطِّلَتْ",
    "tafseer": "[4] وإذا النوق الحوامل تُركت وأهملت",
    "t_verse_number": 4,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  },
  {
    "verse_id": 5805,
    "text_uthmani": "وَإِذَا الْوُحُوشُ حُشِرَتْ",
    "tafseer": "[5] وإذا الحيوانات الوحشية جُمعت واختلطت؛ ليقتصَّ الله من بعضها لبعض",
    "t_verse_number": 5,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  },
  {
    "verse_id": 5806,
    "text_uthmani": "وَإِذَا الْبِحَارُ سُجِّرَتْ",
    "tafseer": "[6] وإذا البحار أوقدت، فصارت على عِظَمها ناراً تتوقد",
    "t_verse_number": 6,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  },
  {
    "verse_id": 5807,
    "text_uthmani": "وَإِذَا النُّفُوسُ زُوِّجَتْ",
    "tafseer": "[7]  وإذا النفوس قُرنت بأمثالها ونظائرها",
    "t_verse_number": 7,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  },
  {
    "verse_id": 5808,
    "text_uthmani": "وَإِذَا الْمَوْؤُودَةُ سُئِلَتْ",
    "tafseer": "[8] وإذا الطفلة المدفونة حيةً سُئلت يوم القيامة سؤالَ تطييب لها وتبكيت لوائدها",
    "t_verse_number": 8,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  },
  {
    "verse_id": 5809,
    "text_uthmani": "بِأَيِّ ذَنبٍ قُتِلَتْ",
    "tafseer": "[9]  بأيِّ ذنب كان دفنها؟",
    "t_verse_number": 9,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  },
  {
    "verse_id": 5810,
    "text_uthmani": "وَإِذَا الصُّحُفُ نُشِرَتْ",
    "tafseer": "[10] وإذا صحف الأعمال عُرضت",
    "t_verse_number": 10,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  },
  {
    "verse_id": 5811,
    "text_uthmani": "وَإِذَا السَّمَاء كُشِطَتْ",
    "tafseer": "[11] وإذا السماء قُلعت وأزيلت من مكانها",
    "t_verse_number": 11,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  },
  {
    "verse_id": 5812,
    "text_uthmani": "وَإِذَا الْجَحِيمُ سُعِّرَتْ",
    "tafseer": "[12] وإذا النار أوقدت فأضرِمت",
    "t_verse_number": 12,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  },
  {
    "verse_id": 5813,
    "text_uthmani": "وَإِذَا الْجَنَّةُ أُزْلِفَتْ",
    "tafseer": "[13] وإذا الجنة دار النعيم قُرِّبت من أهلها المتقين",
    "t_verse_number": 13,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  },
  {
    "verse_id": 5814,
    "text_uthmani": "عَلِمَتْ نَفْسٌ مَّا أَحْضَرَتْ",
    "tafseer": "[14] إذا وقع ذلك، تيقنتْ ووجدتْ كلُّ نفس ما قدَّمت من خير أو شر.",
    "t_verse_number": 14,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  },
  {
    "verse_id": 5815,
    "text_uthmani": "فَلَا أُقْسِمُ بِالْخُنَّسِ",
    "tafseer": "[15] أقسم الله تعالى بالنجوم المختفية أنوارها نهاراً",
    "t_verse_number": 15,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  },
  {
    "verse_id": 5816,
    "text_uthmani": "الْجَوَارِ الْكُنَّسِ",
    "tafseer": "[16]  الجارية والمستترة في أبراجها",
    "t_verse_number": 16,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  },
  {
    "verse_id": 5817,
    "text_uthmani": "وَاللَّيْلِ إِذَا عَسْعَسَ",
    "tafseer": "[17] والليل إذا أقبل بظلامه",
    "t_verse_number": 17,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  },
  {
    "verse_id": 5818,
    "text_uthmani": "وَالصُّبْحِ إِذَا تَنَفَّسَ",
    "tafseer": "[18] والصبح إذا ظهر ضياؤه",
    "t_verse_number": 18,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  },
  {
    "verse_id": 5819,
    "text_uthmani": "إِنَّهُ لَقَوْلُ رَسُولٍ كَرِيمٍ",
    "tafseer": "[19]  إن القرآن لَتبليغ رسول كريم هو جبريل عليه السلام",
    "t_verse_number": 19,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  },
  {
    "verse_id": 5820,
    "text_uthmani": "ذِي قُوَّةٍ عِندَ ذِي الْعَرْشِ مَكِينٍ",
    "tafseer": "[20] ذي قوة في تنفيذ ما يؤمر به، صاحبِ مكانة رفيعة عند الله",
    "t_verse_number": 20,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  },
  {
    "verse_id": 5821,
    "text_uthmani": "مُطَاعٍ ثَمَّ أَمِينٍ",
    "tafseer": "[21] تطيعه الملائكة، مؤتمنٍ على الوحي الذي ينزل به.",
    "t_verse_number": 21,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  },
  {
    "verse_id": 5822,
    "text_uthmani": "وَمَا صَاحِبُكُم بِمَجْنُونٍ",
    "tafseer": "[22] وما محمد الذي تعرفونه بمجنون",
    "t_verse_number": 22,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  },
  {
    "verse_id": 5823,
    "text_uthmani": "وَلَقَدْ رَآهُ بِالْأُفُقِ الْمُبِينِ",
    "tafseer": "[23] ولقد رأى محمدٌ -صلى الله عليه وسلم- جبريلَ الذي يأتيه بالرسالة على صورته الحقيقية التي خلقه الله عليها في الأفق العظيم من ناحية المشرق  ﺑ«مكة»، وهي الرؤية الأولى الواقعةُ  ﺑ«غار حراء»",
    "t_verse_number": 23,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  },
  {
    "verse_id": 5824,
    "text_uthmani": "وَمَا هُوَ عَلَى الْغَيْبِ بِضَنِينٍ",
    "tafseer": "[24] وما محمد -صلى الله عليه وسلم- ببخيل في تبليغ الوحي",
    "t_verse_number": 24,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  },
  {
    "verse_id": 5825,
    "text_uthmani": "وَمَا هُوَ بِقَوْلِ شَيْطَانٍ رَجِيمٍ",
    "tafseer": "[25]  وما هذا القرآن بقول شيطان رجيم، مطرود من رحمة الله، ولكنه كلام الله ووحيه.",
    "t_verse_number": 25,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  },
  {
    "verse_id": 5826,
    "text_uthmani": "فَأَيْنَ تَذْهَبُونَ",
    "tafseer": "[26] فأين تذهب بكم عقولكم في التكذيب بالقرآن بعد هذه الحجج القاطعة؟",
    "t_verse_number": 26,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  },
  {
    "verse_id": 5827,
    "text_uthmani": "إِنْ هُوَ إِلَّا ذِكْرٌ لِّلْعَالَمِينَ",
    "tafseer": "[27] ما هو إلا موعظة من الله لجميع الناس",
    "t_verse_number": 27,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  },
  {
    "verse_id": 5828,
    "text_uthmani": "لِمَن شَاء مِنكُمْ أَن يَسْتَقِيمَ",
    "tafseer": "[28] لمن شاء منكم أن يستقيم على الحق والإيمان",
    "t_verse_number": 28,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  },
  {
    "verse_id": 5829,
    "text_uthmani": "وَمَا تَشَاؤُونَ إِلَّا أَن يَشَاء اللَّهُ رَبُّ الْعَالَمِينَ",
    "tafseer": "[29] وما تشاؤون الاستقامة، ولا تقدرون على ذلك، إلا بمشيئة الله رب الخلائق أجمعين.",
    "t_verse_number": 29,
    "t_chapter_id": 81,
    "t_name_arabic": "التكوير"
  }
]