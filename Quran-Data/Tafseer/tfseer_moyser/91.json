[
  {
    "verse_id": 6044,
    "text_uthmani": "وَالشَّمْسِ وَضُحَاهَا",
    "tafseer": "[1] أقسم الله بالشمس ونهارها وإشراقها ضحى.",
    "t_verse_number": 1,
    "t_chapter_id": 91,
    "t_name_arabic": "الشمس"
  },
  {
    "verse_id": 6045,
    "text_uthmani": "وَالْقَمَرِ إِذَا تَلَاهَا",
    "tafseer": "[2] وبالقمر إذا تبعها في طلوعه ومغيبه",
    "t_verse_number": 2,
    "t_chapter_id": 91,
    "t_name_arabic": "الشمس"
  },
  {
    "verse_id": 6046,
    "text_uthmani": "وَالنَّهَارِ إِذَا جَلَّاهَا",
    "tafseer": "[3] وبالنهار إذا جلَّى الظلمة وكشفها",
    "t_verse_number": 3,
    "t_chapter_id": 91,
    "t_name_arabic": "الشمس"
  },
  {
    "verse_id": 6047,
    "text_uthmani": "وَاللَّيْلِ إِذَا يَغْشَاهَا",
    "tafseer": "[4] وبالليل عندما يغطي الأرض فيكون ما عليها مظلماً",
    "t_verse_number": 4,
    "t_chapter_id": 91,
    "t_name_arabic": "الشمس"
  },
  {
    "verse_id": 6048,
    "text_uthmani": "وَالسَّمَاء وَمَا بَنَاهَا",
    "tafseer": "[5] وبالسماء وبنائها المحكم",
    "t_verse_number": 5,
    "t_chapter_id": 91,
    "t_name_arabic": "الشمس"
  },
  {
    "verse_id": 6049,
    "text_uthmani": "وَالْأَرْضِ وَمَا طَحَاهَا",
    "tafseer": "[6] وبالأرض وبَسْطها",
    "t_verse_number": 6,
    "t_chapter_id": 91,
    "t_name_arabic": "الشمس"
  },
  {
    "verse_id": 6050,
    "text_uthmani": "وَنَفْسٍ وَمَا سَوَّاهَا",
    "tafseer": "[7] وبكل نفس وإكمال الله خلقها لأداء مهمتها",
    "t_verse_number": 7,
    "t_chapter_id": 91,
    "t_name_arabic": "الشمس"
  },
  {
    "verse_id": 6051,
    "text_uthmani": "فَأَلْهَمَهَا فُجُورَهَا وَتَقْوَاهَا",
    "tafseer": "[8] فبيَّن لها طريق الشر وطريق الخير",
    "t_verse_number": 8,
    "t_chapter_id": 91,
    "t_name_arabic": "الشمس"
  },
  {
    "verse_id": 6052,
    "text_uthmani": "قَدْ أَفْلَحَ مَن زَكَّاهَا",
    "tafseer": "[9] قد فاز مَن طهَّرها ونمَّاها بالخير",
    "t_verse_number": 9,
    "t_chapter_id": 91,
    "t_name_arabic": "الشمس"
  },
  {
    "verse_id": 6053,
    "text_uthmani": "وَقَدْ خَابَ مَن دَسَّاهَا",
    "tafseer": "[10] وقد خسر مَن أخفى نفسه في المعاصي.",
    "t_verse_number": 10,
    "t_chapter_id": 91,
    "t_name_arabic": "الشمس"
  },
  {
    "verse_id": 6054,
    "text_uthmani": "كَذَّبَتْ ثَمُودُ بِطَغْوَاهَا",
    "tafseer": "[11] كذَّبت ثمود نبيها ببلوغها الغاية في العصيان",
    "t_verse_number": 11,
    "t_chapter_id": 91,
    "t_name_arabic": "الشمس"
  },
  {
    "verse_id": 6055,
    "text_uthmani": "إِذِ انبَعَثَ أَشْقَاهَا",
    "tafseer": "[12] إذ نهض أكثر القبيلة شقاوة لعقر الناقة",
    "t_verse_number": 12,
    "t_chapter_id": 91,
    "t_name_arabic": "الشمس"
  },
  {
    "verse_id": 6056,
    "text_uthmani": "فَقَالَ لَهُمْ رَسُولُ اللَّهِ نَاقَةَ اللَّهِ وَسُقْيَاهَا",
    "tafseer": "[13] فقال لهم رسول الله صالح عليه السلام: احذروا أن تمسوا الناقة بسوء؛ فإنها آية أرسلها الله إليكم، تدلُّ على صدق نبيِّكم، واحذروا أن تعتدوا على سقيها، فإن لها شِرْبَ يوم ولكم شِرْبُ يوم معلوم",
    "t_verse_number": 13,
    "t_chapter_id": 91,
    "t_name_arabic": "الشمس"
  },
  {
    "verse_id": 6057,
    "text_uthmani": "فَكَذَّبُوهُ فَعَقَرُوهَا فَدَمْدَمَ عَلَيْهِمْ رَبُّهُم بِذَنبِهِمْ فَسَوَّاهَا",
    "tafseer": "[14] فشق عليهم ذلك، فكذبوه فيما توعَّدهم به فنحروها، فأطبق عليهم ربهم العقوبة بجرمهم، فجعلها عليهم على السواء فلم يُفْلِت منهم أحد",
    "t_verse_number": 14,
    "t_chapter_id": 91,
    "t_name_arabic": "الشمس"
  },
  {
    "verse_id": 6058,
    "text_uthmani": "وَلَا يَخَافُ عُقْبَاهَا",
    "tafseer": "[15] ولا يخاف -جَلَّت قدرته- تبعة ما أنزله بهم من شديد العقاب.",
    "t_verse_number": 15,
    "t_chapter_id": 91,
    "t_name_arabic": "الشمس"
  }
]