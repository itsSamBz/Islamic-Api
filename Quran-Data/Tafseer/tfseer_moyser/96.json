[
  {
    "verse_id": 6107,
    "text_uthmani": "اقْرَأْ بِاسْمِ رَبِّكَ الَّذِي خَلَقَ",
    "tafseer": "[1] اقرأ -أيها النبي- ما أُنزل إليك من القرآن مُفْتَتِحاً باسم ربك المتفرد بالخلق",
    "t_verse_number": 1,
    "t_chapter_id": 96,
    "t_name_arabic": "العلق"
  },
  {
    "verse_id": 6108,
    "text_uthmani": "خَلَقَ الْإِنسَانَ مِنْ عَلَقٍ",
    "tafseer": "[2] الذي خلق كل إنسان من قطعة دم غليظ أحمر",
    "t_verse_number": 2,
    "t_chapter_id": 96,
    "t_name_arabic": "العلق"
  },
  {
    "verse_id": 6109,
    "text_uthmani": "اقْرَأْ وَرَبُّكَ الْأَكْرَمُ",
    "tafseer": "[3] اقرأ -أيها النبي- ما أُنزل إليك، وإن ربك لكثير الإحسان واسع الجود",
    "t_verse_number": 3,
    "t_chapter_id": 96,
    "t_name_arabic": "العلق"
  },
  {
    "verse_id": 6110,
    "text_uthmani": "الَّذِي عَلَّمَ بِالْقَلَمِ",
    "tafseer": "[4] الذي علَّم خلقه الكتابة بالقلم",
    "t_verse_number": 4,
    "t_chapter_id": 96,
    "t_name_arabic": "العلق"
  },
  {
    "verse_id": 6111,
    "text_uthmani": "عَلَّمَ الْإِنسَانَ مَا لَمْ يَعْلَمْ",
    "tafseer": "[5] علَّم الإنسان ما لم يكن يعلم، ونقله من ظلمة الجهل إلى نور العلم.",
    "t_verse_number": 5,
    "t_chapter_id": 96,
    "t_name_arabic": "العلق"
  },
  {
    "verse_id": 6112,
    "text_uthmani": "كَلَّا إِنَّ الْإِنسَانَ لَيَطْغَى",
    "tafseer": "[6] حقّاً أن الإنسان ليتجاوز حدود الله",
    "t_verse_number": 6,
    "t_chapter_id": 96,
    "t_name_arabic": "العلق"
  },
  {
    "verse_id": 6113,
    "text_uthmani": "أَن رَّآهُ اسْتَغْنَى",
    "tafseer": "[7]  إذا أبطره الغنى",
    "t_verse_number": 7,
    "t_chapter_id": 96,
    "t_name_arabic": "العلق"
  },
  {
    "verse_id": 6114,
    "text_uthmani": "إِنَّ إِلَى رَبِّكَ الرُّجْعَى",
    "tafseer": "[8] فليعلم كل طاغية أن المصير إلى الله، فيجازي كلَّ إنسان بعمله.",
    "t_verse_number": 8,
    "t_chapter_id": 96,
    "t_name_arabic": "العلق"
  },
  {
    "verse_id": 6115,
    "text_uthmani": "أَرَأَيْتَ الَّذِي يَنْهَى",
    "tafseer": "[9] أرأيت أعجب مِن طغيان هذا الرجل، وهو أبو جهل",
    "t_verse_number": 9,
    "t_chapter_id": 96,
    "t_name_arabic": "العلق"
  },
  {
    "verse_id": 6116,
    "text_uthmani": "عَبْدًا إِذَا صَلَّى",
    "tafseer": "[10] الذي ينهى عبداً لنا إذا صلَّى لربه، وهو محمد -صلى الله عليه وسلم-؟",
    "t_verse_number": 10,
    "t_chapter_id": 96,
    "t_name_arabic": "العلق"
  },
  {
    "verse_id": 6117,
    "text_uthmani": "أَرَأَيْتَ إِن كَانَ عَلَى الْهُدَى",
    "tafseer": "[11] أرأيت إن كان المنهي عن الصلاة على الهدى فكيف ينهاه؟",
    "t_verse_number": 11,
    "t_chapter_id": 96,
    "t_name_arabic": "العلق"
  },
  {
    "verse_id": 6118,
    "text_uthmani": "أَوْ أَمَرَ بِالتَّقْوَى",
    "tafseer": "[12] أو إن كان آمراً غيره بالتقوى أينهاه عن ذلك؟",
    "t_verse_number": 12,
    "t_chapter_id": 96,
    "t_name_arabic": "العلق"
  },
  {
    "verse_id": 6119,
    "text_uthmani": "أَرَأَيْتَ إِن كَذَّبَ وَتَوَلَّى",
    "tafseer": "[13] أرأيت إن كذَّب هذا الناهي بما يُدعى إليه، وأعرض عنه",
    "t_verse_number": 13,
    "t_chapter_id": 96,
    "t_name_arabic": "العلق"
  },
  {
    "verse_id": 6120,
    "text_uthmani": "أَلَمْ يَعْلَمْ بِأَنَّ اللَّهَ يَرَى",
    "tafseer": "[14] ألم يعلم بأن الله يرى كل ما يفعل؟",
    "t_verse_number": 14,
    "t_chapter_id": 96,
    "t_name_arabic": "العلق"
  },
  {
    "verse_id": 6121,
    "text_uthmani": "كَلَّا لَئِن لَّمْ يَنتَهِ لَنَسْفَعًا بِالنَّاصِيَةِ",
    "tafseer": "[15] ليس الأمر كما يزعم أبو جهل، لئن لم يرجع هذا عن شقاقه وأذاه لنأخذنَّ بمقدَّم رأسه أخذاً عنيفاً وليطرحَنَّ في النار",
    "t_verse_number": 15,
    "t_chapter_id": 96,
    "t_name_arabic": "العلق"
  },
  {
    "verse_id": 6122,
    "text_uthmani": "نَاصِيَةٍ كَاذِبَةٍ خَاطِئَةٍ",
    "tafseer": "[16] ناصيته ناصية كاذبة في مقالها، خاطئة في أفعالها، فكأنَّ الكذب والخطَأ باديان منها",
    "t_verse_number": 16,
    "t_chapter_id": 96,
    "t_name_arabic": "العلق"
  },
  {
    "verse_id": 6123,
    "text_uthmani": "فَلْيَدْعُ نَادِيَه",
    "tafseer": "[17] فليُحْضِر هذا الطاغية أهل ناديه الذين يستنصر بهم",
    "t_verse_number": 17,
    "t_chapter_id": 96,
    "t_name_arabic": "العلق"
  },
  {
    "verse_id": 6124,
    "text_uthmani": "سَنَدْعُ الزَّبَانِيَةَ",
    "tafseer": "[18] سندعو ملائكة العذاب",
    "t_verse_number": 18,
    "t_chapter_id": 96,
    "t_name_arabic": "العلق"
  },
  {
    "verse_id": 6125,
    "text_uthmani": "كَلَّا لَا تُطِعْهُ وَاسْجُدْ وَاقْتَرِبْ",
    "tafseer": "[19] ليس الأمر على ما يظن أبو جهل، إنه لن ينالك -أيها الرسول- بسوء، فلا تطعه فيما دعاك إليه مِن تَرْك الصلاة، واسجد لربك، واقترب منه بالتحبب إليه بطاعته.",
    "t_verse_number": 19,
    "t_chapter_id": 96,
    "t_name_arabic": "العلق"
  }
]