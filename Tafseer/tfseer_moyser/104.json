[
  {
    "verse_id": 6180,
    "text_uthmani": "وَيْلٌ لِّكُلِّ هُمَزَةٍ لُّمَزَةٍ",
    "tafseer": "[1] شر وهلاك لكل مغتاب للناسِ، طعَّان فيهم.",
    "t_verse_number": 1,
    "t_chapter_id": 104,
    "t_name_arabic": "الهمزة"
  },
  {
    "verse_id": 6181,
    "text_uthmani": "الَّذِي جَمَعَ مَالًا وَعَدَّدَهُ",
    "tafseer": "[2] الذي كان همُّه جمع المال وتَعْداده.",
    "t_verse_number": 2,
    "t_chapter_id": 104,
    "t_name_arabic": "الهمزة"
  },
  {
    "verse_id": 6182,
    "text_uthmani": "يَحْسَبُ أَنَّ مَالَهُ أَخْلَدَهُ",
    "tafseer": "[3] يظن أنه ضَمِنَ لنفسه بهذا المال الذي جمعه، الخلود في الدنيا والإفلات من الحساب.",
    "t_verse_number": 3,
    "t_chapter_id": 104,
    "t_name_arabic": "الهمزة"
  },
  {
    "verse_id": 6183,
    "text_uthmani": "كَلَّا لَيُنبَذَنَّ فِي الْحُطَمَةِ",
    "tafseer": "[4] ليس الأمر كما ظن، ليُطرحنَّ في النار التي تهشم كل ما يُلْقى فيها.",
    "t_verse_number": 4,
    "t_chapter_id": 104,
    "t_name_arabic": "الهمزة"
  },
  {
    "verse_id": 6184,
    "text_uthmani": "وَمَا أَدْرَاكَ مَا الْحُطَمَةُ",
    "tafseer": "[5] وما أدراك -أيها الرسول- ما حقيقة النار؟",
    "t_verse_number": 5,
    "t_chapter_id": 104,
    "t_name_arabic": "الهمزة"
  },
  {
    "verse_id": 6185,
    "text_uthmani": "نَارُ اللَّهِ الْمُوقَدَةُ",
    "tafseer": "[6] إنها نار الله المشتعلةُ الشديدةُ اللَّهب",
    "t_verse_number": 6,
    "t_chapter_id": 104,
    "t_name_arabic": "الهمزة"
  },
  {
    "verse_id": 6186,
    "text_uthmani": "الَّتِي تَطَّلِعُ عَلَى الْأَفْئِدَةِ",
    "tafseer": "[7]  التي من شدة حرِّها تنفُذ من الأجسام إلى القلوب.",
    "t_verse_number": 7,
    "t_chapter_id": 104,
    "t_name_arabic": "الهمزة"
  },
  {
    "verse_id": 6187,
    "text_uthmani": "إِنَّهَا عَلَيْهِم مُّؤْصَدَةٌ",
    "tafseer": "[8] إنها عليهم مطبَقة",
    "t_verse_number": 8,
    "t_chapter_id": 104,
    "t_name_arabic": "الهمزة"
  },
  {
    "verse_id": 6188,
    "text_uthmani": "فِي عَمَدٍ مُّمَدَّدَةٍ",
    "tafseer": "[9] في سلاسل وأغلال مطوَّلة؛ لئلا يخرجوا منها.",
    "t_verse_number": 9,
    "t_chapter_id": 104,
    "t_name_arabic": "الهمزة"
  }
]