[
  {
    "verse_id": 5830,
    "text_uthmani": "إِذَا السَّمَاء انفَطَرَتْ",
    "tafseer": "[1] إذا السماء انشقت، واختلَّ نظامها.",
    "t_verse_number": 1,
    "t_chapter_id": 82,
    "t_name_arabic": "الإنفطار"
  },
  {
    "verse_id": 5831,
    "text_uthmani": "وَإِذَا الْكَوَاكِبُ انتَثَرَتْ",
    "tafseer": "[2] إوإذا الكواكب تساقطت",
    "t_verse_number": 2,
    "t_chapter_id": 82,
    "t_name_arabic": "الإنفطار"
  },
  {
    "verse_id": 5832,
    "text_uthmani": "وَإِذَا الْبِحَارُ فُجِّرَتْ",
    "tafseer": "[3] وإذا البحار فجَّر الله بعضها في بعض، فذهب ماؤها",
    "t_verse_number": 3,
    "t_chapter_id": 82,
    "t_name_arabic": "الإنفطار"
  },
  {
    "verse_id": 5833,
    "text_uthmani": "وَإِذَا الْقُبُورُ بُعْثِرَتْ",
    "tafseer": "[4] وإذا القبور قُلِبت ببعث مَن كان فيها",
    "t_verse_number": 4,
    "t_chapter_id": 82,
    "t_name_arabic": "الإنفطار"
  },
  {
    "verse_id": 5834,
    "text_uthmani": "عَلِمَتْ نَفْسٌ مَّا قَدَّمَتْ وَأَخَّرَتْ",
    "tafseer": "[5]  حينئذ تعلم كلُّ نفس جميع أعمالها، ما تقدَّم منها وما تأخر، وجوزيت بها.",
    "t_verse_number": 5,
    "t_chapter_id": 82,
    "t_name_arabic": "الإنفطار"
  },
  {
    "verse_id": 5835,
    "text_uthmani": "يَا أَيُّهَا الْإِنسَانُ مَا غَرَّكَ بِرَبِّكَ الْكَرِيمِ",
    "tafseer": "[6] يا أيها الإنسان المنكر للبعث، ما الذي جعلك تغترُّ بربك الجوادِ الكثير الخير، الحقيق بالشكر والطاعة",
    "t_verse_number": 6,
    "t_chapter_id": 82,
    "t_name_arabic": "الإنفطار"
  },
  {
    "verse_id": 5836,
    "text_uthmani": "الَّذِي خَلَقَكَ فَسَوَّاكَ فَعَدَلَكَ",
    "tafseer": "[7] أليس هو الذي خلقك فسوَّى خلقك فعَدَلك، وركَّبك لأداء وظائفك",
    "t_verse_number": 7,
    "t_chapter_id": 82,
    "t_name_arabic": "الإنفطار"
  },
  {
    "verse_id": 5837,
    "text_uthmani": "فِي أَيِّ صُورَةٍ مَّا شَاء رَكَّبَكَ",
    "tafseer": "8] في أيِّ صورة شاءها خلقك؟",
    "t_verse_number": 8,
    "t_chapter_id": 82,
    "t_name_arabic": "الإنفطار"
  },
  {
    "verse_id": 5838,
    "text_uthmani": "كَلَّا بَلْ تُكَذِّبُونَ بِالدِّينِ",
    "tafseer": "[9] ليس الأمر كما تقولون من أنكم في عبادتكم غير الله مُحِقون، بل تكذِّبون بيوم الحساب والجزاء",
    "t_verse_number": 9,
    "t_chapter_id": 82,
    "t_name_arabic": "الإنفطار"
  },
  {
    "verse_id": 5839,
    "text_uthmani": "وَإِنَّ عَلَيْكُمْ لَحَافِظِينَ",
    "tafseer": "[10] وإن عليكم لملائكة رقباء",
    "t_verse_number": 10,
    "t_chapter_id": 82,
    "t_name_arabic": "الإنفطار"
  },
  {
    "verse_id": 5840,
    "text_uthmani": "كِرَامًا كَاتِبِينَ",
    "tafseer": "[11] كراماً على الله كاتبين لما وُكِّلوا بإحصائه، لا يفوتهم من أعمالكم شيء",
    "t_verse_number": 11,
    "t_chapter_id": 82,
    "t_name_arabic": "الإنفطار"
  },
  {
    "verse_id": 5841,
    "text_uthmani": "يَعْلَمُونَ مَا تَفْعَلُونَ",
    "tafseer": "[12] يعلمون ما تفعلون من خير أو شر.",
    "t_verse_number": 12,
    "t_chapter_id": 82,
    "t_name_arabic": "الإنفطار"
  },
  {
    "verse_id": 5842,
    "text_uthmani": "إِنَّ الْأَبْرَارَ لَفِي نَعِيمٍ",
    "tafseer": "[13] إن الأتقياء القائمين بحقوق الله وحقوق عباده لفي نعيم.",
    "t_verse_number": 13,
    "t_chapter_id": 82,
    "t_name_arabic": "الإنفطار"
  },
  {
    "verse_id": 5843,
    "text_uthmani": "وَإِنَّ الْفُجَّارَ لَفِي جَحِيمٍ",
    "tafseer": "[14] وإن الفُجَّار الذين قَصَّروا في حقوق الله وحقوق عباده لفي جحيم",
    "t_verse_number": 14,
    "t_chapter_id": 82,
    "t_name_arabic": "الإنفطار"
  },
  {
    "verse_id": 5844,
    "text_uthmani": "يَصْلَوْنَهَا يَوْمَ الدِّينِ",
    "tafseer": "[15] يصيبهم لهبها يوم الجزاء",
    "t_verse_number": 15,
    "t_chapter_id": 82,
    "t_name_arabic": "الإنفطار"
  },
  {
    "verse_id": 5845,
    "text_uthmani": "وَمَا هُمْ عَنْهَا بِغَائِبِينَ",
    "tafseer": "[16] وما هم عن عذاب جهنم بغائبين لا بخروج ولا بموت.",
    "t_verse_number": 16,
    "t_chapter_id": 82,
    "t_name_arabic": "الإنفطار"
  },
  {
    "verse_id": 5846,
    "text_uthmani": "وَمَا أَدْرَاكَ مَا يَوْمُ الدِّينِ",
    "tafseer": "[17] وما أدراك ما عظمةُ يوم الحساب",
    "t_verse_number": 17,
    "t_chapter_id": 82,
    "t_name_arabic": "الإنفطار"
  },
  {
    "verse_id": 5847,
    "text_uthmani": "ثُمَّ مَا أَدْرَاكَ مَا يَوْمُ الدِّينِ",
    "tafseer": "[18] ثم ما أدراك ما عظمة يوم الحساب؟",
    "t_verse_number": 18,
    "t_chapter_id": 82,
    "t_name_arabic": "الإنفطار"
  },
  {
    "verse_id": 5848,
    "text_uthmani": "يَوْمَ لَا تَمْلِكُ نَفْسٌ لِّنَفْسٍ شَيْئًا وَالْأَمْرُ يَوْمَئِذٍ لِلَّهِ",
    "tafseer": "[19] يوم الحساب لا يقدر أحد على نفع أحد، والأمر في ذلك اليوم لله وحده الذي لا يغلبه غالب، ولا يقهره قاهر، ولا ينازعه أحد.",
    "t_verse_number": 19,
    "t_chapter_id": 82,
    "t_name_arabic": "الإنفطار"
  }
]