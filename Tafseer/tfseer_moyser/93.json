[
  {
    "verse_id": 6080,
    "text_uthmani": "وَالضُّحَى",
    "tafseer": "[1] أقسم الله بوقت الضحى، والمراد به النهار كله",
    "t_verse_number": 1,
    "t_chapter_id": 93,
    "t_name_arabic": "الضحى"
  },
  {
    "verse_id": 6081,
    "text_uthmani": "وَاللَّيْلِ إِذَا سَجَى",
    "tafseer": "[2]  وبالليل إذا سكن بالخلق واشتد ظلامه، ويقسم الله بما يشاء من مخلوقاته، أما المخلوق فلا يجوز له أن يقسم بغير خالقه، فإن القسم بغير الله شرك.",
    "t_verse_number": 2,
    "t_chapter_id": 93,
    "t_name_arabic": "الضحى"
  },
  {
    "verse_id": 6082,
    "text_uthmani": "مَا وَدَّعَكَ رَبُّكَ وَمَا قَلَى",
    "tafseer": "[3]  ما تركك -أيها النبي- ربك، وما أبغضك بإبطاء الوحي عنك.",
    "t_verse_number": 3,
    "t_chapter_id": 93,
    "t_name_arabic": "الضحى"
  },
  {
    "verse_id": 6083,
    "text_uthmani": "وَلَلْآخِرَةُ خَيْرٌ لَّكَ مِنَ الْأُولَى",
    "tafseer": "[4] ولَلدار الآخرة خير لك من دار الدنيا",
    "t_verse_number": 4,
    "t_chapter_id": 93,
    "t_name_arabic": "الضحى"
  },
  {
    "verse_id": 6084,
    "text_uthmani": "وَلَسَوْفَ يُعْطِيكَ رَبُّكَ فَتَرْضَى",
    "tafseer": "[5] ولسوف يعطيك ربك -أيها النبي- مِن أنواع الإنعام في الآخرة، فترضى بذلك.",
    "t_verse_number": 5,
    "t_chapter_id": 93,
    "t_name_arabic": "الضحى"
  },
  {
    "verse_id": 6085,
    "text_uthmani": "أَلَمْ يَجِدْكَ يَتِيمًا فَآوَى",
    "tafseer": "[6] ألم يَجِدْك من قبلُ يتيماً مات أبوك وأنت حَمْل في بطن أمِّك، فآواك ورعاك؟",
    "t_verse_number": 6,
    "t_chapter_id": 93,
    "t_name_arabic": "الضحى"
  },
  {
    "verse_id": 6086,
    "text_uthmani": "وَوَجَدَكَ ضَالًّا فَهَدَى",
    "tafseer": "[7] ووجدك لا تدري ما الكتاب ولا الإيمان، فعلَّمك ما لم تكن تعلم، ووفقك لأحسن الأعمال؟",
    "t_verse_number": 7,
    "t_chapter_id": 93,
    "t_name_arabic": "الضحى"
  },
  {
    "verse_id": 6087,
    "text_uthmani": "وَوَجَدَكَ عَائِلًا فَأَغْنَى",
    "tafseer": "[8] ووجدك فقيراً، فساق إليك رزقك، وأغنى نفسك بالقناعة والصبر؟",
    "t_verse_number": 8,
    "t_chapter_id": 93,
    "t_name_arabic": "الضحى"
  },
  {
    "verse_id": 6088,
    "text_uthmani": "فَأَمَّا الْيَتِيمَ فَلَا تَقْهَرْ",
    "tafseer": "[9] فأما اليتيم فلا تُسِئْ معاملته ",
    "t_verse_number": 9,
    "t_chapter_id": 93,
    "t_name_arabic": "الضحى"
  },
  {
    "verse_id": 6089,
    "text_uthmani": "وَأَمَّا السَّائِلَ فَلَا تَنْهَرْ",
    "tafseer": "[10] وأما السائل فلا تزجره، بل أطعمه، واقض حاجته",
    "t_verse_number": 10,
    "t_chapter_id": 93,
    "t_name_arabic": "الضحى"
  },
  {
    "verse_id": 6090,
    "text_uthmani": "وَأَمَّا بِنِعْمَةِ رَبِّكَ فَحَدِّثْ",
    "tafseer": "[11] وأما بنعمة ربك التي أسبغها عليك فتحدث بها.",
    "t_verse_number": 11,
    "t_chapter_id": 93,
    "t_name_arabic": "الضحى"
  }
]