[
  {
    "verse_id": 5968,
    "text_uthmani": "هَلْ أَتَاكَ حَدِيثُ الْغَاشِيَةِ",
    "tafseer": "[1] هل أتاك -أيها الرسول- خبر القيامة التي تغشى الناس بأهوالها؟",
    "t_verse_number": 1,
    "t_chapter_id": 88,
    "t_name_arabic": "الغاشية"
  },
  {
    "verse_id": 5969,
    "text_uthmani": "وُجُوهٌ يَوْمَئِذٍ خَاشِعَةٌ",
    "tafseer": "[2] وجوه الكفار يومئذ ذليلة بالعذاب",
    "t_verse_number": 2,
    "t_chapter_id": 88,
    "t_name_arabic": "الغاشية"
  },
  {
    "verse_id": 5970,
    "text_uthmani": "عَامِلَةٌ نَّاصِبَةٌ",
    "tafseer": "[3]  مجهدة بالعمل متعبة",
    "t_verse_number": 3,
    "t_chapter_id": 88,
    "t_name_arabic": "الغاشية"
  },
  {
    "verse_id": 5971,
    "text_uthmani": "تَصْلَى نَارًا حَامِيَةً",
    "tafseer": "[4]  تصيبها نار شديدة التوهج",
    "t_verse_number": 4,
    "t_chapter_id": 88,
    "t_name_arabic": "الغاشية"
  },
  {
    "verse_id": 5972,
    "text_uthmani": "تُسْقَى مِنْ عَيْنٍ آنِيَةٍ",
    "tafseer": "[5] تُسقى مِن عين بلغت منتهى الحرارة",
    "t_verse_number": 5,
    "t_chapter_id": 88,
    "t_name_arabic": "الغاشية"
  },
  {
    "verse_id": 5973,
    "text_uthmani": "لَّيْسَ لَهُمْ طَعَامٌ إِلَّا مِن ضَرِيعٍ",
    "tafseer": "[6] ليس لأصحاب النار طعام إلا مِن نبت ذي شوك لاصق بالأرض، وهو مِن شر الطعام وأخبثه",
    "t_verse_number": 6,
    "t_chapter_id": 88,
    "t_name_arabic": "الغاشية"
  },
  {
    "verse_id": 5974,
    "text_uthmani": "لَا يُسْمِنُ وَلَا يُغْنِي مِن جُوعٍ",
    "tafseer": "[7] لا يُسْمن بدن صاحبه من الهُزال، ولا يسدُّ جوعه ورَمَقَه.",
    "t_verse_number": 7,
    "t_chapter_id": 88,
    "t_name_arabic": "الغاشية"
  },
  {
    "verse_id": 5975,
    "text_uthmani": "وُجُوهٌ يَوْمَئِذٍ نَّاعِمَةٌ",
    "tafseer": "[8] وجوه المؤمنين يوم القيامة ذات نعمة.",
    "t_verse_number": 8,
    "t_chapter_id": 88,
    "t_name_arabic": "الغاشية"
  },
  {
    "verse_id": 5976,
    "text_uthmani": "لِسَعْيِهَا رَاضِيَةٌ",
    "tafseer": "[9]  لسعيها في الدنيا بالطاعات راضية في الآخرة",
    "t_verse_number": 9,
    "t_chapter_id": 88,
    "t_name_arabic": "الغاشية"
  },
  {
    "verse_id": 5977,
    "text_uthmani": "فِي جَنَّةٍ عَالِيَةٍ",
    "tafseer": "[10] في جنة رفيعة المكان والمكانة",
    "t_verse_number": 10,
    "t_chapter_id": 88,
    "t_name_arabic": "الغاشية"
  },
  {
    "verse_id": 5978,
    "text_uthmani": "لَّا تَسْمَعُ فِيهَا لَاغِيَةً",
    "tafseer": "[11] لا تسمع فيها كلمة لغو واحدة",
    "t_verse_number": 11,
    "t_chapter_id": 88,
    "t_name_arabic": "الغاشية"
  },
  {
    "verse_id": 5979,
    "text_uthmani": "فِيهَا عَيْنٌ جَارِيَةٌ",
    "tafseer": "[12]  فيها عين تتدفق مياهها",
    "t_verse_number": 12,
    "t_chapter_id": 88,
    "t_name_arabic": "الغاشية"
  },
  {
    "verse_id": 5980,
    "text_uthmani": "فِيهَا سُرُرٌ مَّرْفُوعَةٌ",
    "tafseer": "[13] فيها سرر عالية",
    "t_verse_number": 13,
    "t_chapter_id": 88,
    "t_name_arabic": "الغاشية"
  },
  {
    "verse_id": 5981,
    "text_uthmani": "وَأَكْوَابٌ مَّوْضُوعَةٌ",
    "tafseer": "[14]  وأكواب معدة للشاربين",
    "t_verse_number": 14,
    "t_chapter_id": 88,
    "t_name_arabic": "الغاشية"
  },
  {
    "verse_id": 5982,
    "text_uthmani": "وَنَمَارِقُ مَصْفُوفَةٌ",
    "tafseer": "[15] ووسائد مصفوفة، الواحدة جنب الأخرى",
    "t_verse_number": 15,
    "t_chapter_id": 88,
    "t_name_arabic": "الغاشية"
  },
  {
    "verse_id": 5983,
    "text_uthmani": "وَزَرَابِيُّ مَبْثُوثَةٌ",
    "tafseer": "[16]  وبُسُط كثيرة مفروشة.",
    "t_verse_number": 16,
    "t_chapter_id": 88,
    "t_name_arabic": "الغاشية"
  },
  {
    "verse_id": 5984,
    "text_uthmani": "أَفَلَا يَنظُرُونَ إِلَى الْإِبِلِ كَيْفَ خُلِقَتْ",
    "tafseer": "[17] أفلا ينظر الكافرون المكذِّبون إلى الإبل: كيف خُلِقَت هذا الخلق العجيب؟",
    "t_verse_number": 17,
    "t_chapter_id": 88,
    "t_name_arabic": "الغاشية"
  },
  {
    "verse_id": 5985,
    "text_uthmani": "وَإِلَى السَّمَاء كَيْفَ رُفِعَتْ",
    "tafseer": "[18] وإلى السماء كيف رُفِعَت هذا الرَّفع البديع؟",
    "t_verse_number": 18,
    "t_chapter_id": 88,
    "t_name_arabic": "الغاشية"
  },
  {
    "verse_id": 5986,
    "text_uthmani": "وَإِلَى الْجِبَالِ كَيْفَ نُصِبَتْ",
    "tafseer": "[19] وإلى الجبال كيف نُصبت، فحصل بها الثبات للأرض والاستقرار؟",
    "t_verse_number": 19,
    "t_chapter_id": 88,
    "t_name_arabic": "الغاشية"
  },
  {
    "verse_id": 5987,
    "text_uthmani": "وَإِلَى الْأَرْضِ كَيْفَ سُطِحَتْ",
    "tafseer": "[20] وإلى الأرض كيف بُسِطت ومُهِّدت؟",
    "t_verse_number": 20,
    "t_chapter_id": 88,
    "t_name_arabic": "الغاشية"
  },
  {
    "verse_id": 5988,
    "text_uthmani": "فَذَكِّرْ إِنَّمَا أَنتَ مُذَكِّرٌ",
    "tafseer": "[21] فعِظْ -أيها الرسول- المعرضين بما أُرْسِلْتَ به إليهم، ولا تحزن على إعراضهم، إنما أنت واعظ لهم",
    "t_verse_number": 21,
    "t_chapter_id": 88,
    "t_name_arabic": "الغاشية"
  },
  {
    "verse_id": 5989,
    "text_uthmani": "لَّسْتَ عَلَيْهِم بِمُصَيْطِرٍ",
    "tafseer": "[22] ليس عليك إكراههم على الإيمان.",
    "t_verse_number": 22,
    "t_chapter_id": 88,
    "t_name_arabic": "الغاشية"
  },
  {
    "verse_id": 5990,
    "text_uthmani": "إِلَّا مَن تَوَلَّى وَكَفَرَ",
    "tafseer": "[23] لكن الذي أعرض عن التذكير والموعظة وأصرَّ على كفره",
    "t_verse_number": 23,
    "t_chapter_id": 88,
    "t_name_arabic": "الغاشية"
  },
  {
    "verse_id": 5991,
    "text_uthmani": "فَيُعَذِّبُهُ اللَّهُ الْعَذَابَ الْأَكْبَرَ",
    "tafseer": "[24] فيعذبه الله العذاب الشديد في النار.",
    "t_verse_number": 24,
    "t_chapter_id": 88,
    "t_name_arabic": "الغاشية"
  },
  {
    "verse_id": 5992,
    "text_uthmani": "إِنَّ إِلَيْنَا إِيَابَهُمْ",
    "tafseer": "[25] إنَّ إلينا مرجعهم بعد الموت",
    "t_verse_number": 25,
    "t_chapter_id": 88,
    "t_name_arabic": "الغاشية"
  },
  {
    "verse_id": 5993,
    "text_uthmani": "ثُمَّ إِنَّ عَلَيْنَا حِسَابَهُمْ",
    "tafseer": "[26] ثم إن علينا جزاءهم على ما عملوا.",
    "t_verse_number": 26,
    "t_chapter_id": 88,
    "t_name_arabic": "الغاشية"
  }
]