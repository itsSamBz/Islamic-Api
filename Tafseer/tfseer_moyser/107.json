[
  {
    "verse_id": 6198,
    "text_uthmani": "أَرَأَيْتَ الَّذِي يُكَذِّبُ بِالدِّينِ",
    "tafseer": "[1] أرأيت حال ذلك الذي يكذِّب بالبعث والجزاء؟",
    "t_verse_number": 1,
    "t_chapter_id": 107,
    "t_name_arabic": "الماعون"
  },
  {
    "verse_id": 6199,
    "text_uthmani": "فَذَلِكَ الَّذِي يَدُعُّ الْيَتِيمَ",
    "tafseer": "[2] فذلك الذي يدفع اليتيم الذي مات أبوه وهو صغير بعنف وشدة عن حقه؛ لقساوة قلبه.",
    "t_verse_number": 2,
    "t_chapter_id": 107,
    "t_name_arabic": "الماعون"
  },
  {
    "verse_id": 6200,
    "text_uthmani": "وَلَا يَحُضُّ عَلَى طَعَامِ الْمِسْكِينِ",
    "tafseer": "[3] ولا يحضُّ غيره على إطعام المحتاج الذي لا يملك ما يكفيه ويسدُّ حاجته، فكيف له أن يطعمه بنفسه؟",
    "t_verse_number": 3,
    "t_chapter_id": 107,
    "t_name_arabic": "الماعون"
  },
  {
    "verse_id": 6201,
    "text_uthmani": "فَوَيْلٌ لِّلْمُصَلِّينَ",
    "tafseer": "[4] فعذاب شديد للمصلين",
    "t_verse_number": 4,
    "t_chapter_id": 107,
    "t_name_arabic": "الماعون"
  },
  {
    "verse_id": 6202,
    "text_uthmani": "الَّذِينَ هُمْ عَن صَلَاتِهِمْ سَاهُونَ",
    "tafseer": "[5]  الذين هم عن صلاتهم لاهون، لا يقيمونها على وجهها، ولا يؤدونها في وقتها.",
    "t_verse_number": 5,
    "t_chapter_id": 107,
    "t_name_arabic": "الماعون"
  },
  {
    "verse_id": 6203,
    "text_uthmani": "الَّذِينَ هُمْ يُرَاؤُونَ",
    "tafseer": "[6] الذين هم يتظاهرون بأعمال الخير؛ مراءاة للناس.",
    "t_verse_number": 6,
    "t_chapter_id": 107,
    "t_name_arabic": "الماعون"
  },
  {
    "verse_id": 6204,
    "text_uthmani": "وَيَمْنَعُونَ الْمَاعُونَ",
    "tafseer": "[7] ويمنعون إعارة ما لا تضر إعارته من الآنية وغيرها، فلا هم أحسنوا عبادة ربهم، ولا هم أحسنوا إلى خلقه.",
    "t_verse_number": 7,
    "t_chapter_id": 107,
    "t_name_arabic": "الماعون"
  }
]