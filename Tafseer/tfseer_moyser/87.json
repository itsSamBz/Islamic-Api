[
  {
    "verse_id": 5949,
    "text_uthmani": "سَبِّحِ اسْمَ رَبِّكَ الْأَعْلَى",
    "tafseer": "[1] نَزِّه اسم ربك الأعلى عن الشريك والنقائص تنزيهاً يليق بعظمته سبحانه ",
    "t_verse_number": 1,
    "t_chapter_id": 87,
    "t_name_arabic": "الأعلى"
  },
  {
    "verse_id": 5950,
    "text_uthmani": "الَّذِي خَلَقَ فَسَوَّى",
    "tafseer": "[2] الذي خلق المخلوقات، فأتقن خلقها، وأحسنه",
    "t_verse_number": 2,
    "t_chapter_id": 87,
    "t_name_arabic": "الأعلى"
  },
  {
    "verse_id": 5951,
    "text_uthmani": "وَالَّذِي قَدَّرَ فَهَدَى",
    "tafseer": "[3] والذي قدَّر جميع المقدرات، فهدى كل خلق إلى ما يناسبه",
    "t_verse_number": 3,
    "t_chapter_id": 87,
    "t_name_arabic": "الأعلى"
  },
  {
    "verse_id": 5952,
    "text_uthmani": "وَالَّذِي أَخْرَجَ الْمَرْعَى",
    "tafseer": "[4] والذي أنبت الكلأ الأخضر",
    "t_verse_number": 4,
    "t_chapter_id": 87,
    "t_name_arabic": "الأعلى"
  },
  {
    "verse_id": 5953,
    "text_uthmani": "فَجَعَلَهُ غُثَاء أَحْوَى",
    "tafseer": "[5] فجعله بعد ذلك هشيماً جافّاً متغيِّراً إلى السَّواد بعد اخضراره.",
    "t_verse_number": 5,
    "t_chapter_id": 87,
    "t_name_arabic": "الأعلى"
  },
  {
    "verse_id": 5954,
    "text_uthmani": "سَنُقْرِؤُكَ فَلَا تَنسَى",
    "tafseer": "[6] سنقرئك -أيها الرسول- هذا القرآن قراءة لا تنساها",
    "t_verse_number": 6,
    "t_chapter_id": 87,
    "t_name_arabic": "الأعلى"
  },
  {
    "verse_id": 5955,
    "text_uthmani": "إِلَّا مَا شَاء اللَّهُ إِنَّهُ يَعْلَمُ الْجَهْرَ وَمَا يَخْفَى",
    "tafseer": "[7] إلَّا ما شاء الله مما اقتضت حكمته أن ينسيه لمصلحة يعلمها. إنه -سبحانه- يعلم الجهر من القول والعمل، وما يخفى منهما.",
    "t_verse_number": 7,
    "t_chapter_id": 87,
    "t_name_arabic": "الأعلى"
  },
  {
    "verse_id": 5956,
    "text_uthmani": "وَنُيَسِّرُكَ لِلْيُسْرَى",
    "tafseer": "[8] ونيسرك لليسرى في جميع أمورك، ومن ذلك تسهيل تَلَقِّي أعباء الرسالة، وجعل دينك يسراً لا عسر فيه.",
    "t_verse_number": 8,
    "t_chapter_id": 87,
    "t_name_arabic": "الأعلى"
  },
  {
    "verse_id": 5957,
    "text_uthmani": "فَذَكِّرْ إِن نَّفَعَتِ الذِّكْرَى",
    "tafseer": "[9] فعِظ قومك -أيها الرسول- حسبما يسَّرناه لك بما يوحى إليك، واهدهم إلى ما فيه خيرهم. وخُصَّ بالتذكير مَنْ يُرْجى منه التذكُّر، ولا تُتْعِب نفسك في تذكير مَن لا يورثه التذكير إلا عتوّاً ونفوراً.",
    "t_verse_number": 9,
    "t_chapter_id": 87,
    "t_name_arabic": "الأعلى"
  },
  {
    "verse_id": 5958,
    "text_uthmani": "سَيَذَّكَّرُ مَن يَخْشَى",
    "tafseer": "[10]  سيتعظ الذي يخاف ربه.",
    "t_verse_number": 10,
    "t_chapter_id": 87,
    "t_name_arabic": "الأعلى"
  },
  {
    "verse_id": 5959,
    "text_uthmani": "وَيَتَجَنَّبُهَا الْأَشْقَى",
    "tafseer": "[11] ويبتعد عن الذكرى الأشقى الذي لا يخشى ربه",
    "t_verse_number": 11,
    "t_chapter_id": 87,
    "t_name_arabic": "الأعلى"
  },
  {
    "verse_id": 5960,
    "text_uthmani": "الَّذِي يَصْلَى النَّارَ الْكُبْرَى",
    "tafseer": "[12] الذي سيدخل نار جهنم العظمى يقاسي حرَّها",
    "t_verse_number": 12,
    "t_chapter_id": 87,
    "t_name_arabic": "الأعلى"
  },
  {
    "verse_id": 5961,
    "text_uthmani": "ثُمَّ لَا يَمُوتُ فِيهَا وَلَا يَحْيَى",
    "tafseer": "[13] ثم لا يموت فيها فيستريح، ولا يحيا حياة تنفعه",
    "t_verse_number": 13,
    "t_chapter_id": 87,
    "t_name_arabic": "الأعلى"
  },
  {
    "verse_id": 5962,
    "text_uthmani": "قَدْ أَفْلَحَ مَن تَزَكَّى",
    "tafseer": "[14]  قد فاز مَن طهَّر نفسه مِن الأخلاق السيئة",
    "t_verse_number": 14,
    "t_chapter_id": 87,
    "t_name_arabic": "الأعلى"
  },
  {
    "verse_id": 5963,
    "text_uthmani": "وَذَكَرَ اسْمَ رَبِّهِ فَصَلَّى",
    "tafseer": "[15] وذكر الله، فوحَّده ودعاه وعمل بما يرضيه، وأقام الصلاة في أوقاتها؛ ابتغاء رضوان الله وامتثالاً لشرعه.",
    "t_verse_number": 15,
    "t_chapter_id": 87,
    "t_name_arabic": "الأعلى"
  },
  {
    "verse_id": 5964,
    "text_uthmani": "بَلْ تُؤْثِرُونَ الْحَيَاةَ الدُّنْيَا",
    "tafseer": "[16] إنكم -أيها الناس- تفضِّلون زينة الحياة الدنيا على نعيم الآخرة.",
    "t_verse_number": 16,
    "t_chapter_id": 87,
    "t_name_arabic": "الأعلى"
  },
  {
    "verse_id": 5965,
    "text_uthmani": "وَالْآخِرَةُ خَيْرٌ وَأَبْقَى",
    "tafseer": "[17] والدار الآخرة وما فيها من النعيم المقيم، خير من الدنيا وأبقى.",
    "t_verse_number": 17,
    "t_chapter_id": 87,
    "t_name_arabic": "الأعلى"
  },
  {
    "verse_id": 5966,
    "text_uthmani": "إِنَّ هَذَا لَفِي الصُّحُفِ الْأُولَى",
    "tafseer": "[18] إنَّ ما أُخبِرتم به في هذه السورة هو مما ثبت معناه في الصحف التي أُنزلت قبل القرآن",
    "t_verse_number": 18,
    "t_chapter_id": 87,
    "t_name_arabic": "الأعلى"
  },
  {
    "verse_id": 5967,
    "text_uthmani": "صُحُفِ إِبْرَاهِيمَ وَمُوسَى",
    "tafseer": "[19] وهي صحف إبراهيم وموسى عليهما السلام.",
    "t_verse_number": 19,
    "t_chapter_id": 87,
    "t_name_arabic": "الأعلى"
  }
]