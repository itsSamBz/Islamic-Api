[
  {
    "verse_id": 5713,
    "text_uthmani": "وَالنَّازِعَاتِ غَرْقًا",
    "tafseer": "[1] أقسم الله تعالى بالملائكة التي تنزع أرواح الكفار نزعاً شديداً",
    "t_verse_number": 1,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5714,
    "text_uthmani": "وَالنَّاشِطَاتِ نَشْطًا",
    "tafseer": "[2] والملائكة التي تقبض أرواح المؤمنين بنشاط ورفق",
    "t_verse_number": 2,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5715,
    "text_uthmani": "وَالسَّابِحَاتِ سَبْحًا",
    "tafseer": "[3] والملائكة التي تَسْبَح في نزولها من السماء وصعودها إليها",
    "t_verse_number": 3,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5716,
    "text_uthmani": "فَالسَّابِقَاتِ سَبْقًا",
    "tafseer": "[4] فالملائكة التي تسبق وتسارع إلى تنفيذ أمر الله",
    "t_verse_number": 4,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5717,
    "text_uthmani": "فَالْمُدَبِّرَاتِ أَمْرًا",
    "tafseer": "[5] فالملائكة المنفذات أمر ربها فيما أوكل إليها تدبيره مِن شؤون الكون، -ولا يجوز للمخلوق أن يقسم بغير خالقه، فإن فعل فقد أشرك- لتُبعثَنَّ الخلائق وتُحَاسَب",
    "t_verse_number": 5,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5718,
    "text_uthmani": "يَوْمَ تَرْجُفُ الرَّاجِفَةُ",
    "tafseer": "[6] يوم تضطرب الأرض بالنفخة الأولى نفخة الإماتة",
    "t_verse_number": 6,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5719,
    "text_uthmani": "تَتْبَعُهَا الرَّادِفَةُ",
    "tafseer": "[7] تتبعها نفخة أخرى للإحياء.",
    "t_verse_number": 7,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5720,
    "text_uthmani": "قُلُوبٌ يَوْمَئِذٍ وَاجِفَةٌ",
    "tafseer": "[8] قلوب الكفار يومئذ مضطربة من شدة الخوف",
    "t_verse_number": 8,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5721,
    "text_uthmani": "أَبْصَارُهَا خَاشِعَةٌ",
    "tafseer": "[9] أبصار أصحابها ذليلة من هول ما ترى.",
    "t_verse_number": 9,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5722,
    "text_uthmani": "يَقُولُونَ أَئِنَّا لَمَرْدُودُونَ فِي الْحَافِرَةِ",
    "tafseer": "[10] يقول هؤلاء المكذبون بالبعث: أنُرَدُّ بعد موتنا إلى ما كنا عليه أحياء في الأرض؟  ",
    "t_verse_number": 10,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5723,
    "text_uthmani": "أَئِذَا كُنَّا عِظَامًا نَّخِرَةً",
    "tafseer": "[11] أنردُّ وقد صرنا عظاماً بالية؟",
    "t_verse_number": 11,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5724,
    "text_uthmani": "قَالُوا تِلْكَ إِذًا كَرَّةٌ خَاسِرَةٌ",
    "tafseer": "[12] قالوا: رجعتنا تلك ستكون إذاً خائبة كاذبة.",
    "t_verse_number": 12,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5725,
    "text_uthmani": "فَإِنَّمَا هِيَ زَجْرَةٌ وَاحِدَةٌ",
    "tafseer": "[13] فإنما هي نفخة واحدة ",
    "t_verse_number": 13,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5726,
    "text_uthmani": "فَإِذَا هُم بِالسَّاهِرَةِ",
    "tafseer": "[14] فإذا هم أحياء على وجه الأرض بعد أن كانوا في بطنها.",
    "t_verse_number": 14,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5727,
    "text_uthmani": "هَلْ أتَاكَ حَدِيثُ مُوسَى",
    "tafseer": "[15] هل أتاك -أيها الرسول- خبر موسى؟",
    "t_verse_number": 15,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5728,
    "text_uthmani": "إِذْ نَادَاهُ رَبُّهُ بِالْوَادِ الْمُقَدَّسِ طُوًى",
    "tafseer": "[16] حين ناداه ربه بالوادي المطهَّر المبارك «طوى».",
    "t_verse_number": 16,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5729,
    "text_uthmani": "اذْهَبْ إِلَى فِرْعَوْنَ إِنَّهُ طَغَى",
    "tafseer": "[17] فقال له: اذهب إلى فرعون، إنه قد أفرط في العصيان",
    "t_verse_number": 17,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5730,
    "text_uthmani": "فَقُلْ هَل لَّكَ إِلَى أَن تَزَكَّى",
    "tafseer": "[18] فقل له: أتودُّ أن تطهِّر نفسك من النقائص وتحليها بالإيمان",
    "t_verse_number": 18,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5731,
    "text_uthmani": "وَأَهْدِيَكَ إِلَى رَبِّكَ فَتَخْشَى",
    "tafseer": "[19] وأُرشدك إلى طاعة ربك، فتخشاه وتتقيه؟",
    "t_verse_number": 19,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5732,
    "text_uthmani": "فَأَرَاهُ الْآيَةَ الْكُبْرَى",
    "tafseer": "[20] فأرى موسى فرعونَ العلامة العظمى: العصا واليد",
    "t_verse_number": 20,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5733,
    "text_uthmani": "فَكَذَّبَ وَعَصَى",
    "tafseer": "[21] فكذب فرعون نبيَّ الله موسى عليه السلام، وعصى ربه عزَّ وجلَّ",
    "t_verse_number": 21,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5734,
    "text_uthmani": "ثُمَّ أَدْبَرَ يَسْعَى",
    "tafseer": "[22] ثم ولَّى معرضاً عن الإيمان مجتهداً في معارضة موسى.",
    "t_verse_number": 22,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5735,
    "text_uthmani": "فَحَشَرَ فَنَادَى",
    "tafseer": "[23] فجمع أهل مملكته وناداهم",
    "t_verse_number": 23,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5736,
    "text_uthmani": "فَقَالَ أَنَا رَبُّكُمُ الْأَعْلَى",
    "tafseer": "[24] فقال: أنا ربكم الذي لا ربَّ فوقه",
    "t_verse_number": 24,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5737,
    "text_uthmani": "فَأَخَذَهُ اللَّهُ نَكَالَ الْآخِرَةِ وَالْأُولَى",
    "tafseer": "[25] فانتقم الله منه بالعذاب في الدنيا والآخرة، وجعله عبرة ونكالاً لأمثاله من المتمردين",
    "t_verse_number": 25,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5738,
    "text_uthmani": "إِنَّ فِي ذَلِكَ لَعِبْرَةً لِّمَن يَخْشَى",
    "tafseer": "[26] إن في فرعون وما نزل به من العذاب لموعظةً لمن يتعظ وينزجر.",
    "t_verse_number": 26,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5739,
    "text_uthmani": "أَأَنتُمْ أَشَدُّ خَلْقًا أَمِ السَّمَاء بَنَاهَا",
    "tafseer": "[27] أبَعْثُكم -أيها الناس- بعد الموت أشد في تقديركم أم خلق السماء؟",
    "t_verse_number": 27,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5740,
    "text_uthmani": "رَفَعَ سَمْكَهَا فَسَوَّاهَا",
    "tafseer": "[28] رفعها فوقكم كالبناء، وأعلى سقفها في الهواء لا تفاوت فيها ولا فطور",
    "t_verse_number": 28,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5741,
    "text_uthmani": "وَأَغْطَشَ لَيْلَهَا وَأَخْرَجَ ضُحَاهَا",
    "tafseer": "[29] وأظلم ليلها بغروب شمسها، وأبرز نهارها بشروقها",
    "t_verse_number": 29,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5742,
    "text_uthmani": "وَالْأَرْضَ بَعْدَ ذَلِكَ دَحَاهَا",
    "tafseer": "[30] والأرض بعد خلق السماء بسطها، وأودع فيها منافعها",
    "t_verse_number": 30,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5743,
    "text_uthmani": "أَخْرَجَ مِنْهَا مَاءهَا وَمَرْعَاهَا",
    "tafseer": "[31] وفجَّر فيها عيون الماء، وأنبت فيها ما يُرعى من النباتات",
    "t_verse_number": 31,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5744,
    "text_uthmani": "وَالْجِبَالَ أَرْسَاهَا",
    "tafseer": "[32] وأثبت فيها الجبال أوتاداً لها",
    "t_verse_number": 32,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5745,
    "text_uthmani": "مَتَاعًا لَّكُمْ وَلِأَنْعَامِكُمْ",
    "tafseer": "[33] خلق سبحانه كل هذه النعم منفعة لكم ولأنعامكم. إن إعادة خلقكم يوم القيامة أهون على الله مِن خلق هذه الأشياء، وكله على الله هين يسير.",
    "t_verse_number": 33,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5746,
    "text_uthmani": "فَإِذَا جَاءتِ الطَّامَّةُ الْكُبْرَى",
    "tafseer": "[34] فإذا جاءت القيامة الكبرى والشدة العظمى وهي النفخة الثانية",
    "t_verse_number": 34,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5747,
    "text_uthmani": "يَوْمَ يَتَذَكَّرُ الْإِنسَانُ مَا سَعَى",
    "tafseer": "[35] عندئذ يُعْرض على الإنسان كل عمله من خير وشر، فيتذكره",
    "t_verse_number": 35,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5748,
    "text_uthmani": "وَبُرِّزَتِ الْجَحِيمُ لِمَن يَرَى",
    "tafseer": "[36] وأُظهرت جهنم لكل مُبْصر تُرى عِياناً.",
    "t_verse_number": 36,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5749,
    "text_uthmani": "فَأَمَّا مَن طَغَى",
    "tafseer": "[37] فأمَّا من تمرَّد على أمر الله",
    "t_verse_number": 37,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5750,
    "text_uthmani": "وَآثَرَ الْحَيَاةَ الدُّنْيَا",
    "tafseer": "[38] وفضَّل الحياة الدنيا على الآخرة",
    "t_verse_number": 38,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5751,
    "text_uthmani": "فَإِنَّ الْجَحِيمَ هِيَ الْمَأْوَى",
    "tafseer": "[39] فإن مصيره إلى النار.",
    "t_verse_number": 39,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5752,
    "text_uthmani": "وَأَمَّا مَنْ خَافَ مَقَامَ رَبِّهِ وَنَهَى النَّفْسَ عَنِ الْهَوَى",
    "tafseer": "[40] وأمَّا مَن خاف القيام بين يدي الله للحساب، ونهى النفس عن الأهواء الفاسدة",
    "t_verse_number": 40,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5753,
    "text_uthmani": "فَإِنَّ الْجَنَّةَ هِيَ الْمَأْوَى",
    "tafseer": "[41]  فإن الجنة هي مسكنه.",
    "t_verse_number": 41,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5754,
    "text_uthmani": "يَسْأَلُونَكَ عَنِ السَّاعَةِ أَيَّانَ مُرْسَاهَا",
    "tafseer": "[42] يسألك المشركون - أيها الرسول -استخفافاً- عن وقت حلول الساعة التي تتوعدهم بها",
    "t_verse_number": 42,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5755,
    "text_uthmani": "فِيمَ أَنتَ مِن ذِكْرَاهَا",
    "tafseer": "[43] لستَ في شيء مِن علمها",
    "t_verse_number": 43,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5756,
    "text_uthmani": "إِلَى رَبِّكَ مُنتَهَاهَا",
    "tafseer": "[44] بل مردُّ ذلك إلى الله عزَّ وجلَّ",
    "t_verse_number": 44,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5757,
    "text_uthmani": "إِنَّمَا أَنتَ مُنذِرُ مَن يَخْشَاهَا",
    "tafseer": "[45]  وإنما شأنك في أمر الساعة أن تحذر منها مَن يخافها",
    "t_verse_number": 45,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  },
  {
    "verse_id": 5758,
    "text_uthmani": "كَأَنَّهُمْ يَوْمَ يَرَوْنَهَا لَمْ يَلْبَثُوا إِلَّا عَشِيَّةً أَوْ ضُحَاهَا",
    "tafseer": "[46]  كأنهم يوم يرون قيام الساعة لم يلبثوا في الحياة الدنيا؛ لهول الساعة إلا ما بين الظهر إلى غروب الشمس، أو ما بين طلوع الشمس إلى نصف النهار.",
    "t_verse_number": 46,
    "t_chapter_id": 79,
    "t_name_arabic": "النازعات"
  }
]