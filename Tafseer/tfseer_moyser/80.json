[
  {
    "verse_id": 5759,
    "text_uthmani": "عَبَسَ وَتَوَلَّى",
    "tafseer": "[1] ظهر التغير والعبوس في وجه الرسول صلى الله عليه وسلم",
    "t_verse_number": 1,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5760,
    "text_uthmani": "أَن جَاءهُ الْأَعْمَى",
    "tafseer": "[2] وأعرض لأجل أن الأعمى عبدالله بن أم مكتوم جاءه مسترشداً، وكان الرسول -صلى الله عليه وسلم- منشغلاً بدعوة كبار قريش إلى الإسلام.",
    "t_verse_number": 2,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5761,
    "text_uthmani": "وَمَا يُدْرِيكَ لَعَلَّهُ يَزَّكَّى",
    "tafseer": "[3] وأيُّ شيء يجعلك عالماً بحقيقة أمره؟ لعله بسؤاله تزكو نفسه وتطهر",
    "t_verse_number": 3,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5762,
    "text_uthmani": "أَوْ يَذَّكَّرُ فَتَنفَعَهُ الذِّكْرَى",
    "tafseer": "[4]أو يحصل له المزيد من الاعتبار والازدجار.",
    "t_verse_number": 4,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5763,
    "text_uthmani": "أَمَّا مَنِ اسْتَغْنَى",
    "tafseer": "[5] أما مَن استغنى عن هديك",
    "t_verse_number": 5,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5764,
    "text_uthmani": "فَأَنتَ لَهُ تَصَدَّى",
    "tafseer": "[6] فأنت تتعرض له وتصغي إلى كلامه",
    "t_verse_number": 6,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5765,
    "text_uthmani": "وَمَا عَلَيْكَ أَلَّا يَزَّكَّى",
    "tafseer": "[7] وأيُّ شيء عليك ألا يتطهر من كفره؟",
    "t_verse_number": 7,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5766,
    "text_uthmani": "وَأَمَّا مَن جَاءكَ يَسْعَى",
    "tafseer": "[8] وأمَّا من كان حريصاً على لقائك",
    "t_verse_number": 8,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5767,
    "text_uthmani": "وَهُوَ يَخْشَى",
    "tafseer": "[9] وهو يخشى الله من التقصير في الاسترشاد",
    "t_verse_number": 9,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5768,
    "text_uthmani": "فَأَنتَ عَنْهُ تَلَهَّى",
    "tafseer": "[10] فأنت عنه تتشاغل",
    "t_verse_number": 10,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5769,
    "text_uthmani": "كَلَّا إِنَّهَا تَذْكِرَةٌ",
    "tafseer": "[11] . ليس الأمر كما فعلت -أيها الرسول-، إنَّ هذه السورة بما اشتملت عليه من الهداية موعظة لك ولكل من شاء الاتعاظ",
    "t_verse_number": 11,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5770,
    "text_uthmani": "فَمَن شَاء ذَكَرَهُ",
    "tafseer": "[12] فمن شاء ذكر الله وَأْتَمَّ بوحيه",
    "t_verse_number": 12,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5771,
    "text_uthmani": "فِي صُحُفٍ مُّكَرَّمَةٍ",
    "tafseer": "[13] هذا الوحي، وهو القرآن في صحف معظمة، موقرة",
    "t_verse_number": 13,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5772,
    "text_uthmani": "مَّرْفُوعَةٍ مُّطَهَّرَةٍ",
    "tafseer": "[14] عالية القدر مطهرة من الدنس والزيادة والنقص",
    "t_verse_number": 14,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5773,
    "text_uthmani": "بِأَيْدِي سَفَرَةٍ",
    "tafseer": "[15]  بأيدي ملائكة كتبة، سفراء بين الله وخلقه",
    "t_verse_number": 15,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5774,
    "text_uthmani": "كِرَامٍ بَرَرَةٍ",
    "tafseer": "[16] كرام الخلق، أخلاقهم وأفعالهم بارة طاهرة.",
    "t_verse_number": 16,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5775,
    "text_uthmani": "قُتِلَ الْإِنسَانُ مَا أَكْفَرَهُ",
    "tafseer": "[17] لُعِنَ الإنسان الكافر وعُذِّب، ما أشدَّ كفره بربه!",
    "t_verse_number": 17,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5776,
    "text_uthmani": "مِنْ أَيِّ شَيْءٍ خَلَقَهُ",
    "tafseer": "[18]  ألم ير مِن أيِّ شيء خلقه الله أول مرة؟",
    "t_verse_number": 18,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5777,
    "text_uthmani": "مِن نُّطْفَةٍ خَلَقَهُ فَقَدَّرَهُ",
    "tafseer": "[19] خلقه الله من ماء قليل -وهو المنيُّ- فقدَّره أطواراً",
    "t_verse_number": 19,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5778,
    "text_uthmani": "ثُمَّ السَّبِيلَ يَسَّرَهُ",
    "tafseer": "[20] ثم بيَّن له طريق الخير والشر",
    "t_verse_number": 20,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5779,
    "text_uthmani": "ثُمَّ أَمَاتَهُ فَأَقْبَرَهُ",
    "tafseer": "[21] ثم أماته فجعل له مكاناً يُقبر فيه",
    "t_verse_number": 21,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5780,
    "text_uthmani": "ثُمَّ إِذَا شَاء أَنشَرَهُ",
    "tafseer": "[22] ثم إذا شاء سبحانه أحياه، وبعثه بعد موته للحساب والجزاء",
    "t_verse_number": 22,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5781,
    "text_uthmani": "كَلَّا لَمَّا يَقْضِ مَا أَمَرَهُ",
    "tafseer": "[23]  ليس الأمر كما يقول الكافر ويفعل، فلم يؤدِّ ما أمره الله به من الإيمان والعمل بطاعته.",
    "t_verse_number": 23,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5782,
    "text_uthmani": "فَلْيَنظُرِ الْإِنسَانُ إِلَى طَعَامِهِ",
    "tafseer": "[24] فليتدبر الإنسان: كيف خلق الله طعامه الذي هو قِوام حياته؟",
    "t_verse_number": 24,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5783,
    "text_uthmani": "أَنَّا صَبَبْنَا الْمَاء صَبًّا",
    "tafseer": "[25] بأنَّا صببنا الماء على الأرض صبّاً",
    "t_verse_number": 25,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5784,
    "text_uthmani": "ثُمَّ شَقَقْنَا الْأَرْضَ شَقًّا",
    "tafseer": "[26] ثم شققناها بما أخرجنا منها من نبات شتى  ",
    "t_verse_number": 26,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5785,
    "text_uthmani": "فَأَنبَتْنَا فِيهَا حَبًّا",
    "tafseer": "[27]   فأنبتنا فيها حبّاً",
    "t_verse_number": 27,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5786,
    "text_uthmani": "وَعِنَبًا وَقَضْبًا",
    "tafseer": "[28] وعنباً وعلفاً للدواب",
    "t_verse_number": 28,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5787,
    "text_uthmani": "وَزَيْتُونًا وَنَخْلًا",
    "tafseer": "[29]  وزيتوناً ونخلاً،",
    "t_verse_number": 29,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5788,
    "text_uthmani": "وَحَدَائِقَ غُلْبًا",
    "tafseer": "[30] وحدائق عظيمة الأشجار",
    "t_verse_number": 30,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5789,
    "text_uthmani": "وَفَاكِهَةً وَأَبًّا",
    "tafseer": "[31] وثماراً وكـلأً",
    "t_verse_number": 31,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5790,
    "text_uthmani": "مَّتَاعًا لَّكُمْ وَلِأَنْعَامِكُمْ",
    "tafseer": "[32]  تَنْعَمون بها أنتم وأنعامكم.",
    "t_verse_number": 32,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5791,
    "text_uthmani": "فَإِذَا جَاءتِ الصَّاخَّةُ",
    "tafseer": "[33] فإذا جاءت صيحة البعث يوم القيامة التي تَصَمُّ مِن هولها الأسماع",
    "t_verse_number": 33,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5792,
    "text_uthmani": "يَوْمَ يَفِرُّ الْمَرْءُ مِنْ أَخِيهِ",
    "tafseer": "[34] يوم يفرُّ المرء لهول ذلك اليوم من أخيه",
    "t_verse_number": 34,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5793,
    "text_uthmani": "وَأُمِّهِ وَأَبِيهِ",
    "tafseer": "[35] وأمه وأبيه",
    "t_verse_number": 35,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5794,
    "text_uthmani": "وَصَاحِبَتِهِ وَبَنِيهِ",
    "tafseer": "[36]  وزوجه وبنيه",
    "t_verse_number": 36,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5795,
    "text_uthmani": "لِكُلِّ امْرِئٍ مِّنْهُمْ يَوْمَئِذٍ شَأْنٌ يُغْنِيهِ",
    "tafseer": "[37] لكل واحد منهم يومئذٍ أمر يمنعه من الانشغال بغيره.",
    "t_verse_number": 37,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5796,
    "text_uthmani": "وُجُوهٌ يَوْمَئِذٍ مُّسْفِرَةٌ",
    "tafseer": "[38] وجوه أهل النعيم في ذلك اليوم مستنيرة",
    "t_verse_number": 38,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5797,
    "text_uthmani": "ضَاحِكَةٌ مُّسْتَبْشِرَةٌ",
    "tafseer": "[39]  مسرورة فرحة",
    "t_verse_number": 39,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5798,
    "text_uthmani": "وَوُجُوهٌ يَوْمَئِذٍ عَلَيْهَا غَبَرَةٌ",
    "tafseer": "[40] ووجوه أهل الجحيم مظلمة مسودَّة.",
    "t_verse_number": 40,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5799,
    "text_uthmani": "تَرْهَقُهَا قَتَرَةٌ",
    "tafseer": "[41] تغشاها ذلَّة",
    "t_verse_number": 41,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5800,
    "text_uthmani": "أُوْلَئِكَ هُمُ الْكَفَرَةُ الْفَجَرَةُ",
    "tafseer": "[42] أولئك الموصوفون بهذا الوصف هم الذين كفروا بنعم الله وكذَّبوا بآياته، وتجرؤوا على محارمه بالفجور والطغيان.",
    "t_verse_number": 42,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  }
]