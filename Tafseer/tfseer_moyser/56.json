[
  {
    "verse_id": 4980,
    "text_uthmani": "إِذَا وَقَعَتِ الْوَاقِعَةُ",
    "tafseer": "[1] إذا قامت القيامة،",
    "t_verse_number": 1,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 4981,
    "text_uthmani": "لَيْسَ لِوَقْعَتِهَا كَاذِبَةٌ",
    "tafseer": "[2]  ليس لقيامها أحد يكذِّب به،",
    "t_verse_number": 2,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 4982,
    "text_uthmani": "خَافِضَةٌ رَّافِعَةٌ",
    "tafseer": "[3]  هي خافضة لأعداء الله في النار، رافعة لأوليائه في الجنة.",
    "t_verse_number": 3,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 4983,
    "text_uthmani": "إِذَا رُجَّتِ الْأَرْضُ رَجًّا",
    "tafseer": "[4] إذا حُرِّكت الأرض تحريكاً شديداً،",
    "t_verse_number": 4,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 4984,
    "text_uthmani": "وَبُسَّتِ الْجِبَالُ بَسًّا",
    "tafseer": "[5] وفُتِّتت الجبال تفتيتاً دقيقاً،",
    "t_verse_number": 5,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 4985,
    "text_uthmani": "فَكَانَتْ هَبَاء مُّنبَثًّا",
    "tafseer": "[6]  فصارت غباراً متطايراً في الجو قد ذَرَتْه الريح.",
    "t_verse_number": 6,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 4986,
    "text_uthmani": "وَكُنتُمْ أَزْوَاجًا ثَلَاثَةً",
    "tafseer": "[7] وكنتم -أيها الخلق- أصنافاً ثلاثة:",
    "t_verse_number": 7,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 4987,
    "text_uthmani": "فَأَصْحَابُ الْمَيْمَنَةِ مَا أَصْحَابُ الْمَيْمَنَةِ",
    "tafseer": "[8] فأصحاب اليمين أهل المنزلة العالية، ما أعظم مكانتهم!",
    "t_verse_number": 8,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 4988,
    "text_uthmani": "وَأَصْحَابُ الْمَشْأَمَةِ مَا أَصْحَابُ الْمَشْأَمَةِ",
    "tafseer": "[9]  وأصحاب الشمال أهل المنزلة الدنيئة، ما أسوأ حالهم!",
    "t_verse_number": 9,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 4989,
    "text_uthmani": "وَالسَّابِقُونَ السَّابِقُونَ",
    "tafseer": "[10] والسابقون إلى الخيرات في الدنيا هم السابقون إلى الدرجات في الآخرة، ",
    "t_verse_number": 10,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 4990,
    "text_uthmani": "أُوْلَئِكَ الْمُقَرَّبُونَ",
    "tafseer": "[11]  أولئك هم المقربون عند الله،",
    "t_verse_number": 11,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 4991,
    "text_uthmani": "فِي جَنَّاتِ النَّعِيمِ",
    "tafseer": "[12]  يُدْخلهم ربهم في جنات النعيم.",
    "t_verse_number": 12,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 4992,
    "text_uthmani": "ثُلَّةٌ مِّنَ الْأَوَّلِينَ",
    "tafseer": "[13] يدخلها جماعة كثيرة من صدر هذه الأمة، وغيرهم من الأمم الأخرى،",
    "t_verse_number": 13,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 4993,
    "text_uthmani": "وَقَلِيلٌ مِّنَ الْآخِرِينَ",
    "tafseer": "[14]  وقليل من آخر هذه الأمة",
    "t_verse_number": 14,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 4994,
    "text_uthmani": "عَلَى سُرُرٍ مَّوْضُونَةٍ",
    "tafseer": "[15] على سرر منسوجة بالذهب،",
    "t_verse_number": 15,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 4995,
    "text_uthmani": "مُتَّكِئِينَ عَلَيْهَا مُتَقَابِلِينَ",
    "tafseer": "[16]  متكئين عليها يقابل بعضهم بعضاً.",
    "t_verse_number": 16,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 4996,
    "text_uthmani": "يَطُوفُ عَلَيْهِمْ وِلْدَانٌ مُّخَلَّدُونَ",
    "tafseer": "[17] يطوف عليهم لخدمتهم غلمان لا يهرمون ولا يموتون،",
    "t_verse_number": 17,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 4997,
    "text_uthmani": "بِأَكْوَابٍ وَأَبَارِيقَ وَكَأْسٍ مِّن مَّعِينٍ",
    "tafseer": "[18]  بأقداح وأباريق وكأس من عين خمر جارية في الجنة،",
    "t_verse_number": 18,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 4998,
    "text_uthmani": "لَا يُصَدَّعُونَ عَنْهَا وَلَا يُنزِفُونَ",
    "tafseer": "[19]  لا تُصَدَّعُ منها رؤوسهم، ولا تذهب بعقولهم.",
    "t_verse_number": 19,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 4999,
    "text_uthmani": "وَفَاكِهَةٍ مِّمَّا يَتَخَيَّرُونَ",
    "tafseer": "[20] ويطوف عليهم الغلمان بما يتخيرون من الفواكه،",
    "t_verse_number": 20,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5000,
    "text_uthmani": "وَلَحْمِ طَيْرٍ مِّمَّا يَشْتَهُونَ",
    "tafseer": "[21] وبلحم طير ممَّا ترغب فيه نفوسهم.",
    "t_verse_number": 21,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5001,
    "text_uthmani": "وَحُورٌ عِينٌ",
    "tafseer": "[22]  ولهم نساء ذوات عيون واسعة،",
    "t_verse_number": 22,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5002,
    "text_uthmani": "كَأَمْثَالِ اللُّؤْلُؤِ الْمَكْنُونِ",
    "tafseer": "[23]  كأمثال اللؤلؤ المصون في أصدافه صفاءً وجمالاً؛",
    "t_verse_number": 23,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5003,
    "text_uthmani": "جَزَاء بِمَا كَانُوا يَعْمَلُونَ",
    "tafseer": "[24] جزاء لهم بما كانوا يعملون من الصالحات في الدنيا.",
    "t_verse_number": 24,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5004,
    "text_uthmani": "لَا يَسْمَعُونَ فِيهَا لَغْوًا وَلَا تَأْثِيمًا",
    "tafseer": "[25] لا يسمعون في الجنة باطلاً، ولا ما يتأثمون بسماعه، ",
    "t_verse_number": 25,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5005,
    "text_uthmani": "إِلَّا قِيلًا سَلَامًا سَلَامًا",
    "tafseer": "[26] إلا قولاً سالماً من هذه العيوب، وتسليمَ بعضهم على بعض.",
    "t_verse_number": 26,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5006,
    "text_uthmani": "وَأَصْحَابُ الْيَمِينِ مَا أَصْحَابُ الْيَمِينِ",
    "tafseer": "[27] وأصحاب اليمين، ما أعظم مكانتهم وجزاءهم! ",
    "t_verse_number": 27,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5007,
    "text_uthmani": "فِي سِدْرٍ مَّخْضُودٍ",
    "tafseer": "[28] هم في سِدْر لا شوك فيه،",
    "t_verse_number": 28,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5008,
    "text_uthmani": "وَطَلْحٍ مَّنضُودٍ",
    "tafseer": "[29]  وموز متراكب بعضه على بعض،",
    "t_verse_number": 29,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5009,
    "text_uthmani": "وَظِلٍّ مَّمْدُودٍ",
    "tafseer": "[30] وظلٍّ دائم لا يزول،",
    "t_verse_number": 30,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5010,
    "text_uthmani": "وَمَاء مَّسْكُوبٍ",
    "tafseer": "[31] وماء جار لا ينقطع،",
    "t_verse_number": 31,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5011,
    "text_uthmani": "وَفَاكِهَةٍ كَثِيرَةٍ",
    "tafseer": "[32] ، وفاكهة كثيرة لا تنفَد ",
    "t_verse_number": 32,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5012,
    "text_uthmani": "لَّا مَقْطُوعَةٍ وَلَا مَمْنُوعَةٍ",
    "tafseer": "[33]  ولا تنقطع عنهم، ولا يمنعهم منها مانع،",
    "t_verse_number": 33,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5013,
    "text_uthmani": "وَفُرُشٍ مَّرْفُوعَةٍ",
    "tafseer": "[34]  وفرشٍ مرفوعة على السرر.",
    "t_verse_number": 34,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5014,
    "text_uthmani": "إِنَّا أَنشَأْنَاهُنَّ إِنشَاء",
    "tafseer": "[35] إنا أنشأنا نساء أهل الجنة نشأة غير النشأة التي كانت في الدنيا، نشأة كاملة لا تقبل الفناء،",
    "t_verse_number": 35,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5015,
    "text_uthmani": "فَجَعَلْنَاهُنَّ أَبْكَارًا",
    "tafseer": "[36]  فجعلناهن أبكاراً،",
    "t_verse_number": 36,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5016,
    "text_uthmani": "عُرُبًا أَتْرَابًا",
    "tafseer": "[37]  متحببات إلى أزواجهن، في سنٍّ واحدة،",
    "t_verse_number": 37,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5017,
    "text_uthmani": "لِّأَصْحَابِ الْيَمِينِ",
    "tafseer": "[38]  خلقناهن لأصحاب اليمين.",
    "t_verse_number": 38,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5018,
    "text_uthmani": "ثُلَّةٌ مِّنَ الْأَوَّلِينَ",
    "tafseer": "[39] وهم جماعة كثيرة من الأولين،",
    "t_verse_number": 39,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5019,
    "text_uthmani": "وَثُلَّةٌ مِّنَ الْآخِرِينَ",
    "tafseer": "[40] وجماعة كثيرة من الآخرين.",
    "t_verse_number": 40,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5020,
    "text_uthmani": "وَأَصْحَابُ الشِّمَالِ مَا أَصْحَابُ الشِّمَالِ",
    "tafseer": "[41] وأصحاب الشمال ما أسوأ حالهم وجزاءهم! ",
    "t_verse_number": 41,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5021,
    "text_uthmani": "فِي سَمُومٍ وَحَمِيمٍ",
    "tafseer": "[42]  في ريح حارة من حَرِّ نار جهنم تأخذ بأنفاسهم، وماء حار يغلي،",
    "t_verse_number": 42,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5022,
    "text_uthmani": "وَظِلٍّ مِّن يَحْمُومٍ",
    "tafseer": "[43]  وظلٍّ من دخان شديد السواد،",
    "t_verse_number": 43,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5023,
    "text_uthmani": "لَّا بَارِدٍ وَلَا كَرِيمٍ",
    "tafseer": "[44]  لا بارد المنزل، ولا كريم المنظر.",
    "t_verse_number": 44,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5024,
    "text_uthmani": "إِنَّهُمْ كَانُوا قَبْلَ ذَلِكَ مُتْرَفِينَ",
    "tafseer": "[45] إنهم كانوا في الدنيا متنعِّمين بالحرام، معرِضين عما جاءتهم به الرسل.",
    "t_verse_number": 45,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5025,
    "text_uthmani": "وَكَانُوا يُصِرُّونَ عَلَى الْحِنثِ الْعَظِيمِ",
    "tafseer": "[46] وكانوا يقيمون على الكفر بالله والإشراك به ومعصيته، ولا ينوون التوبة من ذلك.",
    "t_verse_number": 46,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5026,
    "text_uthmani": "وَكَانُوا يَقُولُونَ أَئِذَا مِتْنَا وَكُنَّا تُرَابًا وَعِظَامًا أَئِنَّا لَمَبْعُوثُونَ",
    "tafseer": "[47] وكانوا يقولون إنكاراً للبعث: أنُبعث إذا متنا وصرنا تراباً وعظاماً بالية؟ وهذا استبعاد منهم لأمر البعث وتكذيب له.",
    "t_verse_number": 47,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5027,
    "text_uthmani": "أَوَ آبَاؤُنَا الْأَوَّلُونَ",
    "tafseer": "[48] أنُبعث نحن وآباؤنا الأقدمون الذين صاروا تراباً، قد تفرَّق في الأرض؟",
    "t_verse_number": 48,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5028,
    "text_uthmani": "قُلْ إِنَّ الْأَوَّلِينَ وَالْآخِرِينَ",
    "tafseer": "[49] قل لهم -أيها الرسول-: إن الأولين والآخرين من بني آدم",
    "t_verse_number": 49,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5029,
    "text_uthmani": "لَمَجْمُوعُونَ إِلَى مِيقَاتِ يَوْمٍ مَّعْلُومٍ",
    "tafseer": "[50]  سيُجمَعون في يوم مؤقت بوقت محدد، وهو يوم القيامة.",
    "t_verse_number": 50,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5030,
    "text_uthmani": "ثُمَّ إِنَّكُمْ أَيُّهَا الضَّالُّونَ الْمُكَذِّبُونَ",
    "tafseer": "[51] ثم إنكم أيها الضالون عن طريق الهدى المكذبون بوعيد الله ووعده،",
    "t_verse_number": 51,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5031,
    "text_uthmani": "لَآكِلُونَ مِن شَجَرٍ مِّن زَقُّومٍ",
    "tafseer": "[52]  لآكلون من شجر من زقوم، وهو من أقبح الشجر،",
    "t_verse_number": 52,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5032,
    "text_uthmani": "فَمَالِؤُونَ مِنْهَا الْبُطُونَ",
    "tafseer": "[53]  فمالئون منها بطونكم؛ لشدة الجوع،",
    "t_verse_number": 53,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5033,
    "text_uthmani": "فَشَارِبُونَ عَلَيْهِ مِنَ الْحَمِيمِ",
    "tafseer": "[54]  فشاربون عليه ماء متناهياً في الحرارة لا يَرْوي ظمأ،",
    "t_verse_number": 54,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5034,
    "text_uthmani": "فَشَارِبُونَ شُرْبَ الْهِيمِ",
    "tafseer": "[55]  فشاربون منه بكثرة، كشرب الإبل العطاش التي لا تَرْوى لداء يصيبها.",
    "t_verse_number": 55,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5035,
    "text_uthmani": "هَذَا نُزُلُهُمْ يَوْمَ الدِّينِ",
    "tafseer": "[56] هذا الذي يلقونه من العذاب هو ما أُعدَّ لهم من الزاد يوم القيامة. وفي هذا توبيخ لهم وتهكُّم بهم.",
    "t_verse_number": 56,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5036,
    "text_uthmani": "نَحْنُ خَلَقْنَاكُمْ فَلَوْلَا تُصَدِّقُونَ",
    "tafseer": "[57] نحن خلقناكم -أيها الناس- ولم تكونوا شيئاً، فهلَّا تصدِّقون بالبعث.",
    "t_verse_number": 57,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5037,
    "text_uthmani": "أَفَرَأَيْتُم مَّا تُمْنُونَ",
    "tafseer": "[58] أفرأيتم النُّطَف التي تقذفونها في أرحام نسائكم،",
    "t_verse_number": 58,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5038,
    "text_uthmani": "أَأَنتُمْ تَخْلُقُونَهُ أَمْ نَحْنُ الْخَالِقُونَ",
    "tafseer": "[59] هل أنتم تخلقون ذلك بشراً أم نحن الخالقون؟",
    "t_verse_number": 59,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5039,
    "text_uthmani": "نَحْنُ قَدَّرْنَا بَيْنَكُمُ الْمَوْتَ وَمَا نَحْنُ بِمَسْبُوقِينَ",
    "tafseer": "[60] نحن قَدَّرنا بينكم الموت، وما نحن بعاجزين ",
    "t_verse_number": 60,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5040,
    "text_uthmani": "عَلَى أَن نُّبَدِّلَ أَمْثَالَكُمْ وَنُنشِئَكُمْ فِي مَا لَا تَعْلَمُونَ",
    "tafseer": "[61]  عن أن نغيِّر خلقكم يوم القيامة، وننشئكم فيما لا تعلمونه من الصفات والأحوال.",
    "t_verse_number": 61,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5041,
    "text_uthmani": "وَلَقَدْ عَلِمْتُمُ النَّشْأَةَ الْأُولَى فَلَوْلَا تَذكَّرُونَ",
    "tafseer": "[62] ولقد علمتم أن الله أنشأكم النشأة الأولى ولم تكونوا شيئاً، فهلَّا تذكَّرون قدرة الله على إنشائكم مرة أخرى.",
    "t_verse_number": 62,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5042,
    "text_uthmani": "أَفَرَأَيْتُم مَّا تَحْرُثُونَ",
    "tafseer": "[63] أفرأيتم الحرث الذي تحرثونه ",
    "t_verse_number": 63,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5043,
    "text_uthmani": "أَأَنتُمْ تَزْرَعُونَهُ أَمْ نَحْنُ الزَّارِعُونَ",
    "tafseer": "[64] هل أنتم تُنبتونه في الأرض أم نحن نُقِرُّ قراره وننبته في الأرض؟",
    "t_verse_number": 64,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5044,
    "text_uthmani": "لَوْ نَشَاء لَجَعَلْنَاهُ حُطَامًا فَظَلَلْتُمْ تَفَكَّهُونَ",
    "tafseer": "[65]  لو نشاء لجعلنا ذلك الزرع هشيماً، لا يُنتفع به في مطعم، فأصبحتم تتعجبون مما نزل بزرعكم،",
    "t_verse_number": 65,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5045,
    "text_uthmani": "إِنَّا لَمُغْرَمُونَ",
    "tafseer": "[66]  وتقولون: إنا لخاسرون معذَّبون،",
    "t_verse_number": 66,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5046,
    "text_uthmani": "بَلْ نَحْنُ مَحْرُومُونَ",
    "tafseer": "[67]  بل نحن محرومون من الرزق.",
    "t_verse_number": 67,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5047,
    "text_uthmani": "أَفَرَأَيْتُمُ الْمَاء الَّذِي تَشْرَبُونَ",
    "tafseer": "[68] أفرأيتم الماء الذي تشربونه لتحيَوْا به،",
    "t_verse_number": 68,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5048,
    "text_uthmani": "أَأَنتُمْ أَنزَلْتُمُوهُ مِنَ الْمُزْنِ أَمْ نَحْنُ الْمُنزِلُونَ",
    "tafseer": "[69]  أأنتم أنزلتموه من السحاب إلى قرار الأرض، أم نحن الذين أنزلناه رحمة بكم؟",
    "t_verse_number": 69,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5049,
    "text_uthmani": "لَوْ نَشَاء جَعَلْنَاهُ أُجَاجًا فَلَوْلَا تَشْكُرُونَ",
    "tafseer": "[70] لو نشاء جعلنا هذا الماء شديد الملوحة، لا يُنتفع به في شرب ولا زرع، فهلَّا تشكرون ربكم على إنزاله الماء العذب لنفعكم.",
    "t_verse_number": 70,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5050,
    "text_uthmani": "أَفَرَأَيْتُمُ النَّارَ الَّتِي تُورُونَ",
    "tafseer": "[71] أفرأيتم النار التي توقدون،",
    "t_verse_number": 71,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5051,
    "text_uthmani": "أَأَنتُمْ أَنشَأْتُمْ شَجَرَتَهَا أَمْ نَحْنُ الْمُنشِؤُونَ",
    "tafseer": "[72]  أأنتم أوجدتم شجرتها التي تُقْدح منها النار، أم نحن الموجدون لها؟",
    "t_verse_number": 72,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5052,
    "text_uthmani": "نَحْنُ جَعَلْنَاهَا تَذْكِرَةً وَمَتَاعًا لِّلْمُقْوِينَ",
    "tafseer": "[73] نحن جعلنا ناركم التي توقدون تذكيراً لكم بنار جهنم ومنفعة للمسافرين.",
    "t_verse_number": 73,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5053,
    "text_uthmani": "فَسَبِّحْ بِاسْمِ رَبِّكَ الْعَظِيمِ",
    "tafseer": "[74] فنزِّه -أيها النبي- ربك العظيم الكاملَ الأسماء والصفات، الكثيرَ الإحسان والخيرات.",
    "t_verse_number": 74,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5054,
    "text_uthmani": "فَلَا أُقْسِمُ بِمَوَاقِعِ النُّجُومِ",
    "tafseer": "[75] أقسم الله تعالى بمساقط النجوم في مغاربها في السماء،",
    "t_verse_number": 75,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5055,
    "text_uthmani": "وَإِنَّهُ لَقَسَمٌ لَّوْ تَعْلَمُونَ عَظِيمٌ",
    "tafseer": "[76]  وإنه لقَسَم لو تعلمون قَدْره عظيم.",
    "t_verse_number": 76,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5056,
    "text_uthmani": "إِنَّهُ لَقُرْآنٌ كَرِيمٌ",
    "tafseer": "[77] إن هذا القرآن الذي نزل على محمد -صلى الله عليه وسلم- لقرآن عظيم المنافع، كثير الخير، غزير العلم،",
    "t_verse_number": 77,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5057,
    "text_uthmani": "فِي كِتَابٍ مَّكْنُونٍ",
    "tafseer": "[78]  في كتاب مَصُون مستور عن أعين الخلق، وهو اللوح المحفوظ.",
    "t_verse_number": 78,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5058,
    "text_uthmani": "لَّا يَمَسُّهُ إِلَّا الْمُطَهَّرُونَ",
    "tafseer": "[79] . لا يَمَسُّ القرآن إلا الملائكة الكرام الذين طهرهم الله من الآفات والذنوب، ولا يَمَسُّه أيضاً إلا المتطهرون من الشرك والجنابة والحدث.",
    "t_verse_number": 79,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5059,
    "text_uthmani": "تَنزِيلٌ مِّن رَّبِّ الْعَالَمِينَ",
    "tafseer": "[80] وهذا القرآن الكريم منزل من رب العالمين، فهو الحق الذي لا مرية فيه.",
    "t_verse_number": 80,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5060,
    "text_uthmani": "أَفَبِهَذَا الْحَدِيثِ أَنتُم مُّدْهِنُونَ",
    "tafseer": "[81] أفبهذا القرآن أنتم -أيها المشركون- مكذِّبون؟",
    "t_verse_number": 81,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5061,
    "text_uthmani": "وَتَجْعَلُونَ رِزْقَكُمْ أَنَّكُمْ تُكَذِّبُونَ",
    "tafseer": "[82] وتجعلون شكركم لنعم الله عليكم أنكم تكذِّبون بها وتكفرون؟وفي هذا إنكار على من يتهاون بأمر القرآن ولا يبالي بدعوته.",
    "t_verse_number": 82,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5062,
    "text_uthmani": "فَلَوْلَا إِذَا بَلَغَتِ الْحُلْقُومَ",
    "tafseer": "[83] فهل تستطيعون إذا بلغت نفس أحدكم الحلقوم عند النَّزْع،",
    "t_verse_number": 83,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5063,
    "text_uthmani": "وَأَنتُمْ حِينَئِذٍ تَنظُرُونَ",
    "tafseer": "[84] وأنتم حضور تنظرون إليه، أن تمسكوا روحه في جسده؟ لن تستطيعوا ذلك،",
    "t_verse_number": 84,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5064,
    "text_uthmani": "وَنَحْنُ أَقْرَبُ إِلَيْهِ مِنكُمْ وَلَكِن لَّا تُبْصِرُونَ",
    "tafseer": "[85]  ونحن أقرب إليه منكم بملائكتنا، ولكنكم لا ترونهم.",
    "t_verse_number": 85,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5065,
    "text_uthmani": "فَلَوْلَا إِن كُنتُمْ غَيْرَ مَدِينِينَ",
    "tafseer": "[86] وهل تستطيعون إن كنتم غير محاسبين ولا مجزيين بأعمالكم",
    "t_verse_number": 86,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5066,
    "text_uthmani": "تَرْجِعُونَهَا إِن كُنتُمْ صَادِقِينَ",
    "tafseer": "[87]  أن تعيدوا الروح إلى الجسد، إن كنتم صادقين؟ لن تُرْجِعوها.",
    "t_verse_number": 87,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5067,
    "text_uthmani": "فَأَمَّا إِن كَانَ مِنَ الْمُقَرَّبِينَ",
    "tafseer": "[88] فأما إن كان الميت من السابقين المقربين، ",
    "t_verse_number": 88,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5068,
    "text_uthmani": "فَرَوْحٌ وَرَيْحَانٌ وَجَنَّةُ نَعِيمٍ",
    "tafseer": "[89] فله عند موته الرحمة الواسعة والفرح وما تطيب به نفسه، وله جنة النعيم في الآخرة.",
    "t_verse_number": 89,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5069,
    "text_uthmani": "وَأَمَّا إِن كَانَ مِنَ أَصْحَابِ الْيَمِينِ",
    "tafseer": "[90] وأما إن كان الميت من أصحاب اليمين،",
    "t_verse_number": 90,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5070,
    "text_uthmani": "فَسَلَامٌ لَّكَ مِنْ أَصْحَابِ الْيَمِينِ",
    "tafseer": "[91]  فيقال له: سلامة لك وأمن؛ لكونك من أصحاب اليمين.",
    "t_verse_number": 91,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5071,
    "text_uthmani": "وَأَمَّا إِن كَانَ مِنَ الْمُكَذِّبِينَ الضَّالِّينَ",
    "tafseer": "[92] وأما إن كان الميت من المكذبين بالبعث، الضالين عن الهدى،",
    "t_verse_number": 92,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5072,
    "text_uthmani": "فَنُزُلٌ مِّنْ حَمِيمٍ",
    "tafseer": "[93]    فله ضيافة من شراب جهنم المغلي المتناهي الحرارة",
    "t_verse_number": 93,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5073,
    "text_uthmani": "وَتَصْلِيَةُ جَحِيمٍ",
    "tafseer": "[94] والنارُ يحرق بها، ويقاسي عذابها الشديد",
    "t_verse_number": 94,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5074,
    "text_uthmani": "إِنَّ هَذَا لَهُوَ حَقُّ الْيَقِينِ",
    "tafseer": "[95] إن هذا الذي قصصناه عليك -أيها الرسول- لهو حق اليقين الذي لا مرية فيه،",
    "t_verse_number": 95,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5075,
    "text_uthmani": "فَسَبِّحْ بِاسْمِ رَبِّكَ الْعَظِيمِ",
    "tafseer": "[96]  فسبِّح باسم ربك العظيم، ونزِّهه عما يقول الظالمون والجاحدون، تعالى الله عما يقولون علوّاً كبيراً.",
    "t_verse_number": 96,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  }
]