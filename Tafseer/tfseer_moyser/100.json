[
  {
    "verse_id": 6147,
    "text_uthmani": "وَالْعَادِيَاتِ ضَبْحًا",
    "tafseer": "[1] أقسم الله تعالى بالخيل الجاريات في سبيله نحو العدوِّ، حين يظهر صوت أنفاسها من سرعة عَدْوِها. ولا يجوز للمخلوق أن يقسم إلا بالله؛ فإن القسم بغير الله شرك.",
    "t_verse_number": 1,
    "t_chapter_id": 100,
    "t_name_arabic": "العاديات"
  },
  {
    "verse_id": 6148,
    "text_uthmani": "فَالْمُورِيَاتِ قَدْحًا",
    "tafseer": "[2] فالخيلِ اللاتي تنقدح النار من صلابة حوافرها؛ لشدَّة عَدْوها.",
    "t_verse_number": 2,
    "t_chapter_id": 100,
    "t_name_arabic": "العاديات"
  },
  {
    "verse_id": 6149,
    "text_uthmani": "فَالْمُغِيرَاتِ صُبْحًا",
    "tafseer": "[3] فالخيلِ التي تُغير برُكْبانها على الأعداء عند الصبح.",
    "t_verse_number": 3,
    "t_chapter_id": 100,
    "t_name_arabic": "العاديات"
  },
  {
    "verse_id": 6150,
    "text_uthmani": "فَأَثَرْنَ بِهِ نَقْعًا",
    "tafseer": "[4] فهيَّجْنَ بهذا العَدْو غباراً.",
    "t_verse_number": 4,
    "t_chapter_id": 100,
    "t_name_arabic": "العاديات"
  },
  {
    "verse_id": 6151,
    "text_uthmani": "فَوَسَطْنَ بِهِ جَمْعًا",
    "tafseer": "[5] فتوسَّطن بركبانهن جموع الأعداء.",
    "t_verse_number": 5,
    "t_chapter_id": 100,
    "t_name_arabic": "العاديات"
  },
  {
    "verse_id": 6152,
    "text_uthmani": "إِنَّ الْإِنسَانَ لِرَبِّهِ لَكَنُودٌ",
    "tafseer": "[6] إن الإنسان لِنعم ربه لَجحود",
    "t_verse_number": 6,
    "t_chapter_id": 100,
    "t_name_arabic": "العاديات"
  },
  {
    "verse_id": 6153,
    "text_uthmani": "وَإِنَّهُ عَلَى ذَلِكَ لَشَهِيدٌ",
    "tafseer": "[7] وإنه بجحوده ذلك لمقر",
    "t_verse_number": 7,
    "t_chapter_id": 100,
    "t_name_arabic": "العاديات"
  },
  {
    "verse_id": 6154,
    "text_uthmani": "وَإِنَّهُ لِحُبِّ الْخَيْرِ لَشَدِيدٌ",
    "tafseer": "[8] وإنه لحب المال لشديد.",
    "t_verse_number": 8,
    "t_chapter_id": 100,
    "t_name_arabic": "العاديات"
  },
  {
    "verse_id": 6155,
    "text_uthmani": "أَفَلَا يَعْلَمُ إِذَا بُعْثِرَ مَا فِي الْقُبُورِ",
    "tafseer": "[9] أفلا يعلم الإنسان ما ينتظره إذا أخرج الله الأموات من القبور للحساب والجزاء؟",
    "t_verse_number": 9,
    "t_chapter_id": 100,
    "t_name_arabic": "العاديات"
  },
  {
    "verse_id": 6156,
    "text_uthmani": "وَحُصِّلَ مَا فِي الصُّدُورِ",
    "tafseer": "[10] واستُخرج ما استتر في الصدور من خير أو شر.",
    "t_verse_number": 10,
    "t_chapter_id": 100,
    "t_name_arabic": "العاديات"
  },
  {
    "verse_id": 6157,
    "text_uthmani": "إِنَّ رَبَّهُم بِهِمْ يَوْمَئِذٍ لَّخَبِيرٌ",
    "tafseer": "[11] إن ربهم بهم وبأعمالهم يومئذ لخبير، لا يخفى عليه شيء من ذلك.",
    "t_verse_number": 11,
    "t_chapter_id": 100,
    "t_name_arabic": "العاديات"
  }
]