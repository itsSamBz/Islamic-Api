[
  {
    "verse_id": 6059,
    "text_uthmani": "وَاللَّيْلِ إِذَا يَغْشَى",
    "tafseer": "أقسم الله بالليل إذا يغطي ما بين السماء والأرض بظلمته.",
    "t_verse_number": 1,
    "t_chapter_id": 92,
    "t_name_arabic": "الليل"
  },
  {
    "verse_id": 6060,
    "text_uthmani": "وَالنَّهَارِ إِذَا تَجَلَّى",
    "tafseer": "وأقسم بالنهار إذا تكشّف وظهر.",
    "t_verse_number": 2,
    "t_chapter_id": 92,
    "t_name_arabic": "الليل"
  },
  {
    "verse_id": 6061,
    "text_uthmani": "وَمَا خَلَقَ الذَّكَرَ وَالْأُنثَى",
    "tafseer": "وأقسم بخلقه النوعين:الذكر والأنثى.",
    "t_verse_number": 3,
    "t_chapter_id": 92,
    "t_name_arabic": "الليل"
  },
  {
    "verse_id": 6062,
    "text_uthmani": "إِنَّ سَعْيَكُمْ لَشَتَّى",
    "tafseer": "إن عملكم - أيها الناس - لمختلف، فمنه الحسنات التي هي سبب دخول الجنة، والسيئات التي هي سبب دخول النار.",
    "t_verse_number": 4,
    "t_chapter_id": 92,
    "t_name_arabic": "الليل"
  },
  {
    "verse_id": 6063,
    "text_uthmani": "فَأَمَّا مَن أَعْطَى وَاتَّقَى",
    "tafseer": "فأما من أعطى ما يلزمه بذله، من زكاة ونفقة وكفارة، واتقى ما نهى الله عنه.",
    "t_verse_number": 5,
    "t_chapter_id": 92,
    "t_name_arabic": "الليل"
  },
  {
    "verse_id": 6064,
    "text_uthmani": "وَصَدَّقَ بِالْحُسْنَى",
    "tafseer": "وصدق بما وعده الله به من الخَلَف.",
    "t_verse_number": 6,
    "t_chapter_id": 92,
    "t_name_arabic": "الليل"
  },
  {
    "verse_id": 6065,
    "text_uthmani": "فَسَنُيَسِّرُهُ لِلْيُسْرَى",
    "tafseer": "فسنُسَهِّل عليه العمل الصالح، والإنفاق في سبيل الله.",
    "t_verse_number": 7,
    "t_chapter_id": 92,
    "t_name_arabic": "الليل"
  },
  {
    "verse_id": 6066,
    "text_uthmani": "وَأَمَّا مَن بَخِلَ وَاسْتَغْنَى",
    "tafseer": "وأما من بخل بماله فلم يبذله فيما يجب عليه بذله فيه، واستغنى بماله عن الله فلم يسأل الله من فضله شيئًا.",
    "t_verse_number": 8,
    "t_chapter_id": 92,
    "t_name_arabic": "الليل"
  },
  {
    "verse_id": 6067,
    "text_uthmani": "وَكَذَّبَ بِالْحُسْنَى",
    "tafseer": "وكذب بما وعده الله من الخَلَف ومن الثواب على إنفاق ماله في سبيل الله.",
    "t_verse_number": 9,
    "t_chapter_id": 92,
    "t_name_arabic": "الليل"
  },
  {
    "verse_id": 6068,
    "text_uthmani": "فَسَنُيَسِّرُهُ لِلْعُسْرَى",
    "tafseer": "فسنُسَهِّل عليه عمل الشرّ، ونُعَسِّر عليه فعل الخير.",
    "t_verse_number": 10,
    "t_chapter_id": 92,
    "t_name_arabic": "الليل"
  },
  {
    "verse_id": 6069,
    "text_uthmani": "وَمَا يُغْنِي عَنْهُ مَالُهُ إِذَا تَرَدَّى",
    "tafseer": "وما يغني عنه ماله الذي بخل به شيئًا إذا هلك، ودخل النار.",
    "t_verse_number": 11,
    "t_chapter_id": 92,
    "t_name_arabic": "الليل"
  },
  {
    "verse_id": 6070,
    "text_uthmani": "إِنَّ عَلَيْنَا لَلْهُدَى",
    "tafseer": "إن علينا أن نبيّن طريق الحق من الباطل.",
    "t_verse_number": 12,
    "t_chapter_id": 92,
    "t_name_arabic": "الليل"
  },
  {
    "verse_id": 6071,
    "text_uthmani": "وَإِنَّ لَنَا لَلْآخِرَةَ وَالْأُولَى",
    "tafseer": "وإن لنا لَلْحياة الآخرة ولنا الحياة الدنيا، نتصرّف فيهما بما نشاء، وليس ذلك لأحد غيرنا.",
    "t_verse_number": 13,
    "t_chapter_id": 92,
    "t_name_arabic": "الليل"
  },
  {
    "verse_id": 6072,
    "text_uthmani": "فَأَنذَرْتُكُمْ نَارًا تَلَظَّى",
    "tafseer": "فحذّرتكم - أيها الناس - من نار تتوقد إن أنتم عصيتم الله.",
    "t_verse_number": 14,
    "t_chapter_id": 92,
    "t_name_arabic": "الليل"
  },
  {
    "verse_id": 6073,
    "text_uthmani": "لَا يَصْلَاهَا إِلَّا الْأَشْقَى",
    "tafseer": "لا يقاسي حرّ هذه النار إلا الأشقى وهو الكافر.",
    "t_verse_number": 15,
    "t_chapter_id": 92,
    "t_name_arabic": "الليل"
  },
  {
    "verse_id": 6074,
    "text_uthmani": "الَّذِي كَذَّبَ وَتَوَلَّى",
    "tafseer": "الذي كذب بما جاء به الرسول ﷺ، وأعرض عن امتثال أمر الله.",
    "t_verse_number": 16,
    "t_chapter_id": 92,
    "t_name_arabic": "الليل"
  },
  {
    "verse_id": 6075,
    "text_uthmani": "وَسَيُجَنَّبُهَا الْأَتْقَى",
    "tafseer": "وسيُباعَد عنها أتقى الناس أبو بكر رضي الله عنه.",
    "t_verse_number": 17,
    "t_chapter_id": 92,
    "t_name_arabic": "الليل"
  },
  {
    "verse_id": 6076,
    "text_uthmani": "الَّذِي يُؤْتِي مَالَهُ يَتَزَكَّى",
    "tafseer": "الذي ينفق ماله في وجوه البر ليتطهر من الذنوب.",
    "t_verse_number": 18,
    "t_chapter_id": 92,
    "t_name_arabic": "الليل"
  },
  {
    "verse_id": 6077,
    "text_uthmani": "وَمَا لِأَحَدٍ عِندَهُ مِن نِّعْمَةٍ تُجْزَى",
    "tafseer": "ولا يبذل ما يبذل من ماله ليكافئ نعمة أنعم بها أحد عليه.",
    "t_verse_number": 19,
    "t_chapter_id": 92,
    "t_name_arabic": "الليل"
  },
  {
    "verse_id": 6078,
    "text_uthmani": "إِلَّا ابْتِغَاء وَجْهِ رَبِّهِ الْأَعْلَى",
    "tafseer": "لا يريد بما يبذله من ماله إلا وجه ربه العالي على خَلْقِه.",
    "t_verse_number": 20,
    "t_chapter_id": 92,
    "t_name_arabic": "الليل"
  },
  {
    "verse_id": 6079,
    "text_uthmani": "وَلَسَوْفَ يَرْضَى",
    "tafseer": "ولسوف يرضى بما يعطيه الله من الجزاء الكريم.",
    "t_verse_number": 21,
    "t_chapter_id": 92,
    "t_name_arabic": "الليل"
  }
]