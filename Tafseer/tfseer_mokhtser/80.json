[
  {
    "verse_id": 5759,
    "text_uthmani": "عَبَسَ وَتَوَلَّى",
    "tafseer": "قطّب رسول الله ﷺ وجهه وأعرض.",
    "t_verse_number": 1,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5760,
    "text_uthmani": "أَن جَاءهُ الْأَعْمَى",
    "tafseer": "لأجل مجيء عبد الله بن أم مكتوم يسترشده، وكان أعمى، جاء والرسول ﷺ منشغل بأكابر المشركين أملًا في هدايتهم.",
    "t_verse_number": 2,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5761,
    "text_uthmani": "وَمَا يُدْرِيكَ لَعَلَّهُ يَزَّكَّى",
    "tafseer": "وما يُعْلِمُكَ - أيها الرسول - لعل هذا الأعمى يتطهر من ذنوبه؟!",
    "t_verse_number": 3,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5762,
    "text_uthmani": "أَوْ يَذَّكَّرُ فَتَنفَعَهُ الذِّكْرَى",
    "tafseer": "أو يتعظ بما يسمع منك من المواعظ، فينتفع بها.",
    "t_verse_number": 4,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5763,
    "text_uthmani": "أَمَّا مَنِ اسْتَغْنَى",
    "tafseer": "أما من استغنى بنفسه بما لديه من المال عن الإيمان بما جئت به.",
    "t_verse_number": 5,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5764,
    "text_uthmani": "فَأَنتَ لَهُ تَصَدَّى",
    "tafseer": "فأنت تَتَعرَّض له، وتُقبل إليه.",
    "t_verse_number": 6,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5765,
    "text_uthmani": "وَمَا عَلَيْكَ أَلَّا يَزَّكَّى",
    "tafseer": "وأي شيء يلحقك إذا لم يتطهر من ذنوبه بالتوبة إلى الله.",
    "t_verse_number": 7,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5766,
    "text_uthmani": "وَأَمَّا مَن جَاءكَ يَسْعَى",
    "tafseer": "وأما من جاءك يسعى بحثًا عن الخير.",
    "t_verse_number": 8,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5767,
    "text_uthmani": "وَهُوَ يَخْشَى",
    "tafseer": "وهو يخشى ربه.",
    "t_verse_number": 9,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5768,
    "text_uthmani": "فَأَنتَ عَنْهُ تَلَهَّى",
    "tafseer": "فأنت تتشاغل عنه بغيره من أكابر المشركين.",
    "t_verse_number": 10,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5769,
    "text_uthmani": "كَلَّا إِنَّهَا تَذْكِرَةٌ",
    "tafseer": "ليس الأمر كذلك، إنما هي موعظة وتذكير لمن يقبل.",
    "t_verse_number": 11,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5770,
    "text_uthmani": "فَمَن شَاء ذَكَرَهُ",
    "tafseer": "فمن شاء أن يذكر الله ذكره، واتعظ بما في هذا القرآن.",
    "t_verse_number": 12,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5771,
    "text_uthmani": "فِي صُحُفٍ مُّكَرَّمَةٍ",
    "tafseer": "فهذا القرآن في صحف شريفة عند الملائكة.",
    "t_verse_number": 13,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5772,
    "text_uthmani": "مَّرْفُوعَةٍ مُّطَهَّرَةٍ",
    "tafseer": "مرفوعة في مكان عال، مطهرة لا يصيبها دَنَس ولا رِجْس.",
    "t_verse_number": 14,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5773,
    "text_uthmani": "بِأَيْدِي سَفَرَةٍ",
    "tafseer": "وهي بأيدي رسل من الملائكة.",
    "t_verse_number": 15,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5774,
    "text_uthmani": "كِرَامٍ بَرَرَةٍ",
    "tafseer": "كرام عند ربهم، كثيري فعل الخير والطاعات.",
    "t_verse_number": 16,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5775,
    "text_uthmani": "قُتِلَ الْإِنسَانُ مَا أَكْفَرَهُ",
    "tafseer": "لُعِن الإنسان الكافر، ما أشدّ كفره بالله!",
    "t_verse_number": 17,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5776,
    "text_uthmani": "مِنْ أَيِّ شَيْءٍ خَلَقَهُ",
    "tafseer": "من أيّ شيء خلقه الله حتى يتكبّر في الأرض ويَكْفُرَهُ؟!",
    "t_verse_number": 18,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5777,
    "text_uthmani": "مِن نُّطْفَةٍ خَلَقَهُ فَقَدَّرَهُ",
    "tafseer": "من ماء قليل خلقه، فَقَدَّر خلقه طورًا بعد طور.",
    "t_verse_number": 19,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5778,
    "text_uthmani": "ثُمَّ السَّبِيلَ يَسَّرَهُ",
    "tafseer": "ثم يسّر له بعد هذه الأطوار الخروج من بطن أمه.",
    "t_verse_number": 20,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5779,
    "text_uthmani": "ثُمَّ أَمَاتَهُ فَأَقْبَرَهُ",
    "tafseer": "ثم بعد ما قَدَّر له من عمر في الحياة أماته، وجعل له قبرًا يبقى فيه إلى أن يبعث.",
    "t_verse_number": 21,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5780,
    "text_uthmani": "ثُمَّ إِذَا شَاء أَنشَرَهُ",
    "tafseer": "ثم إذا شاء بَعَثَهُ للحساب والجزاء.",
    "t_verse_number": 22,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5781,
    "text_uthmani": "كَلَّا لَمَّا يَقْضِ مَا أَمَرَهُ",
    "tafseer": "ليس الأمر كما يتوهم هذا الكافر أنه أدى ما عليه لربه من حق، فهو لم يؤدّ ما أوجب الله عليه من الفرائض.",
    "t_verse_number": 23,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5782,
    "text_uthmani": "فَلْيَنظُرِ الْإِنسَانُ إِلَى طَعَامِهِ",
    "tafseer": "فلينظر الإنسان الكافر بالله إلى طعامه الذي يأكله كيف حصل؟!",
    "t_verse_number": 24,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5783,
    "text_uthmani": "أَنَّا صَبَبْنَا الْمَاء صَبًّا",
    "tafseer": "فأصله من المطر النازل من السماء بقوة وغزارة.",
    "t_verse_number": 25,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5784,
    "text_uthmani": "ثُمَّ شَقَقْنَا الْأَرْضَ شَقًّا",
    "tafseer": "ثم فَتَقْنا الأرض فانشقت عن النبات.",
    "t_verse_number": 26,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5785,
    "text_uthmani": "فَأَنبَتْنَا فِيهَا حَبًّا",
    "tafseer": "فأنبتنا فيها الحبوب من قمح وذرة وغيرهما.",
    "t_verse_number": 27,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5786,
    "text_uthmani": "وَعِنَبًا وَقَضْبًا",
    "tafseer": "وأنبتنا فيها عنبًا وقتًّا رطبًا، ليكون علفًا لدوابهم.",
    "t_verse_number": 28,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5787,
    "text_uthmani": "وَزَيْتُونًا وَنَخْلًا",
    "tafseer": "وأنبتنا فيها زيتونًا ونخلًا.",
    "t_verse_number": 29,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5788,
    "text_uthmani": "وَحَدَائِقَ غُلْبًا",
    "tafseer": "وأنبتنا فيها بساتين كثيرة الأشجار.",
    "t_verse_number": 30,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5789,
    "text_uthmani": "وَفَاكِهَةً وَأَبًّا",
    "tafseer": "وأنبتنا فيها فاكهة، وأنبتنا فيها ما ترعاه بهائمكم.",
    "t_verse_number": 31,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5790,
    "text_uthmani": "مَّتَاعًا لَّكُمْ وَلِأَنْعَامِكُمْ",
    "tafseer": "لانتفاعكم، وانتفاع بهائمكم.",
    "t_verse_number": 32,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5791,
    "text_uthmani": "فَإِذَا جَاءتِ الصَّاخَّةُ",
    "tafseer": "فإذا جاءت الصيحة العظيمة التي تصخ الآذان وهي النفخة الثانية.",
    "t_verse_number": 33,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5792,
    "text_uthmani": "يَوْمَ يَفِرُّ الْمَرْءُ مِنْ أَخِيهِ",
    "tafseer": "يوم يهرب المرء من أخيه.",
    "t_verse_number": 34,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5793,
    "text_uthmani": "وَأُمِّهِ وَأَبِيهِ",
    "tafseer": "ويفرّ من أمه وأبيه.",
    "t_verse_number": 35,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5794,
    "text_uthmani": "وَصَاحِبَتِهِ وَبَنِيهِ",
    "tafseer": "ويفرّ من زوجته وأولاده.",
    "t_verse_number": 36,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5795,
    "text_uthmani": "لِكُلِّ امْرِئٍ مِّنْهُمْ يَوْمَئِذٍ شَأْنٌ يُغْنِيهِ",
    "tafseer": "لكلّ واحد منهم ما يشغله عن الآخر من شدّة الكرب في ذلك اليوم.",
    "t_verse_number": 37,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5796,
    "text_uthmani": "وُجُوهٌ يَوْمَئِذٍ مُّسْفِرَةٌ",
    "tafseer": "وجوه السعداء في ذلك اليوم مضيئة.",
    "t_verse_number": 38,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5797,
    "text_uthmani": "ضَاحِكَةٌ مُّسْتَبْشِرَةٌ",
    "tafseer": "ضاحكة فرحة بما أعدّ الله لها من رحمته.",
    "t_verse_number": 39,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5798,
    "text_uthmani": "وَوُجُوهٌ يَوْمَئِذٍ عَلَيْهَا غَبَرَةٌ",
    "tafseer": "ووجوه الأشقياء في ذلك اليوم عليها غبار.",
    "t_verse_number": 40,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5799,
    "text_uthmani": "تَرْهَقُهَا قَتَرَةٌ",
    "tafseer": "تغشاها ظلمة.",
    "t_verse_number": 41,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  },
  {
    "verse_id": 5800,
    "text_uthmani": "أُوْلَئِكَ هُمُ الْكَفَرَةُ الْفَجَرَةُ",
    "tafseer": "أولئك الموصوفون بتلك الحال هم الذين جمعوا بين الكفر والفجور.",
    "t_verse_number": 42,
    "t_chapter_id": 80,
    "t_name_arabic": "عبس"
  }
]