[
  {
    "verse_id": 6198,
    "text_uthmani": "أَرَأَيْتَ الَّذِي يُكَذِّبُ بِالدِّينِ",
    "tafseer": "هل عرفت الذي يكذب بالجزاء يوم القيامة؟!",
    "t_verse_number": 1,
    "t_chapter_id": 107,
    "t_name_arabic": "الماعون"
  },
  {
    "verse_id": 6199,
    "text_uthmani": "فَذَلِكَ الَّذِي يَدُعُّ الْيَتِيمَ",
    "tafseer": "فهو ذلك الذي يدفع اليتيم بغلظة عن حاجته.",
    "t_verse_number": 2,
    "t_chapter_id": 107,
    "t_name_arabic": "الماعون"
  },
  {
    "verse_id": 6200,
    "text_uthmani": "وَلَا يَحُضُّ عَلَى طَعَامِ الْمِسْكِينِ",
    "tafseer": "ولا يحثّ نفسه، ولا يحث غيره على إطعام الفقير.",
    "t_verse_number": 3,
    "t_chapter_id": 107,
    "t_name_arabic": "الماعون"
  },
  {
    "verse_id": 6201,
    "text_uthmani": "فَوَيْلٌ لِّلْمُصَلِّينَ",
    "tafseer": "فهلاك وعذاب للمصلِّين.",
    "t_verse_number": 4,
    "t_chapter_id": 107,
    "t_name_arabic": "الماعون"
  },
  {
    "verse_id": 6202,
    "text_uthmani": "الَّذِينَ هُمْ عَن صَلَاتِهِمْ سَاهُونَ",
    "tafseer": "الذين هم عن صلاتهم لاهون، لا يبالون بها حتى ينقضي وقتها.",
    "t_verse_number": 5,
    "t_chapter_id": 107,
    "t_name_arabic": "الماعون"
  },
  {
    "verse_id": 6203,
    "text_uthmani": "الَّذِينَ هُمْ يُرَاؤُونَ",
    "tafseer": "الذين هم يراؤون بصلاتهم وأعمالهم، لا يخلصون العمل لله.",
    "t_verse_number": 6,
    "t_chapter_id": 107,
    "t_name_arabic": "الماعون"
  },
  {
    "verse_id": 6204,
    "text_uthmani": "وَيَمْنَعُونَ الْمَاعُونَ",
    "tafseer": "ويمنعون إعانة غيرهم بما لا ضرر في الإعانة به.",
    "t_verse_number": 7,
    "t_chapter_id": 107,
    "t_name_arabic": "الماعون"
  }
]