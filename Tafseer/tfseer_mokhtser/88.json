[
  {
    "verse_id": 5968,
    "text_uthmani": "هَلْ أَتَاكَ حَدِيثُ الْغَاشِيَةِ",
    "tafseer": "هل أتاك - أيها الرسول - حديث القيامة التي تغشى الناس بأهوالها؟!",
    "t_verse_number": 1,
    "t_chapter_id": 88,
    "t_name_arabic": "الغاشية"
  },
  {
    "verse_id": 5969,
    "text_uthmani": "وُجُوهٌ يَوْمَئِذٍ خَاشِعَةٌ",
    "tafseer": "فالناس في يوم القيامة إما أشقياء وإما سعداء، فوجوه الأشقياء ذليلة خاضعة.",
    "t_verse_number": 2,
    "t_chapter_id": 88,
    "t_name_arabic": "الغاشية"
  },
  {
    "verse_id": 5970,
    "text_uthmani": "عَامِلَةٌ نَّاصِبَةٌ",
    "tafseer": "متعبة مجهدة بالسلاسل التي تُسْحب بها، والأغلال التي تُغَل بها.",
    "t_verse_number": 3,
    "t_chapter_id": 88,
    "t_name_arabic": "الغاشية"
  },
  {
    "verse_id": 5971,
    "text_uthmani": "تَصْلَى نَارًا حَامِيَةً",
    "tafseer": "تدخل تلك الوجوه نارًا حارة تقاسي حرّها.",
    "t_verse_number": 4,
    "t_chapter_id": 88,
    "t_name_arabic": "الغاشية"
  },
  {
    "verse_id": 5972,
    "text_uthmani": "تُسْقَى مِنْ عَيْنٍ آنِيَةٍ",
    "tafseer": "تُسْقى من عين شديدة حرارة الماء.",
    "t_verse_number": 5,
    "t_chapter_id": 88,
    "t_name_arabic": "الغاشية"
  },
  {
    "verse_id": 5973,
    "text_uthmani": "لَّيْسَ لَهُمْ طَعَامٌ إِلَّا مِن ضَرِيعٍ",
    "tafseer": "ليس لهم طعام يتغذّون به إلا من أخبث الطعام وأنتنه من نبات يسمّى الشِّبْرِق إذا يبس صار مسمومًا.",
    "t_verse_number": 6,
    "t_chapter_id": 88,
    "t_name_arabic": "الغاشية"
  },
  {
    "verse_id": 5974,
    "text_uthmani": "لَا يُسْمِنُ وَلَا يُغْنِي مِن جُوعٍ",
    "tafseer": "لا يُسْمِن آكله، ولا يسدّ جوعته.",
    "t_verse_number": 7,
    "t_chapter_id": 88,
    "t_name_arabic": "الغاشية"
  },
  {
    "verse_id": 5975,
    "text_uthmani": "وُجُوهٌ يَوْمَئِذٍ نَّاعِمَةٌ",
    "tafseer": "ووجوه السعداء في ذلك اليوم ذات نعمة وبهجة وسرور، لما لاقوه من النعيم.",
    "t_verse_number": 8,
    "t_chapter_id": 88,
    "t_name_arabic": "الغاشية"
  },
  {
    "verse_id": 5976,
    "text_uthmani": "لِسَعْيِهَا رَاضِيَةٌ",
    "tafseer": "لعملها الصالح الذي عملته في الدنيا راضية، فقد وجدت ثواب عملها مدخرًا لها مضاعفًا.",
    "t_verse_number": 9,
    "t_chapter_id": 88,
    "t_name_arabic": "الغاشية"
  },
  {
    "verse_id": 5977,
    "text_uthmani": "فِي جَنَّةٍ عَالِيَةٍ",
    "tafseer": "في جنة مرتفعة المكان والمكانة.",
    "t_verse_number": 10,
    "t_chapter_id": 88,
    "t_name_arabic": "الغاشية"
  },
  {
    "verse_id": 5978,
    "text_uthmani": "لَّا تَسْمَعُ فِيهَا لَاغِيَةً",
    "tafseer": "لا تسمع في الجنة كلمة باطل ولغو، فضلًا عن سماع كلمة محرمة.",
    "t_verse_number": 11,
    "t_chapter_id": 88,
    "t_name_arabic": "الغاشية"
  },
  {
    "verse_id": 5979,
    "text_uthmani": "فِيهَا عَيْنٌ جَارِيَةٌ",
    "tafseer": "في هذه الجنة عيون جارية يفجرونها، ويصرفونها كيف شاؤوا.",
    "t_verse_number": 12,
    "t_chapter_id": 88,
    "t_name_arabic": "الغاشية"
  },
  {
    "verse_id": 5980,
    "text_uthmani": "فِيهَا سُرُرٌ مَّرْفُوعَةٌ",
    "tafseer": "فيها أسرة عالية.",
    "t_verse_number": 13,
    "t_chapter_id": 88,
    "t_name_arabic": "الغاشية"
  },
  {
    "verse_id": 5981,
    "text_uthmani": "وَأَكْوَابٌ مَّوْضُوعَةٌ",
    "tafseer": "وأكواب مطروحة مُهيَّأة للشرب.",
    "t_verse_number": 14,
    "t_chapter_id": 88,
    "t_name_arabic": "الغاشية"
  },
  {
    "verse_id": 5982,
    "text_uthmani": "وَنَمَارِقُ مَصْفُوفَةٌ",
    "tafseer": "وفيها وسائد مرصوص بعضها إلى بعض.",
    "t_verse_number": 15,
    "t_chapter_id": 88,
    "t_name_arabic": "الغاشية"
  },
  {
    "verse_id": 5983,
    "text_uthmani": "وَزَرَابِيُّ مَبْثُوثَةٌ",
    "tafseer": "وفيها بسط مبسوطة هنا وهناك.",
    "t_verse_number": 16,
    "t_chapter_id": 88,
    "t_name_arabic": "الغاشية"
  },
  {
    "verse_id": 5984,
    "text_uthmani": "أَفَلَا يَنظُرُونَ إِلَى الْإِبِلِ كَيْفَ خُلِقَتْ",
    "tafseer": "ولما ذكر الله تفاوت أحوال الأشقياء والسعداء في الآخرة، وجَّه أنظار الكفار إلى ما يدلّهم على قدرة الخالق وحسن خلقه ليستدلوا بذلك على الإيمان، ليدخلوا الجنة فيكونوا من السعداء فقال:أفلا ينظرون نظر تأمل إلى الإبل كيف خلقها الله، وسخرها لبني آدم؟!",
    "t_verse_number": 17,
    "t_chapter_id": 88,
    "t_name_arabic": "الغاشية"
  },
  {
    "verse_id": 5985,
    "text_uthmani": "وَإِلَى السَّمَاء كَيْفَ رُفِعَتْ",
    "tafseer": "وينظرون إلى السماء كيف رفعها حتى صارت فوقهم سقفًا محفوظًا، لا يسقط عليهم؟!",
    "t_verse_number": 18,
    "t_chapter_id": 88,
    "t_name_arabic": "الغاشية"
  },
  {
    "verse_id": 5986,
    "text_uthmani": "وَإِلَى الْجِبَالِ كَيْفَ نُصِبَتْ",
    "tafseer": "وينظرون إلى الجبال كيف نصبها وثبت بها الأرض أن تضطرب بالناس؟!",
    "t_verse_number": 19,
    "t_chapter_id": 88,
    "t_name_arabic": "الغاشية"
  },
  {
    "verse_id": 5987,
    "text_uthmani": "وَإِلَى الْأَرْضِ كَيْفَ سُطِحَتْ",
    "tafseer": "وينظرون إلى الأرض كيف بسطها، وجعلها مُهيَّأة لاستقرار الناس عليها؟!",
    "t_verse_number": 20,
    "t_chapter_id": 88,
    "t_name_arabic": "الغاشية"
  },
  {
    "verse_id": 5988,
    "text_uthmani": "فَذَكِّرْ إِنَّمَا أَنتَ مُذَكِّرٌ",
    "tafseer": "ولمّا وجههم إلى النظر إلى ما يدل على قدرته تعالى وجَّه رسوله، فقال:فعظ - أيها الرسول - هؤلاء، وخوفهم من عذاب الله، إنما أنت مذكر، لا يطلب منك إلا تذكيرهم، وأما توفيقهم للإيمان فهو بيد الله وحده.",
    "t_verse_number": 21,
    "t_chapter_id": 88,
    "t_name_arabic": "الغاشية"
  },
  {
    "verse_id": 5989,
    "text_uthmani": "لَّسْتَ عَلَيْهِم بِمُصَيْطِرٍ",
    "tafseer": "لست عليهم مسلطًا حتى تكرههم على الإيمان.",
    "t_verse_number": 22,
    "t_chapter_id": 88,
    "t_name_arabic": "الغاشية"
  },
  {
    "verse_id": 5990,
    "text_uthmani": "إِلَّا مَن تَوَلَّى وَكَفَرَ",
    "tafseer": "لكن من تولّى منهم عن الإيمان، وكفر بالله وبرسوله.",
    "t_verse_number": 23,
    "t_chapter_id": 88,
    "t_name_arabic": "الغاشية"
  },
  {
    "verse_id": 5991,
    "text_uthmani": "فَيُعَذِّبُهُ اللَّهُ الْعَذَابَ الْأَكْبَرَ",
    "tafseer": "فيعذبه الله يوم القيامة العذاب الأعظم بأن يدخله جهنم خالدًا فيها.",
    "t_verse_number": 24,
    "t_chapter_id": 88,
    "t_name_arabic": "الغاشية"
  },
  {
    "verse_id": 5992,
    "text_uthmani": "إِنَّ إِلَيْنَا إِيَابَهُمْ",
    "tafseer": "إن إلينا وحدنا رجوعهم بعد موتهم.",
    "t_verse_number": 25,
    "t_chapter_id": 88,
    "t_name_arabic": "الغاشية"
  },
  {
    "verse_id": 5993,
    "text_uthmani": "ثُمَّ إِنَّ عَلَيْنَا حِسَابَهُمْ",
    "tafseer": "ثم إن علينا وحدنا حسابهم على أعمالهم، وليس لك ولا لأحد غيرك ذلك.",
    "t_verse_number": 26,
    "t_chapter_id": 88,
    "t_name_arabic": "الغاشية"
  }
]