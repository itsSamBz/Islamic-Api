    "text_uthmani": "اللَّهُ الصَّمَدُ",
    "tafseer": "هو السيّد الذي انتهى إليه السُّؤْدَد في صفات الكمال والجمال، الذي تصمد إليه الخلائق.",
    "t_verse_number": 2,
    "t_chapter_id": 112,
    "t_name_arabic": "الإخلاص"
  },
  {
    "verse_id": 6224,
    "text_uthmani": "لَمْ يَلِدْ وَلَمْ يُولَدْ",
    "tafseer": "الذي لم يلد أحدًا، ولم يلده أحد، فلا ولد له - سبحانه - ولا والد.",
    "t_verse_number": 3,
    "t_chapter_id": 112,
    "t_name_arabic": "الإخلاص"
  },
  {
