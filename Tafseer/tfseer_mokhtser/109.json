[
  {
    "verse_id": 6208,
    "text_uthmani": "قُلْ يَا أَيُّهَا الْكَافِرُونَ",
    "tafseer": "قل - أيها الرسول -:يا أيها الكافرون بالله.",
    "t_verse_number": 1,
    "t_chapter_id": 109,
    "t_name_arabic": "الكافرون"
  },
  {
    "verse_id": 6209,
    "text_uthmani": "لَا أَعْبُدُ مَا تَعْبُدُونَ",
    "tafseer": "لا أعبد في الحال ولا في المستقبل ما تعبدون من الأصنام.",
    "t_verse_number": 2,
    "t_chapter_id": 109,
    "t_name_arabic": "الكافرون"
  },
  {
    "verse_id": 6210,
    "text_uthmani": "وَلَا أَنتُمْ عَابِدُونَ مَا أَعْبُدُ",
    "tafseer": "ولا أنتم عابدون ما أعبده أنا، وهو الله وحده.",
    "t_verse_number": 3,
    "t_chapter_id": 109,
    "t_name_arabic": "الكافرون"
  },
  {
    "verse_id": 6211,
    "text_uthmani": "وَلَا أَنَا عَابِدٌ مَّا عَبَدتُّمْ",
    "tafseer": "ولا أنا عابد ما عبدتم من الأصنام.",
    "t_verse_number": 4,
    "t_chapter_id": 109,
    "t_name_arabic": "الكافرون"
  },
  {
    "verse_id": 6212,
    "text_uthmani": "وَلَا أَنتُمْ عَابِدُونَ مَا أَعْبُدُ",
    "tafseer": "ولا أنتم عابدون ما أعبده أنا، وهو الله وحده.",
    "t_verse_number": 5,
    "t_chapter_id": 109,
    "t_name_arabic": "الكافرون"
  },
  {
    "verse_id": 6213,
    "text_uthmani": "لَكُمْ دِينُكُمْ وَلِيَ دِينِ",
