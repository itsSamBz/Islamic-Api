[
  {
    "verse_id": 6091,
    "text_uthmani": "أَلَمْ نَشْرَحْ لَكَ صَدْرَكَ",
    "tafseer": "لقد شرح الله لك صدرك فحبَّب إليك تلقِّي الوحي.",
    "t_verse_number": 1,
    "t_chapter_id": 94,
    "t_name_arabic": "الشرح"
  },
  {
    "verse_id": 6092,
    "text_uthmani": "وَوَضَعْنَا عَنكَ وِزْرَكَ",
    "tafseer": "وحططنا عنك الإثم.",
    "t_verse_number": 2,
    "t_chapter_id": 94,
    "t_name_arabic": "الشرح"
  },
  {
    "verse_id": 6093,
    "text_uthmani": "الَّذِي أَنقَضَ ظَهْرَكَ",
    "tafseer": "الذي أتعبك حتى كاد أن يكسر ظهرك.",
    "t_verse_number": 3,
    "t_chapter_id": 94,
    "t_name_arabic": "الشرح"
  },
  {
    "verse_id": 6094,
    "text_uthmani": "وَرَفَعْنَا لَكَ ذِكْرَكَ",
    "tafseer": "وأعلينا لك ذكرك، فقد أصبحت تُذْكَر في الأذان والإقامة وفي غيرهما.",
    "t_verse_number": 4,
    "t_chapter_id": 94,
    "t_name_arabic": "الشرح"
  },
  {
    "verse_id": 6095,
    "text_uthmani": "فَإِنَّ مَعَ الْعُسْرِ يُسْرًا",
    "tafseer": "فإن مع الشدّة والضيق سهولة واتساعًا.",
    "t_verse_number": 5,
    "t_chapter_id": 94,
    "t_name_arabic": "الشرح"
  },
  {
    "verse_id": 6096,
    "text_uthmani": "إِنَّ مَعَ الْعُسْرِ يُسْرًا",
    "tafseer": "إن مع الشدة والضيق سهولة واتساعًا، إذا علمت ذلك فلا يهولنك أذى قومك، ولا يصدنك عن الدعوة إلى الله.",
    "t_verse_number": 6,
    "t_chapter_id": 94,
    "t_name_arabic": "الشرح"
  },
  {
    "verse_id": 6097,
    "text_uthmani": "فَإِذَا فَرَغْتَ فَانصَبْ",
    "tafseer": "فإذا فرغت من أعمالك، وانتهيت منها فاجتهد في عبادة ربك.",
    "t_verse_number": 7,
    "t_chapter_id": 94,
    "t_name_arabic": "الشرح"
  },
  {
    "verse_id": 6098,
    "text_uthmani": "وَإِلَى رَبِّكَ فَارْغَبْ",
    "tafseer": "واجعل رغبتك وقصدك إلى الله وحده.",
    "t_verse_number": 8,
    "t_chapter_id": 94,
    "t_name_arabic": "الشرح"
  }
]