[
  {
    "verse_id": 6147,
    "text_uthmani": "وَالْعَادِيَاتِ ضَبْحًا",
    "tafseer": "أقسم الله بالخيل التي تجري حتى يُسْمَع لنَفَسِها صوتٌ من شدة الجري.",
    "t_verse_number": 1,
    "t_chapter_id": 100,
    "t_name_arabic": "العاديات"
  },
  {
    "verse_id": 6148,
    "text_uthmani": "فَالْمُورِيَاتِ قَدْحًا",
    "tafseer": "وأقسم بالخيل التي تُوقِد بحوافرها النار إذا لامست بها الصخور لشدة وقعها عليها.",
    "t_verse_number": 2,
    "t_chapter_id": 100,
    "t_name_arabic": "العاديات"
  },
  {
    "verse_id": 6149,
    "text_uthmani": "فَالْمُغِيرَاتِ صُبْحًا",
    "tafseer": "وأقسم بالخيل التي تُغِير على الأعداء وقت الصباح.",
    "t_verse_number": 3,
    "t_chapter_id": 100,
    "t_name_arabic": "العاديات"
  },
  {
    "verse_id": 6150,
    "text_uthmani": "فَأَثَرْنَ بِهِ نَقْعًا",
    "tafseer": "فحركن بجريهنّ غبارًا.",
    "t_verse_number": 4,
    "t_chapter_id": 100,
    "t_name_arabic": "العاديات"
  },
  {
    "verse_id": 6151,
    "text_uthmani": "فَوَسَطْنَ بِهِ جَمْعًا",
    "tafseer": "فتوسّطن بفوارسهنّ جَمْعًا من الأعداء.",
    "t_verse_number": 5,
    "t_chapter_id": 100,
    "t_name_arabic": "العاديات"
  },
  {
    "verse_id": 6152,
    "text_uthmani": "إِنَّ الْإِنسَانَ لِرَبِّهِ لَكَنُودٌ",
    "tafseer": "إن الإنسان لمَنُوع للخير الذي يريده منه ربه.",
    "t_verse_number": 6,
    "t_chapter_id": 100,
    "t_name_arabic": "العاديات"
  },
  {
    "verse_id": 6153,
    "text_uthmani": "وَإِنَّهُ عَلَى ذَلِكَ لَشَهِيدٌ",
    "tafseer": "وإنه على منعه للخير لشاهد، لا يستطيع إنكار ذلك لوضوحه.",
    "t_verse_number": 7,
    "t_chapter_id": 100,
    "t_name_arabic": "العاديات"
  },
  {
    "verse_id": 6154,
    "text_uthmani": "وَإِنَّهُ لِحُبِّ الْخَيْرِ لَشَدِيدٌ",
    "tafseer": "وإنه لفرط حبه للمال يبخل به.",
    "t_verse_number": 8,
    "t_chapter_id": 100,
    "t_name_arabic": "العاديات"
  },
  {
    "verse_id": 6155,
    "text_uthmani": "أَفَلَا يَعْلَمُ إِذَا بُعْثِرَ مَا فِي الْقُبُورِ",
    "tafseer": "أفلا يعلم هذا الإنسان المغترّ بالحياة الدنيا إذا بعث الله ما في القبور من الأموات وأخرجهم من الأرض للحساب والجزاء أن الأمر لم يكن كما كان يتوهم؟!",
    "t_verse_number": 9,
    "t_chapter_id": 100,
    "t_name_arabic": "العاديات"
  },
  {
    "verse_id": 6156,
    "text_uthmani": "وَحُصِّلَ مَا فِي الصُّدُورِ",
    "tafseer": "وأُبْرِز وبُيِّن ما في القلوب من النيات والاعتقادات وغيرها.",
    "t_verse_number": 10,
    "t_chapter_id": 100,
    "t_name_arabic": "العاديات"
  },
  {
    "verse_id": 6157,
    "text_uthmani": "إِنَّ رَبَّهُم بِهِمْ يَوْمَئِذٍ لَّخَبِيرٌ",
    "tafseer": "إن ربهم بهم في ذلك اليوم لخبير، لا يخفى عليه من أمر عباده شيء، وسيجازيهم على ذلك.",
    "t_verse_number": 11,
    "t_chapter_id": 100,
    "t_name_arabic": "العاديات"
  }
]