[
  {
    "verse_id": 4980,
    "text_uthmani": "إِذَا وَقَعَتِ الْوَاقِعَةُ",
    "tafseer": "إذا قامت القيامة لا محالة.",
    "t_verse_number": 1,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 4981,
    "text_uthmani": "لَيْسَ لِوَقْعَتِهَا كَاذِبَةٌ",
    "tafseer": "لن توجد نفس تكذّب بها كما كانت تكذّب في الدنيا.",
    "t_verse_number": 2,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 4982,
    "text_uthmani": "خَافِضَةٌ رَّافِعَةٌ",
    "tafseer": "خافضة للكفار الفجار بإدخالهم في النار، رافعة للمؤمنين المتقين بإدخالهم في الجنة.",
    "t_verse_number": 3,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 4983,
    "text_uthmani": "إِذَا رُجَّتِ الْأَرْضُ رَجًّا",
    "tafseer": "إذا حُرِّكت الأرض تحريكًا عظيمًا.",
    "t_verse_number": 4,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 4984,
    "text_uthmani": "وَبُسَّتِ الْجِبَالُ بَسًّا",
    "tafseer": "وفُتِّتت الجبال تفتيتًا.",
    "t_verse_number": 5,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 4985,
    "text_uthmani": "فَكَانَتْ هَبَاء مُّنبَثًّا",
    "tafseer": "فكانت من التفتيت غبارًا منتشرًا لا ثبات لها.",
    "t_verse_number": 6,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 4986,
    "text_uthmani": "وَكُنتُمْ أَزْوَاجًا ثَلَاثَةً",
    "tafseer": "وكنتم أصنافًا ثلاثة في ذلك اليوم:",
    "t_verse_number": 7,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 4987,
    "text_uthmani": "فَأَصْحَابُ الْمَيْمَنَةِ مَا أَصْحَابُ الْمَيْمَنَةِ",
    "tafseer": "فأصحاب اليمين الذين يأخذون كتبهم بأيمانهم، ما أعلى وأعظم منزلتهم!",
    "t_verse_number": 8,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 4988,
    "text_uthmani": "وَأَصْحَابُ الْمَشْأَمَةِ مَا أَصْحَابُ الْمَشْأَمَةِ",
    "tafseer": "وأصحاب الشمال الذين يأخذون كتبهم بشمائلهم، ما أخسّ وأسوأ منزلتهم!",
    "t_verse_number": 9,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 4989,
    "text_uthmani": "وَالسَّابِقُونَ السَّابِقُونَ",
    "tafseer": "والسابقون بفعل الخيرات في الدنيا هم السابقون في الآخرة لدخول الجنة.",
    "t_verse_number": 10,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 4990,
    "text_uthmani": "أُوْلَئِكَ الْمُقَرَّبُونَ",
    "tafseer": "أولئك هم المقربون عند الله.",
    "t_verse_number": 11,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 4991,
    "text_uthmani": "فِي جَنَّاتِ النَّعِيمِ",
    "tafseer": "في جنات النعيم، يتنعمون بأصناف النعيم.",
    "t_verse_number": 12,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 4992,
    "text_uthmani": "ثُلَّةٌ مِّنَ الْأَوَّلِينَ",
    "tafseer": "جماعة من هذه الأمة ومن الأمم السابقة.",
    "t_verse_number": 13,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 4993,
    "text_uthmani": "وَقَلِيلٌ مِّنَ الْآخِرِينَ",
    "tafseer": "وقليل من الناس في آخر الزمان هم السابقون المقربون.",
    "t_verse_number": 14,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 4994,
    "text_uthmani": "عَلَى سُرُرٍ مَّوْضُونَةٍ",
    "tafseer": "على أسِرّة منسوجة بالذهب.",
    "t_verse_number": 15,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 4995,
    "text_uthmani": "مُتَّكِئِينَ عَلَيْهَا مُتَقَابِلِينَ",
    "tafseer": "متكئين على هذه الأسرّة متقابلين بوجوههم، لا ينظر أحدهم قفا غيره.",
    "t_verse_number": 16,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 4996,
    "text_uthmani": "يَطُوفُ عَلَيْهِمْ وِلْدَانٌ مُّخَلَّدُونَ",
    "tafseer": "يدور عليهم لخدمتهم وِلْدان لا ينالهم هَرَم ولا فناء.",
    "t_verse_number": 17,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 4997,
    "text_uthmani": "بِأَكْوَابٍ وَأَبَارِيقَ وَكَأْسٍ مِّن مَّعِينٍ",
    "tafseer": "يدورون عليهم بأقداح لا عُرا لها، وأباريق لها عُرًا، وكأس من خمر جارية في الجنة لا تنقطع.",
    "t_verse_number": 18,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 4998,
    "text_uthmani": "لَا يُصَدَّعُونَ عَنْهَا وَلَا يُنزِفُونَ",
    "tafseer": "ليست كخمر الدنيا، فلا يلحق شاربها صداع، ولا ذهاب عقل.",
    "t_verse_number": 19,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 4999,
    "text_uthmani": "وَفَاكِهَةٍ مِّمَّا يَتَخَيَّرُونَ",
    "tafseer": "ويدور عليهم هؤلاء الوِلْدان بفاكهة مما يختارون.",
    "t_verse_number": 20,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5000,
    "text_uthmani": "وَلَحْمِ طَيْرٍ مِّمَّا يَشْتَهُونَ",
    "tafseer": "ويدورون بلحم طير مما تشتهيه أنفسهم.",
    "t_verse_number": 21,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5001,
    "text_uthmani": "وَحُورٌ عِينٌ",
    "tafseer": "ولهم في الجنة نساء واسعات العيون في جمال.",
    "t_verse_number": 22,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5002,
    "text_uthmani": "كَأَمْثَالِ اللُّؤْلُؤِ الْمَكْنُونِ",
    "tafseer": "كأمثال اللؤلؤ المَصُون في صَدَفه.",
    "t_verse_number": 23,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5003,
    "text_uthmani": "جَزَاء بِمَا كَانُوا يَعْمَلُونَ",
    "tafseer": "ثوابًا لهم على ما كانوا يعملونه من الأعمال الصالحات في الدنيا.",
    "t_verse_number": 24,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5004,
    "text_uthmani": "لَا يَسْمَعُونَ فِيهَا لَغْوًا وَلَا تَأْثِيمًا",
    "tafseer": "لا يسمعون في الجنة فاحش كلام، ولا ما يلحق صاحبه إثم.",
    "t_verse_number": 25,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5005,
    "text_uthmani": "إِلَّا قِيلًا سَلَامًا سَلَامًا",
    "tafseer": "لا يسمعون إلا سلام الملائكة عليهم، وسلام بعضهم على بعض.",
    "t_verse_number": 26,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5006,
    "text_uthmani": "وَأَصْحَابُ الْيَمِينِ مَا أَصْحَابُ الْيَمِينِ",
    "tafseer": "وأصحاب اليمين، ما أصحاب اليمين؟ يالعظمة مكانتهم وشأنهم عند الله.",
    "t_verse_number": 27,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5007,
    "text_uthmani": "فِي سِدْرٍ مَّخْضُودٍ",
    "tafseer": "في سِدْر مقطوع الشوك، لا أذى فيه.",
    "t_verse_number": 28,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5008,
    "text_uthmani": "وَطَلْحٍ مَّنضُودٍ",
    "tafseer": "وفي موز متراكم مصفوف بعضه إلى بعض.",
    "t_verse_number": 29,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5009,
    "text_uthmani": "وَظِلٍّ مَّمْدُودٍ",
    "tafseer": "وظل ممدود مستمرّ لا يزول.",
    "t_verse_number": 30,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5010,
    "text_uthmani": "وَمَاء مَّسْكُوبٍ",
    "tafseer": "وماء جار لا يتوقف.",
    "t_verse_number": 31,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5011,
    "text_uthmani": "وَفَاكِهَةٍ كَثِيرَةٍ",
    "tafseer": "وفاكهة كثيرة لا تنحصر.",
    "t_verse_number": 32,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5012,
    "text_uthmani": "لَّا مَقْطُوعَةٍ وَلَا مَمْنُوعَةٍ",
    "tafseer": "لا تنقطع عنهم أبدًا، فليس لها موسم، ولا يحول دونها مانع في أي وقت أرادوها.",
    "t_verse_number": 33,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5013,
    "text_uthmani": "وَفُرُشٍ مَّرْفُوعَةٍ",
    "tafseer": "وفرش مرفوعة عالية توضع على الأسرّة.",
    "t_verse_number": 34,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5014,
    "text_uthmani": "إِنَّا أَنشَأْنَاهُنَّ إِنشَاء",
    "tafseer": "إنا أنشأنا الحور المذكورات إنشاءً غير مألوف.",
    "t_verse_number": 35,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5015,
    "text_uthmani": "فَجَعَلْنَاهُنَّ أَبْكَارًا",
    "tafseer": "فصيّرناهنّ أبكارًا لم يُلْمَسن من قبل.",
    "t_verse_number": 36,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5016,
    "text_uthmani": "عُرُبًا أَتْرَابًا",
    "tafseer": "مُتَحَبِّبات إلى أزواجهنّ، مستويات في السنّ.",
    "t_verse_number": 37,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5017,
    "text_uthmani": "لِّأَصْحَابِ الْيَمِينِ",
    "tafseer": "أنشأناهنّ لأصحاب اليمين الذين يؤخذ بهم ذات اليمين علامة على سعادتهم.",
    "t_verse_number": 38,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5018,
    "text_uthmani": "ثُلَّةٌ مِّنَ الْأَوَّلِينَ",
    "tafseer": "هم جماعة من أمم الأنبياء السابقين.",
    "t_verse_number": 39,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5019,
    "text_uthmani": "وَثُلَّةٌ مِّنَ الْآخِرِينَ",
    "tafseer": "وجماعة من أمة محمد ﷺ وهي آخر الأمم.",
    "t_verse_number": 40,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5020,
    "text_uthmani": "وَأَصْحَابُ الشِّمَالِ مَا أَصْحَابُ الشِّمَالِ",
    "tafseer": "وأصحاب الشمال، ما أصحاب الشمال؟ يا لسوء حالهم ومصيرهم.",
    "t_verse_number": 41,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5021,
    "text_uthmani": "فِي سَمُومٍ وَحَمِيمٍ",
    "tafseer": "في رياح شديدة الحرارة، وفي ماء شديد الحرارة.",
    "t_verse_number": 42,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5022,
    "text_uthmani": "وَظِلٍّ مِّن يَحْمُومٍ",
    "tafseer": "وفي ظل دخان مُسْودّ.",
    "t_verse_number": 43,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5023,
    "text_uthmani": "لَّا بَارِدٍ وَلَا كَرِيمٍ",
    "tafseer": "لا طيّب الهبوب، ولا حسن المنظر.",
    "t_verse_number": 44,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5024,
    "text_uthmani": "إِنَّهُمْ كَانُوا قَبْلَ ذَلِكَ مُتْرَفِينَ",
    "tafseer": "إنهم كانوا قبل ما صاروا إليه من العذاب مُتَنَعِّمين في الدنيا، لا هَمَّ لهم إلا شهواتهم.",
    "t_verse_number": 45,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5025,
    "text_uthmani": "وَكَانُوا يُصِرُّونَ عَلَى الْحِنثِ الْعَظِيمِ",
    "tafseer": "وكانوا يصممون على الكفر بالله وعبادة الأصنام من دونه.",
    "t_verse_number": 46,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5026,
    "text_uthmani": "وَكَانُوا يَقُولُونَ أَئِذَا مِتْنَا وَكُنَّا تُرَابًا وَعِظَامًا أَئِنَّا لَمَبْعُوثُونَ",
    "tafseer": "وكانوا ينكرون البعث فيقولون استهزاءً واستبعادًا له:أإذا متنا وصرنا ترابًا وعظامًا نَخِرة أنبعث بعد ذلك؟!",
    "t_verse_number": 47,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5027,
    "text_uthmani": "أَوَ آبَاؤُنَا الْأَوَّلُونَ",
    "tafseer": "أوَ يبعث آباؤنا الأولون الذين ماتوا قبلنا؟!",
    "t_verse_number": 48,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5028,
    "text_uthmani": "قُلْ إِنَّ الْأَوَّلِينَ وَالْآخِرِينَ",
    "tafseer": "قل - أيها الرسول - لهؤلاء المنكرين للبعث:إن الأولين من الناس والمتأخرين منهم.",
    "t_verse_number": 49,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5029,
    "text_uthmani": "لَمَجْمُوعُونَ إِلَى مِيقَاتِ يَوْمٍ مَّعْلُومٍ",
    "tafseer": "سيُجْمعون يوم القيامة لا محالة للحساب والجزاء.",
    "t_verse_number": 50,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5030,
    "text_uthmani": "ثُمَّ إِنَّكُمْ أَيُّهَا الضَّالُّونَ الْمُكَذِّبُونَ",
    "tafseer": "ثم إنكم - أيها المكذبون بالبعث، الضالون عن الصراط المستقيم -.",
    "t_verse_number": 51,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5031,
    "text_uthmani": "لَآكِلُونَ مِن شَجَرٍ مِّن زَقُّومٍ",
    "tafseer": "لآكلون يوم القيامة من ثمرِ شجرِ الزَّقُّوم، وهو شرّ ثمر وأخبثه.",
    "t_verse_number": 52,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5032,
    "text_uthmani": "فَمَالِؤُونَ مِنْهَا الْبُطُونَ",
    "tafseer": "فمالئون من ذلك الشجر المُرِّ بطونكم الخاوية.",
    "t_verse_number": 53,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5033,
    "text_uthmani": "فَشَارِبُونَ عَلَيْهِ مِنَ الْحَمِيمِ",
    "tafseer": "فشاربون عليه من الماء الحار الشديد الحرارة.",
    "t_verse_number": 54,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5034,
    "text_uthmani": "فَشَارِبُونَ شُرْبَ الْهِيمِ",
    "tafseer": "فمكثرون من شربه كما تكثر الإبل من الشرب بسبب داء الهُيام.",
    "t_verse_number": 55,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5035,
    "text_uthmani": "هَذَا نُزُلُهُمْ يَوْمَ الدِّينِ",
    "tafseer": "هذا المذكور من الطعام المرّ والماء الحارّ هو ضيافتهم التي يُسْتَقبلون بها يوم الجزاء.",
    "t_verse_number": 56,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5036,
    "text_uthmani": "نَحْنُ خَلَقْنَاكُمْ فَلَوْلَا تُصَدِّقُونَ",
    "tafseer": "نحن خلقناكم - أيها المكذبون - بعد أن كنتم عدمًا، فهلَّا صدَّقتم بأنا سنبعثكم أحياء بعد موتكم؟!",
    "t_verse_number": 57,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5037,
    "text_uthmani": "أَفَرَأَيْتُم مَّا تُمْنُونَ",
    "tafseer": "أفرأيتم - أيها الناس - ما تقذفونه من المني في أرحام نسائكم؟!",
    "t_verse_number": 58,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5038,
    "text_uthmani": "أَأَنتُمْ تَخْلُقُونَهُ أَمْ نَحْنُ الْخَالِقُونَ",
    "tafseer": "أأنتم تخلقون ذلك المني، أم نحن الذين نخلقه؟!",
    "t_verse_number": 59,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5039,
    "text_uthmani": "نَحْنُ قَدَّرْنَا بَيْنَكُمُ الْمَوْتَ وَمَا نَحْنُ بِمَسْبُوقِينَ",
    "tafseer": "نحن قدرنا بينكم الموت، فلكل واحد منكم أجل لا يتقدم عليه ولا يتأخر، وما نحن بعاجزين.",
    "t_verse_number": 60,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5040,
    "text_uthmani": "عَلَى أَن نُّبَدِّلَ أَمْثَالَكُمْ وَنُنشِئَكُمْ فِي مَا لَا تَعْلَمُونَ",
    "tafseer": "على أن نبدل ما أنتم عليه من الخلق والتصوير مما علمتموه، وننشئكم فيما لا تعلمونه من الخلق والتصوير.",
    "t_verse_number": 61,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5041,
    "text_uthmani": "وَلَقَدْ عَلِمْتُمُ النَّشْأَةَ الْأُولَى فَلَوْلَا تَذكَّرُونَ",
    "tafseer": "ولقد علمتم كيف خلقناكم الخلق الأول، أفلا تعتبرون وتعلمون أن الذي خلقكم أول مرة قادر على بعثكم بعد موتكم؟!",
    "t_verse_number": 62,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5042,
    "text_uthmani": "أَفَرَأَيْتُم مَّا تَحْرُثُونَ",
    "tafseer": "أفرأيتم ما تلقونه من البذر في الأرض؟!",
    "t_verse_number": 63,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5043,
    "text_uthmani": "أَأَنتُمْ تَزْرَعُونَهُ أَمْ نَحْنُ الزَّارِعُونَ",
    "tafseer": "أأنتم الذين تنبتون ذلك البذر، أم نحن الذين ننبته؟!",
    "t_verse_number": 64,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5044,
    "text_uthmani": "لَوْ نَشَاء لَجَعَلْنَاهُ حُطَامًا فَظَلَلْتُمْ تَفَكَّهُونَ",
    "tafseer": "لو نشاء جعْل ذلك الزرع حطامًا لجعلناه حطامًا بعد أن أوشك على النضج والإدراك، فظللتم بعد ذلك تتعجبون مما أصابه.",
    "t_verse_number": 65,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5045,
    "text_uthmani": "إِنَّا لَمُغْرَمُونَ",
    "tafseer": "تقولون:إنا لمعذبون بخسارة ما أنفقناه.",
    "t_verse_number": 66,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5046,
    "text_uthmani": "بَلْ نَحْنُ مَحْرُومُونَ",
    "tafseer": "بل نحن محرومون من الرزق.",
    "t_verse_number": 67,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5047,
    "text_uthmani": "أَفَرَأَيْتُمُ الْمَاء الَّذِي تَشْرَبُونَ",
    "tafseer": "أفرأيتم الماء الذي تشربون منه إذا عطشتم؟!",
    "t_verse_number": 68,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5048,
    "text_uthmani": "أَأَنتُمْ أَنزَلْتُمُوهُ مِنَ الْمُزْنِ أَمْ نَحْنُ الْمُنزِلُونَ",
    "tafseer": "أأنتم أنزلتموه من السحاب في السماء، أم نحن الذين أنزلناه؟!",
    "t_verse_number": 69,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5049,
    "text_uthmani": "لَوْ نَشَاء جَعَلْنَاهُ أُجَاجًا فَلَوْلَا تَشْكُرُونَ",
    "tafseer": "لو نشاء جعْل ذلك الماء شديد الملوحة لا يُنْتَفع به شربًا ولا سقيًا لجعلناه شديد الملوحة، فلولا تشكرون الله على إنزاله عَذْبًا رحمة بكم.",
    "t_verse_number": 70,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5050,
    "text_uthmani": "أَفَرَأَيْتُمُ النَّارَ الَّتِي تُورُونَ",
    "tafseer": "أفرأيتم النار التي توقدونها لمنافعكم؟!",
    "t_verse_number": 71,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5051,
    "text_uthmani": "أَأَنتُمْ أَنشَأْتُمْ شَجَرَتَهَا أَمْ نَحْنُ الْمُنشِؤُونَ",
    "tafseer": "أأنتم الذين أنشأتم الشجرة التي توقَد منها، أم نحن الذين أنشأناها رفقًا بكم؟!",
    "t_verse_number": 72,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5052,
    "text_uthmani": "نَحْنُ جَعَلْنَاهَا تَذْكِرَةً وَمَتَاعًا لِّلْمُقْوِينَ",
    "tafseer": "نحن صيّرنا هذه النار تذكرة لكم تذكركم بنار الآخرة، وصيّرناها منفعة للمسافرين منكم.",
    "t_verse_number": 73,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5053,
    "text_uthmani": "فَسَبِّحْ بِاسْمِ رَبِّكَ الْعَظِيمِ",
    "tafseer": "فنزِّه - أيها الرسول - ربك العظيم عما لا يليق به.",
    "t_verse_number": 74,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5054,
    "text_uthmani": "فَلَا أُقْسِمُ بِمَوَاقِعِ النُّجُومِ",
    "tafseer": "أقسم الله بأماكن النجوم ومواقعها.",
    "t_verse_number": 75,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5055,
    "text_uthmani": "وَإِنَّهُ لَقَسَمٌ لَّوْ تَعْلَمُونَ عَظِيمٌ",
    "tafseer": "وإن القَسَم بهذه المواقع - لو تعلمون عظمه - لعظيم، لما فيه من الآيات والعبر التي لا تنحصر",
    "t_verse_number": 76,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5056,
    "text_uthmani": "إِنَّهُ لَقُرْآنٌ كَرِيمٌ",
    "tafseer": "إن القرآن المقروء عليكم - أيها الناس - قرآن كريم، لما فيه من المنافع العظيمة.",
    "t_verse_number": 77,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5057,
    "text_uthmani": "فِي كِتَابٍ مَّكْنُونٍ",
    "tafseer": "في كتاب مَصُون عن أعين الناس، وهو اللوح المحفوظ.",
    "t_verse_number": 78,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5058,
    "text_uthmani": "لَّا يَمَسُّهُ إِلَّا الْمُطَهَّرُونَ",
    "tafseer": "لا يمسّه إلا الملائكة المطهَّرون من الذنوب والعيوب.",
    "t_verse_number": 79,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5059,
    "text_uthmani": "تَنزِيلٌ مِّن رَّبِّ الْعَالَمِينَ",
    "tafseer": "مُنَزَّل من رب الخلائق على نبيه محمد ﷺ.",
    "t_verse_number": 80,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5060,
    "text_uthmani": "أَفَبِهَذَا الْحَدِيثِ أَنتُم مُّدْهِنُونَ",
    "tafseer": "أفبهذا الحديث أنتم - أيها المشركون - مكذبون غير مصدقين؟!",
    "t_verse_number": 81,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5061,
    "text_uthmani": "وَتَجْعَلُونَ رِزْقَكُمْ أَنَّكُمْ تُكَذِّبُونَ",
    "tafseer": "وتجعلون شكركم لله على ما رزقكم به من النعم أنكم تكذبون به، فتنسبون المطر إلى النَّوْء، فتقولون:مُطِرنا بنَوْء كذا ونَوْء كذا؟!لما ذكر بعض أدلة البعث أراد أن ينبه على قدرته على الإعادة بالإشارة إلى عجزهم عن دفع الموت، فالذي أمات قادر على أن يحيي.",
    "t_verse_number": 82,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5062,
    "text_uthmani": "فَلَوْلَا إِذَا بَلَغَتِ الْحُلْقُومَ",
    "tafseer": "فهلَّا إذا وصلت الروح الحلقوم.",
    "t_verse_number": 83,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5063,
    "text_uthmani": "وَأَنتُمْ حِينَئِذٍ تَنظُرُونَ",
    "tafseer": "وأنتم في ذلك الوقت تنظرون المُحْتَضِر بين أيديكم.",
    "t_verse_number": 84,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5064,
    "text_uthmani": "وَنَحْنُ أَقْرَبُ إِلَيْهِ مِنكُمْ وَلَكِن لَّا تُبْصِرُونَ",
    "tafseer": "ونحن بعلمنا وقدرتنا وملائكتنا أقرب إلى ميتكم منكم، ولكن لا تشاهدون هؤلاء الملائكة.",
    "t_verse_number": 85,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5065,
    "text_uthmani": "فَلَوْلَا إِن كُنتُمْ غَيْرَ مَدِينِينَ",
    "tafseer": "فهلَّا - إن كنتم، كما تزعمون، غير مبعوثين لمجازاتكم على أعمالكم -",
    "t_verse_number": 86,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5066,
    "text_uthmani": "تَرْجِعُونَهَا إِن كُنتُمْ صَادِقِينَ",
    "tafseer": "ترجعون هذه الروح التي تخرج من ميتكم إن كنتم صادقين؟! ولا تستطيعون ذلك.",
    "t_verse_number": 87,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5067,
    "text_uthmani": "فَأَمَّا إِن كَانَ مِنَ الْمُقَرَّبِينَ",
    "tafseer": "فأما إن كان الميت من السابقين إلى الخيرات.",
    "t_verse_number": 88,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5068,
    "text_uthmani": "فَرَوْحٌ وَرَيْحَانٌ وَجَنَّةُ نَعِيمٍ",
    "tafseer": "فله راحة لا تعب بعدها، ورزق طيب، ورحمة، وله جنة يتنعم فيها بما تشتهيه نفسه.",
    "t_verse_number": 89,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5069,
    "text_uthmani": "وَأَمَّا إِن كَانَ مِنَ أَصْحَابِ الْيَمِينِ",
    "tafseer": "وأما إن كان الميت من أصحاب اليمين فلا تهتمّ لشأنهم، فلهم السلامة والأمن.",
    "t_verse_number": 90,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5070,
    "text_uthmani": "فَسَلَامٌ لَّكَ مِنْ أَصْحَابِ الْيَمِينِ",
    "tafseer": "وأما إن كان الميت من أصحاب اليمين فلا تهتمّ لشأنهم، فلهم السلامة والأمن.",
    "t_verse_number": 91,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5071,
    "text_uthmani": "وَأَمَّا إِن كَانَ مِنَ الْمُكَذِّبِينَ الضَّالِّينَ",
    "tafseer": "وأما إن كان الميت من المكذبين بما جاء به الرسول ﷺ الضالين عن الصراط المستقيم.",
    "t_verse_number": 92,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5072,
    "text_uthmani": "فَنُزُلٌ مِّنْ حَمِيمٍ",
    "tafseer": "فضيافته التي يستقبل بها ماء حارٌّ شديد الحرارة.",
    "t_verse_number": 93,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5073,
    "text_uthmani": "وَتَصْلِيَةُ جَحِيمٍ",
    "tafseer": "وله احتراق بنار الجحيم.",
    "t_verse_number": 94,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5074,
    "text_uthmani": "إِنَّ هَذَا لَهُوَ حَقُّ الْيَقِينِ",
    "tafseer": "إن هذا الذي قصصناه عليك - أيها الرسول - لهو حق اليقين الذي لا مِرْية فيه.",
    "t_verse_number": 95,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  },
  {
    "verse_id": 5075,
    "text_uthmani": "فَسَبِّحْ بِاسْمِ رَبِّكَ الْعَظِيمِ",
    "tafseer": "فنزِّه اسم ربك العظيم، وقدِّسْه عن النقائص.",
    "t_verse_number": 96,
    "t_chapter_id": 56,
    "t_name_arabic": "الواقعة"
  }
]