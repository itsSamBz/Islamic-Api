[
  {
    "verse_id": 6080,
    "text_uthmani": "وَالضُّحَى",
    "tafseer": "أقسم الله بأول النهار.",
    "t_verse_number": 1,
    "t_chapter_id": 93,
    "t_name_arabic": "الضحى"
  },
  {
    "verse_id": 6081,
    "text_uthmani": "وَاللَّيْلِ إِذَا سَجَى",
    "tafseer": "وأقسم بالليل إذا أظلم وسكن الناس فيه عن الحركة.",
    "t_verse_number": 2,
    "t_chapter_id": 93,
    "t_name_arabic": "الضحى"
  },
  {
    "verse_id": 6082,
    "text_uthmani": "مَا وَدَّعَكَ رَبُّكَ وَمَا قَلَى",
    "tafseer": "ما تركك - أيها الرسول - ربك، وما أبغضك، كما يقول المشركون لما فَتَر الوحي.",
    "t_verse_number": 3,
    "t_chapter_id": 93,
    "t_name_arabic": "الضحى"
  },
  {
    "verse_id": 6083,
    "text_uthmani": "وَلَلْآخِرَةُ خَيْرٌ لَّكَ مِنَ الْأُولَى",
    "tafseer": "ولَلدار الآخرة خير لك من الدنيا، لما فيها من النعيم الدائم الذي لا ينقطع.",
    "t_verse_number": 4,
    "t_chapter_id": 93,
    "t_name_arabic": "الضحى"
  },
  {
    "verse_id": 6084,
    "text_uthmani": "وَلَسَوْفَ يُعْطِيكَ رَبُّكَ فَتَرْضَى",
    "tafseer": "ولسوف يعطيك من الثواب الجزيل لك ولأمتك حتى ترضى بما أعطاك وأعطى أمتك.",
    "t_verse_number": 5,
    "t_chapter_id": 93,
    "t_name_arabic": "الضحى"
  },
  {
    "verse_id": 6085,
    "text_uthmani": "أَلَمْ يَجِدْكَ يَتِيمًا فَآوَى",
    "tafseer": "لقد وجدك صغيرًا قد مات عنك أبوك، فجعل لك مأوى، حيث عطف عليك جدُّك عبد المطلب، ثم عمّك أبو طالب.",
    "t_verse_number": 6,
    "t_chapter_id": 93,
    "t_name_arabic": "الضحى"
  },
  {
    "verse_id": 6086,
    "text_uthmani": "وَوَجَدَكَ ضَالًّا فَهَدَى",
    "tafseer": "ووجدك لا تدري ما الكتاب ولا الإيمان، فعلّمك من ذلك ما لم تكن تعلم.",
    "t_verse_number": 7,
    "t_chapter_id": 93,
    "t_name_arabic": "الضحى"
  },
  {
    "verse_id": 6087,
    "text_uthmani": "وَوَجَدَكَ عَائِلًا فَأَغْنَى",
    "tafseer": "ووجدك فقيرًا فأغناك.",
    "t_verse_number": 8,
    "t_chapter_id": 93,
    "t_name_arabic": "الضحى"
  },
  {
    "verse_id": 6088,
    "text_uthmani": "فَأَمَّا الْيَتِيمَ فَلَا تَقْهَرْ",
    "tafseer": "فلا تُسِئ معاملة من فقد أباه في الصغر، ولا تذلّه.",
    "t_verse_number": 9,
    "t_chapter_id": 93,
    "t_name_arabic": "الضحى"
  },
  {
    "verse_id": 6089,
    "text_uthmani": "وَأَمَّا السَّائِلَ فَلَا تَنْهَرْ",
    "tafseer": "ولا تزجر السائل المحتاج.",
    "t_verse_number": 10,
    "t_chapter_id": 93,
    "t_name_arabic": "الضحى"
  },
  {
    "verse_id": 6090,
    "text_uthmani": "وَأَمَّا بِنِعْمَةِ رَبِّكَ فَحَدِّثْ",
    "tafseer": "واشكر نِعَم الله عليك وتحدث بها.",
    "t_verse_number": 11,
    "t_chapter_id": 93,
    "t_name_arabic": "الضحى"
  }
]