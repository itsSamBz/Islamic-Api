[
  {
    "verse_id": 6231,
    "text_uthmani": "قُلْ أَعُوذُ بِرَبِّ النَّاسِ",
    "tafseer": "قل - أيها الرسول -:أعتصم برب الناس، وأستجير به.",
    "t_verse_number": 1,
    "t_chapter_id": 114,
    "t_name_arabic": "الناس"
  },
  {
    "verse_id": 6232,
    "text_uthmani": "مَلِكِ النَّاسِ",
    "tafseer": "ملك الناس، يتصرّف فيهم بما يشاء، لا ملك لهم غيره.",
    "t_verse_number": 2,
    "t_chapter_id": 114,
    "t_name_arabic": "الناس"
  },
  {
    "verse_id": 6233,
    "text_uthmani": "إِلَهِ النَّاسِ",
    "tafseer": "معبودهم بحقّ، لا معبود لهم بحق غيره.",
    "t_verse_number": 3,
    "t_chapter_id": 114,
    "t_name_arabic": "الناس"
  },
  {
    "verse_id": 6234,
    "text_uthmani": "مِن شَرِّ الْوَسْوَاسِ الْخَنَّاسِ",
    "tafseer": "من شرّ الشيطان الذي يلقي وسوسته إلى الإنسان إذا غفل عن ذكر الله، ويتأخر عنه إذا ذكره.",
    "t_verse_number": 4,
    "t_chapter_id": 114,
    "t_name_arabic": "الناس"
  },
  {
    "verse_id": 6235,
    "text_uthmani": "الَّذِي يُوَسْوِسُ فِي صُدُورِ النَّاسِ",
    "tafseer": "يلقي بوسوسته إلى قلوب الناس.",
    "t_verse_number": 5,
    "t_chapter_id": 114,
    "t_name_arabic": "الناس"
  },
  {
    "verse_id": 6236,
    "text_uthmani": "مِنَ الْجِنَّةِ وَ النَّاسِ",
    "tafseer": "وهو يكون من الإنس كما يكون من الجن.",
    "t_verse_number": 6,
    "t_chapter_id": 114,
    "t_name_arabic": "الناس"
  }
]