[
  {
    "verse_id": 5830,
    "text_uthmani": "إِذَا السَّمَاء انفَطَرَتْ",
    "tafseer": "إذا السماء تشققت لنزول الملائكة منها.",
    "t_verse_number": 1,
    "t_chapter_id": 82,
    "t_name_arabic": "الإنفطار"
  },
  {
    "verse_id": 5831,
    "text_uthmani": "وَإِذَا الْكَوَاكِبُ انتَثَرَتْ",
    "tafseer": "وإذا الكواكب تساقطت متناثرة.",
    "t_verse_number": 2,
    "t_chapter_id": 82,
    "t_name_arabic": "الإنفطار"
  },
  {
    "verse_id": 5832,
    "text_uthmani": "وَإِذَا الْبِحَارُ فُجِّرَتْ",
    "tafseer": "وإذا البحار فتح بعضها على بعض فاختلطت.",
    "t_verse_number": 3,
    "t_chapter_id": 82,
    "t_name_arabic": "الإنفطار"
  },
  {
    "verse_id": 5833,
    "text_uthmani": "وَإِذَا الْقُبُورُ بُعْثِرَتْ",
    "tafseer": "وإذا القبور قُلِب ترابها لبعث من فيها من الأموات.",
    "t_verse_number": 4,
    "t_chapter_id": 82,
    "t_name_arabic": "الإنفطار"
  },
  {
    "verse_id": 5834,
    "text_uthmani": "عَلِمَتْ نَفْسٌ مَّا قَدَّمَتْ وَأَخَّرَتْ",
    "tafseer": "عند ذلك تعلم كل نفس ما قدمت من عمل، وما أخَّرت منه فلم تعمله.",
    "t_verse_number": 5,
    "t_chapter_id": 82,
    "t_name_arabic": "الإنفطار"
  },
  {
    "verse_id": 5835,
    "text_uthmani": "يَا أَيُّهَا الْإِنسَانُ مَا غَرَّكَ بِرَبِّكَ الْكَرِيمِ",
    "tafseer": "يا أيها الإنسان الكافر بربك، ما الذي جعلك تخالف أمر ربك حين أمهلك ولم يعاجلك بالعقوبة تكرّمًا منه؟!",
    "t_verse_number": 6,
    "t_chapter_id": 82,
    "t_name_arabic": "الإنفطار"
  },
  {
    "verse_id": 5836,
    "text_uthmani": "الَّذِي خَلَقَكَ فَسَوَّاكَ فَعَدَلَكَ",
    "tafseer": "الذي أوجدك بعد أن كنت عدمًا، وجعلك سويّ الأعضاء معتدلها.",
    "t_verse_number": 7,
    "t_chapter_id": 82,
    "t_name_arabic": "الإنفطار"
  },
  {
    "verse_id": 5837,
    "text_uthmani": "فِي أَيِّ صُورَةٍ مَّا شَاء رَكَّبَكَ",
    "tafseer": "في أي صورة شاء أن يخلقك خلقك، وقد أنعم عليك إذ لم يخلقك في صورة حمار ولا قرد ولا كلب ولا غيرها.",
    "t_verse_number": 8,
    "t_chapter_id": 82,
    "t_name_arabic": "الإنفطار"
  },
  {
    "verse_id": 5838,
    "text_uthmani": "كَلَّا بَلْ تُكَذِّبُونَ بِالدِّينِ",
    "tafseer": "ليس الأمر كما تصورتم - أيها المغترون - بل أنتم تكذبون بيوم الجزاء فلا تعملون له.",
    "t_verse_number": 9,
    "t_chapter_id": 82,
    "t_name_arabic": "الإنفطار"
  },
  {
    "verse_id": 5839,
    "text_uthmani": "وَإِنَّ عَلَيْكُمْ لَحَافِظِينَ",
    "tafseer": "وإن عليكم ملائكة يحفظون أعمالكم.",
    "t_verse_number": 10,
    "t_chapter_id": 82,
    "t_name_arabic": "الإنفطار"
  },
  {
    "verse_id": 5840,
    "text_uthmani": "كِرَامًا كَاتِبِينَ",
    "tafseer": "كرامًا عند الله، كاتبين يكتبون أعمالكم.",
    "t_verse_number": 11,
    "t_chapter_id": 82,
    "t_name_arabic": "الإنفطار"
  },
  {
    "verse_id": 5841,
    "text_uthmani": "يَعْلَمُونَ مَا تَفْعَلُونَ",
    "tafseer": "يعلمون ما تفعلون من فعل فيكتبونه.",
    "t_verse_number": 12,
    "t_chapter_id": 82,
    "t_name_arabic": "الإنفطار"
  },
  {
    "verse_id": 5842,
    "text_uthmani": "إِنَّ الْأَبْرَارَ لَفِي نَعِيمٍ",
    "tafseer": "إن كثيري فعل الخير والطاعة لفي نعيم دائم يوم القيامة.",
    "t_verse_number": 13,
    "t_chapter_id": 82,
    "t_name_arabic": "الإنفطار"
  },
  {
    "verse_id": 5843,
    "text_uthmani": "وَإِنَّ الْفُجَّارَ لَفِي جَحِيمٍ",
    "tafseer": "وإن أصحاب الفجور لفي نار تستعر عليهم.",
    "t_verse_number": 14,
    "t_chapter_id": 82,
    "t_name_arabic": "الإنفطار"
  },
  {
    "verse_id": 5844,
    "text_uthmani": "يَصْلَوْنَهَا يَوْمَ الدِّينِ",
    "tafseer": "يدخلونها يوم الجزاء يعانون حرّها.",
    "t_verse_number": 15,
    "t_chapter_id": 82,
    "t_name_arabic": "الإنفطار"
  },
  {
    "verse_id": 5845,
    "text_uthmani": "وَمَا هُمْ عَنْهَا بِغَائِبِينَ",
    "tafseer": "وليسوا عنها بغائبين أبدًا، بل هم خالدون فيها.",
    "t_verse_number": 16,
    "t_chapter_id": 82,
    "t_name_arabic": "الإنفطار"
  },
  {
    "verse_id": 5846,
    "text_uthmani": "وَمَا أَدْرَاكَ مَا يَوْمُ الدِّينِ",
    "tafseer": "وما أعلمك - أيها الرسول - ما يوم الدين؟!",
    "t_verse_number": 17,
    "t_chapter_id": 82,
    "t_name_arabic": "الإنفطار"
  },
  {
    "verse_id": 5847,
    "text_uthmani": "ثُمَّ مَا أَدْرَاكَ مَا يَوْمُ الدِّينِ",
    "tafseer": "ثم ما أعلمك ما يوم الدين؟!",
    "t_verse_number": 18,
    "t_chapter_id": 82,
    "t_name_arabic": "الإنفطار"
  },
  {
    "verse_id": 5848,
    "text_uthmani": "يَوْمَ لَا تَمْلِكُ نَفْسٌ لِّنَفْسٍ شَيْئًا وَالْأَمْرُ يَوْمَئِذٍ لِلَّهِ",
    "tafseer": "يوم لا يستطيع أحد أن ينفع أحدًا، والأمر كله في ذلك اليوم لله وحده، يتصرّف بما يشاء، لا لأحد غيره.",
    "t_verse_number": 19,
    "t_chapter_id": 82,
    "t_name_arabic": "الإنفطار"
  }
]