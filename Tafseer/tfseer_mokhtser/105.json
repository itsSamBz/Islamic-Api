[
  {
    "verse_id": 6189,
    "text_uthmani": "أَلَمْ تَرَ كَيْفَ فَعَلَ رَبُّكَ بِأَصْحَابِ الْفِيلِ",
    "tafseer": "ألم تعلم - أيها الرسول - كيف فعل ربك بأبْرَهَة وأصحابه أصحاب الفيل حين أرادوا هدم الكعبة؟!",
    "t_verse_number": 1,
    "t_chapter_id": 105,
    "t_name_arabic": "الفيل"
  },
  {
    "verse_id": 6190,
    "text_uthmani": "أَلَمْ يَجْعَلْ كَيْدَهُمْ فِي تَضْلِيلٍ",
    "tafseer": "لقد جعل الله تدبيرهم السيئ لهدمها في ضياع، فما نالوا ما تمنّوه من صرف الناس عن الكعبة، وما نالوا منها شيئًا.",
    "t_verse_number": 2,
    "t_chapter_id": 105,
    "t_name_arabic": "الفيل"
  },
  {
    "verse_id": 6191,
    "text_uthmani": "وَأَرْسَلَ عَلَيْهِمْ طَيْرًا أَبَابِيلَ",
    "tafseer": "وبَعَث عليهم طيرًا أتتهم جماعات جماعات.",
    "t_verse_number": 3,
    "t_chapter_id": 105,
    "t_name_arabic": "الفيل"
  },
  {
    "verse_id": 6192,
    "text_uthmani": "تَرْمِيهِم بِحِجَارَةٍ مِّن سِجِّيلٍ",
    "tafseer": "ترميهم بحجارة من طين مُتَحَجِّر.",
    "t_verse_number": 4,
    "t_chapter_id": 105,
    "t_name_arabic": "الفيل"
  },
  {
    "verse_id": 6193,
    "text_uthmani": "فَجَعَلَهُمْ كَعَصْفٍ مَّأْكُولٍ",
    "tafseer": "فجعلهم الله كورق زرع أكلته الدوابّ وداسته.",
    "t_verse_number": 5,
    "t_chapter_id": 105,
    "t_name_arabic": "الفيل"
  }
