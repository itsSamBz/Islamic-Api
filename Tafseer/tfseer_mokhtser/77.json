[
  {
    "verse_id": 5623,
    "text_uthmani": "وَالْمُرْسَلَاتِ عُرْفًا",
    "tafseer": "أقسم الله بالرياح المتتابعة مثل عُرف الفرس.",
    "t_verse_number": 1,
    "t_chapter_id": 77,
    "t_name_arabic": "المرسلات"
  },
  {
    "verse_id": 5624,
    "text_uthmani": "فَالْعَاصِفَاتِ عَصْفًا",
    "tafseer": "وأقسم بالرياح الشديدة الهبوب.",
    "t_verse_number": 2,
    "t_chapter_id": 77,
    "t_name_arabic": "المرسلات"
  },
  {
    "verse_id": 5625,
    "text_uthmani": "وَالنَّاشِرَاتِ نَشْرًا",
    "tafseer": "وأقسم بالرياح التي تنشر المطر.",
    "t_verse_number": 3,
    "t_chapter_id": 77,
    "t_name_arabic": "المرسلات"
  },
  {
    "verse_id": 5626,
    "text_uthmani": "فَالْفَارِقَاتِ فَرْقًا",
    "tafseer": "وأقسم بالملائكة التي تنزل بما يفرق بين الحق والباطل.",
    "t_verse_number": 4,
    "t_chapter_id": 77,
    "t_name_arabic": "المرسلات"
  },
  {
    "verse_id": 5627,
    "text_uthmani": "فَالْمُلْقِيَاتِ ذِكْرًا",
    "tafseer": "وأقسم بالملائكة التي تنزل بالوحي.",
    "t_verse_number": 5,
    "t_chapter_id": 77,
    "t_name_arabic": "المرسلات"
  },
  {
    "verse_id": 5628,
    "text_uthmani": "عُذْرًا أَوْ نُذْرًا",
    "tafseer": "تنزل بالوحي إعذارًا من الله إلى الناس، وإنذارًا للناس من عذاب الله.",
    "t_verse_number": 6,
    "t_chapter_id": 77,
    "t_name_arabic": "المرسلات"
  },
  {
    "verse_id": 5629,
    "text_uthmani": "إِنَّمَا تُوعَدُونَ لَوَاقِعٌ",
    "tafseer": "إن الذي توعدون به من البعث والحساب والجزاء لواقع لا محالة.",
    "t_verse_number": 7,
    "t_chapter_id": 77,
    "t_name_arabic": "المرسلات"
  },
  {
    "verse_id": 5630,
    "text_uthmani": "فَإِذَا النُّجُومُ طُمِسَتْ",
    "tafseer": "فإذا النجوم مُحِيَ نورها وذهب ضوؤها.",
    "t_verse_number": 8,
    "t_chapter_id": 77,
    "t_name_arabic": "المرسلات"
  },
  {
    "verse_id": 5631,
    "text_uthmani": "وَإِذَا السَّمَاء فُرِجَتْ",
    "tafseer": "وإذا السماء شُقَّت لتنزّل الملائكة منها.",
    "t_verse_number": 9,
    "t_chapter_id": 77,
    "t_name_arabic": "المرسلات"
  },
  {
    "verse_id": 5632,
    "text_uthmani": "وَإِذَا الْجِبَالُ نُسِفَتْ",
    "tafseer": "وإذا الجبال اقتُلِعت من مكانها فَفُتِّتَتْ حتى تصير هباءً.",
    "t_verse_number": 10,
    "t_chapter_id": 77,
    "t_name_arabic": "المرسلات"
  },
  {
    "verse_id": 5633,
    "text_uthmani": "وَإِذَا الرُّسُلُ أُقِّتَتْ",
    "tafseer": "وإذا الرسل جُمِعت لوقت محدد.",
    "t_verse_number": 11,
    "t_chapter_id": 77,
    "t_name_arabic": "المرسلات"
  },
  {
    "verse_id": 5634,
    "text_uthmani": "لِأَيِّ يَوْمٍ أُجِّلَتْ",
    "tafseer": "ليوم عظيم أُجِّلت للشهادة على أممها.",
    "t_verse_number": 12,
    "t_chapter_id": 77,
    "t_name_arabic": "المرسلات"
  },
  {
    "verse_id": 5635,
    "text_uthmani": "لِيَوْمِ الْفَصْلِ",
    "tafseer": "ليوم الفصل بين العباد، فيتبين المحق من المبطل، والسعيد من الشقي.",
    "t_verse_number": 13,
    "t_chapter_id": 77,
    "t_name_arabic": "المرسلات"
  },
  {
    "verse_id": 5636,
    "text_uthmani": "وَمَا أَدْرَاكَ مَا يَوْمُ الْفَصْلِ",
    "tafseer": "وما أعلمك - أيها الرسول - ما يوم الفصل؟!",
    "t_verse_number": 14,
    "t_chapter_id": 77,
    "t_name_arabic": "المرسلات"
  },
  {
    "verse_id": 5637,
    "text_uthmani": "وَيْلٌ يَوْمَئِذٍ لِّلْمُكَذِّبِينَ",
    "tafseer": "هلاك وعذاب وخسران في ذلك اليوم للمكذبين الذين يكذبون بما جاءت به الرسل من عند الله.",
    "t_verse_number": 15,
    "t_chapter_id": 77,
    "t_name_arabic": "المرسلات"
  },
  {
    "verse_id": 5638,
    "text_uthmani": "أَلَمْ نُهْلِكِ الْأَوَّلِينَ",
    "tafseer": "ألم نهلك الأمم السابقة لما كفرت بالله وكذبت رسلها؟!",
    "t_verse_number": 16,
    "t_chapter_id": 77,
    "t_name_arabic": "المرسلات"
  },
  {
    "verse_id": 5639,
    "text_uthmani": "ثُمَّ نُتْبِعُهُمُ الْآخِرِينَ",
    "tafseer": "ثم نتبعهم المكذبين من المتأخرين، فنهلكهم كما أهلكناهم.",
    "t_verse_number": 17,
    "t_chapter_id": 77,
    "t_name_arabic": "المرسلات"
  },
  {
    "verse_id": 5640,
    "text_uthmani": "كَذَلِكَ نَفْعَلُ بِالْمُجْرِمِينَ",
    "tafseer": "مثل الإهلاك لتلك الأمم نهلك المجرمين المكذبين بما جاء به محمد ﷺ.",
    "t_verse_number": 18,
    "t_chapter_id": 77,
    "t_name_arabic": "المرسلات"
  },
  {
    "verse_id": 5641,
    "text_uthmani": "وَيْلٌ يَوْمَئِذٍ لِّلْمُكَذِّبِينَ",
    "tafseer": "هلاك وعذاب وخسران في ذلك اليوم للمكذبين بوعيد الله بالعقاب للمجرمين.",
    "t_verse_number": 19,
    "t_chapter_id": 77,
    "t_name_arabic": "المرسلات"
  },
  {
    "verse_id": 5642,
    "text_uthmani": "أَلَمْ نَخْلُقكُّم مِّن مَّاء مَّهِينٍ",
    "tafseer": "ألم نخلقكم - أيها الناس - من ماء حقير قليل وهو النُّطْفة.",
    "t_verse_number": 20,
    "t_chapter_id": 77,
    "t_name_arabic": "المرسلات"
  },
  {
    "verse_id": 5643,
    "text_uthmani": "فَجَعَلْنَاهُ فِي قَرَارٍ مَّكِينٍ",
    "tafseer": "فجعلنا ذلك الماء المَهِين في مكان مَحْروز وهو رحم المرأة.",
    "t_verse_number": 21,
    "t_chapter_id": 77,
    "t_name_arabic": "المرسلات"
  },
  {
    "verse_id": 5644,
    "text_uthmani": "إِلَى قَدَرٍ مَّعْلُومٍ",
    "tafseer": "إلى مُدّة معلومة هي مدّة الحمل.",
    "t_verse_number": 22,
    "t_chapter_id": 77,
    "t_name_arabic": "المرسلات"
  },
  {
    "verse_id": 5645,
    "text_uthmani": "فَقَدَرْنَا فَنِعْمَ الْقَادِرُونَ",
    "tafseer": "فقدَّرنا صفة المولود وقَدْرَه ولونه وغير ذلك، فنعم القادرون لذلك كله نحن.",
    "t_verse_number": 23,
    "t_chapter_id": 77,
    "t_name_arabic": "المرسلات"
  },
  {
    "verse_id": 5646,
    "text_uthmani": "وَيْلٌ يَوْمَئِذٍ لِّلْمُكَذِّبِينَ",
    "tafseer": "هلاك وعذاب وخسران في ذلك اليوم للمكذبين بقدرة الله.",
    "t_verse_number": 24,
    "t_chapter_id": 77,
    "t_name_arabic": "المرسلات"
  },
  {
    "verse_id": 5647,
    "text_uthmani": "أَلَمْ نَجْعَلِ الْأَرْضَ كِفَاتًا",
    "tafseer": "ألم نجعل الأرض تضمّ الناس جميعًا.",
    "t_verse_number": 25,
    "t_chapter_id": 77,
    "t_name_arabic": "المرسلات"
  },
  {
    "verse_id": 5648,
    "text_uthmani": "أَحْيَاء وَأَمْوَاتًا",
    "tafseer": "تضمّ أحياءهم بالسكن عليها وعمارتها، وأمواتهم بالدفن فيها.",
    "t_verse_number": 26,
    "t_chapter_id": 77,
    "t_name_arabic": "المرسلات"
  },
  {
    "verse_id": 5649,
    "text_uthmani": "وَجَعَلْنَا فِيهَا رَوَاسِيَ شَامِخَاتٍ وَأَسْقَيْنَاكُم مَّاء فُرَاتًا",
    "tafseer": "وجعلنا فيها جبالًا ثوابتَ، تمنعها من الاضطراب، عاليات، وأسقيناكم - أيها الناس - ماءً عذبًا، فمن خلق ذلك ليس عاجزًا عن بعثكم.",
    "t_verse_number": 27,
    "t_chapter_id": 77,
    "t_name_arabic": "المرسلات"
  },
  {
    "verse_id": 5650,
    "text_uthmani": "وَيْلٌ يوْمَئِذٍ لِّلْمُكَذِّبِينَ",
    "tafseer": "هلاك وعذاب وخسران في ذلك اليوم للمكذبين بنعم الله عليهم.",
    "t_verse_number": 28,
    "t_chapter_id": 77,
    "t_name_arabic": "المرسلات"
  },
  {
    "verse_id": 5651,
    "text_uthmani": "انطَلِقُوا إِلَى مَا كُنتُم بِهِ تُكَذِّبُونَ",
    "tafseer": "ويقال للمكذبين بما جاءت به رسلهم:سيروا - أيها المكذبون - إلى ما كنتم به تكذبون من العذاب.",
    "t_verse_number": 29,
    "t_chapter_id": 77,
    "t_name_arabic": "المرسلات"
  },
  {
    "verse_id": 5652,
    "text_uthmani": "انطَلِقُوا إِلَى ظِلٍّ ذِي ثَلَاثِ شُعَبٍ",
    "tafseer": "سيروا إلى ظل من دخان النار مفترق ثلاث فرق.",
    "t_verse_number": 30,
    "t_chapter_id": 77,
    "t_name_arabic": "المرسلات"
  },
  {
    "verse_id": 5653,
    "text_uthmani": "لَا ظَلِيلٍ وَلَا يُغْنِي مِنَ اللَّهَبِ",
    "tafseer": "ليس فيه برد الظلال، ولا يمنع لهيب النار وحرّها أن ينفذ إليكم.",
    "t_verse_number": 31,
    "t_chapter_id": 77,
    "t_name_arabic": "المرسلات"
  },
  {
    "verse_id": 5654,
    "text_uthmani": "إِنَّهَا تَرْمِي بِشَرَرٍ كَالْقَصْرِ",
    "tafseer": "إن النار تقذف بشرارات، كل شرارة مثل القصر في عظمها.",
    "t_verse_number": 32,
    "t_chapter_id": 77,
    "t_name_arabic": "المرسلات"
  },
  {
    "verse_id": 5655,
    "text_uthmani": "كَأَنَّهُ جِمَالَتٌ صُفْرٌ",
    "tafseer": "كأن الشرارات التي تقذف بها في سوادها وضخامتها جِمال سود.",
    "t_verse_number": 33,
    "t_chapter_id": 77,
    "t_name_arabic": "المرسلات"
  },
  {
    "verse_id": 5656,
    "text_uthmani": "وَيْلٌ يَوْمَئِذٍ لِّلْمُكَذِّبِينَ",
    "tafseer": "هلاك وعذاب وخسران في ذلك اليوم للمكذبين بعذاب الله.",
    "t_verse_number": 34,
    "t_chapter_id": 77,
    "t_name_arabic": "المرسلات"
  },
  {
    "verse_id": 5657,
    "text_uthmani": "هَذَا يَوْمُ لَا يَنطِقُونَ",
    "tafseer": "هذا يوم لا يتكلمون فيه بشيء.",
    "t_verse_number": 35,
    "t_chapter_id": 77,
    "t_name_arabic": "المرسلات"
  },
  {
    "verse_id": 5658,
    "text_uthmani": "وَلَا يُؤْذَنُ لَهُمْ فَيَعْتَذِرُونَ",
    "tafseer": "ولا يُؤْذَن لهم أن يعتذروا إلى ربهم من كفرهم وسيئاتهم، فيعتذرون إليه.",
    "t_verse_number": 36,
    "t_chapter_id": 77,
    "t_name_arabic": "المرسلات"
  },
  {
    "verse_id": 5659,
    "text_uthmani": "وَيْلٌ يَوْمَئِذٍ لِّلْمُكَذِّبِينَ",
    "tafseer": "هلاك وعذاب وخسران في ذلك اليوم للمكذبين بأخبار هذا اليوم.",
    "t_verse_number": 37,
    "t_chapter_id": 77,
    "t_name_arabic": "المرسلات"
  },
  {
    "verse_id": 5660,
    "text_uthmani": "هَذَا يَوْمُ الْفَصْلِ جَمَعْنَاكُمْ وَالْأَوَّلِينَ",
    "tafseer": "هذا يوم الفصل بين الخلائق، جمعناكم والأمم السابقة في صعيد واحد.",
    "t_verse_number": 38,
    "t_chapter_id": 77,
    "t_name_arabic": "المرسلات"
  },
  {
    "verse_id": 5661,
    "text_uthmani": "فَإِن كَانَ لَكُمْ كَيْدٌ فَكِيدُونِ",
    "tafseer": "فإن كانت لكم حيلة تحتالون بها للنجاة من عذاب الله فاحتالوا عليّ.",
    "t_verse_number": 39,
    "t_chapter_id": 77,
    "t_name_arabic": "المرسلات"
  },
  {
    "verse_id": 5662,
    "text_uthmani": "وَيْلٌ يَوْمَئِذٍ لِّلْمُكَذِّبِينَ",
    "tafseer": "هلاك وعذاب وخسران في ذلك اليوم للمكذبين بيوم الفصل.",
    "t_verse_number": 40,
    "t_chapter_id": 77,
    "t_name_arabic": "المرسلات"
  },
  {
    "verse_id": 5663,
    "text_uthmani": "إِنَّ الْمُتَّقِينَ فِي ظِلَالٍ وَعُيُونٍ",
    "tafseer": "إن المتقين لربهم بامتثال أوامره واجتناب نواهيه، في ظلال أشجار الجنة الوارفة، وعيون الماء العذبة الجارية.",
    "t_verse_number": 41,
    "t_chapter_id": 77,
    "t_name_arabic": "المرسلات"
  },
  {
    "verse_id": 5664,
    "text_uthmani": "وَفَوَاكِهَ مِمَّا يَشْتَهُونَ",
    "tafseer": "وفواكه مما يشتهون أكله.",
    "t_verse_number": 42,
    "t_chapter_id": 77,
    "t_name_arabic": "المرسلات"
  },
  {
    "verse_id": 5665,
    "text_uthmani": "كُلُوا وَاشْرَبُوا هَنِيئًا بِمَا كُنتُمْ تَعْمَلُونَ",
    "tafseer": "ويقال لهم:كلوا من الطيبات، واشربوا شرابًا هنيئًا لا مُنَغِّص فيه، بما كنتم تعملون في الدنيا من الأعمال الصالحات.",
    "t_verse_number": 43,
    "t_chapter_id": 77,
    "t_name_arabic": "المرسلات"
  },
  {
    "verse_id": 5666,
    "text_uthmani": "إِنَّا كَذَلِكَ نَجْزِي الْمُحْسِنينَ",
    "tafseer": "إنا مثل هذا الجزاء الذي جزيناكم به نجزي المحسنين لأعمالهم.",
    "t_verse_number": 44,
    "t_chapter_id": 77,
    "t_name_arabic": "المرسلات"
  },
  {
    "verse_id": 5667,
    "text_uthmani": "وَيْلٌ يَوْمَئِذٍ لِّلْمُكَذِّبِينَ",
    "tafseer": "هلاك وعذاب وخسران في ذلك اليوم للمكذبين بما أعد الله للمتقين.",
    "t_verse_number": 45,
    "t_chapter_id": 77,
    "t_name_arabic": "المرسلات"
  },
  {
    "verse_id": 5668,
    "text_uthmani": "كُلُوا وَتَمَتَّعُوا قَلِيلًا إِنَّكُم مُّجْرِمُونَ",
    "tafseer": "ويقال للمكذبين:كلوا وتمتعوا بملذات الحياة وقتًا قليلًا في الدنيا، إنكم بكفركم بالله وتكذيبكم رسله مجرمون",
    "t_verse_number": 46,
    "t_chapter_id": 77,
    "t_name_arabic": "المرسلات"
  },
  {
    "verse_id": 5669,
    "text_uthmani": "وَيْلٌ يَوْمَئِذٍ لِّلْمُكَذِّبِينَ",
    "tafseer": "هلاك وعذاب وخسران في ذلك اليوم للمكذبين بجزائهم يوم الدين.",
    "t_verse_number": 47,
    "t_chapter_id": 77,
    "t_name_arabic": "المرسلات"
  },
  {
    "verse_id": 5670,
    "text_uthmani": "وَإِذَا قِيلَ لَهُمُ ارْكَعُوا لَا يَرْكَعُونَ",
    "tafseer": "وإذا قيل لهؤلاء المكذبين:صلّوا لله لا يصلّون له.",
    "t_verse_number": 48,
    "t_chapter_id": 77,
    "t_name_arabic": "المرسلات"
  },
  {
    "verse_id": 5671,
    "text_uthmani": "وَيْلٌ يَوْمَئِذٍ لِّلْمُكَذِّبِينَ",
    "tafseer": "هلاك وعذاب وخسران في ذلك اليوم للمكذبين الذين يكذبون بما جاءت به الرسل من عند الله.",
    "t_verse_number": 49,
    "t_chapter_id": 77,
    "t_name_arabic": "المرسلات"
  },
  {
    "verse_id": 5672,
