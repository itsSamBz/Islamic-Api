[
  {
    "verse_id": 4785,
    "elements": [
      {
        "text_uthmani": "وَالنَّجْمِ إِذَا هَوَى",
        "verse_number": 1,
        "chapter_id": 53,
        "name_arabic": "النجم"
      }
    ]
  },
  {
    "verse_id": 4786,
    "elements": [
      {
        "text_uthmani": "مَا ضَلَّ صَاحِبُكُمْ وَمَا غَوَى",
        "verse_number": 2,
        "chapter_id": 53,
        "name_arabic": "النجم"
      }
    ]
  },
  {
    "verse_id": 4787,
    "elements": [
      {
        "text_uthmani": "وَمَا يَنطِقُ عَنِ الْهَوَى",
        "verse_number": 3,
        "chapter_id": 53,
        "name_arabic": "النجم"
      }
    ]
  },
  {
    "verse_id": 4788,
    "elements": [
      {
        "text_uthmani": "إِنْ هُوَ إِلَّا وَحْيٌ يُوحَى",
        "verse_number": 4,
        "chapter_id": 53,
        "name_arabic": "النجم"
      }
    ]
  },
  {
    "verse_id": 4789,
    "elements": [
      {
        "text_uthmani": "عَلَّمَهُ شَدِيدُ الْقُوَى",
        "verse_number": 5,
        "chapter_id": 53,
        "name_arabic": "النجم"
      }
    ]
  },
  {
    "verse_id": 4790,
    "elements": [
      {
        "text_uthmani": "ذُو مِرَّةٍ فَاسْتَوَى",
        "verse_number": 6,
        "chapter_id": 53,
        "name_arabic": "النجم"
      }
    ]
  },
  {
    "verse_id": 4791,
    "elements": [
      {
        "text_uthmani": "وَهُوَ بِالْأُفُقِ الْأَعْلَى",
        "verse_number": 7,
        "chapter_id": 53,
        "name_arabic": "النجم"
      }
    ]
  },
  {
    "verse_id": 4792,
    "elements": [
      {
        "text_uthmani": "ثُمَّ دَنَا فَتَدَلَّى",
        "verse_number": 8,
        "chapter_id": 53,
        "name_arabic": "النجم"
      }
    ]
  },
  {
    "verse_id": 4793,
    "elements": [
      {
        "text_uthmani": "فَكَانَ قَابَ قَوْسَيْنِ أَوْ أَدْنَى",
        "verse_number": 9,
        "chapter_id": 53,
        "name_arabic": "النجم"
      }
    ]
  },
  {
    "verse_id": 4794,
    "elements": [
      {
