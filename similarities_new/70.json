  {
    "verse_id": 5386,
    "elements": [
      {
        "text_uthmani": "يُبَصَّرُونَهُمْ يَوَدُّ الْمُجْرِمُ لَوْ يَفْتَدِي مِنْ عَذَابِ يَوْمِئِذٍ بِبَنِيهِ",
        "name_arabic": "المعارج",
        "chapter_id": 70,
        "verse_number": 11,
        "content": [
          {
            "black": "يُبَصَّرُونَهُمْ ۚ يَوَدُّ الْمُجْرِمُ لَوْ يَفْتَدِي مِنْ عَذَابِ يَوْمِئِذٍ"
          },
          {
            "red": "بِبَنِيهِ * وَصَاحِبَتِهِ وَأَخِيهِ * وَفَصِيلَتِهِ الَّتِي تُؤْوِيهِ"
          }
        ]
      },
      {
        "sim_chapter_name": "عبس",
        "sim_chapter_id": 80,
        "sim_verse_number": 34,
        "content": [
          {
            "black": "يَوْمَ يَفِرُّ الْمَرْءُ"
          },
          {
            "red": "مِنْ أَخِيهِ * وَأُمِّهِ وَأَبِيهِ * وَصَاحِبَتِهِ وَبَنِيهِ"
          }
        ]
      }
    ],
    "spotlights": [
      "وباقي المواضع: ﴿يَوْمَئِذٍ﴾, تكررت 67 مرة.",
      "﴿يَوْمِئِذٍ﴾ تكررت مرتين فقط: [هود: 66, المعارج: 11].",
      "كل آية فيها ذِكْر: (يَوْمَئِذٍ) فهي بهذا اللفظ بميم مفتوحة, ما عدا مَوْضِعَي هود والمعارج: (يَوْمِئِذٍ) فبميم مكسورة.",
      "بدأ في سورة عبس بذكر: الأخ, فالأم, فالأب, فالصاحبة, ثم الأبناء في الأخير, وفي سورة المعارج على عكس ذلك, فقد بدأ بالأبناء, فالصاحبة, فالأخ, فالفصيلة, ثم انتهى بأهل الأرض أجمعين, وسبب ذلك -والله أعلم- أن المقام في عبس مقام الفرار والهرب, قال تعالى: (يَوْمَ يَفِرُّ الْمَرْءُ), والإنسان يفر من الأباعد أولًا, ثم ينتهي بألصق الناس به وأقربهم إليه, فيكونون آخر من يفر منهم, والأخ أبعد المذكورين في الآية من المرء, وإن ألصقهم به زوجه وأبناؤه, فنحن ملتصقون في حياتنا بأزواجنا وأبنائنا أكثر من التصاقنا بإخواننا وآبائنا وأمهاتنا, فقد تمر شهور بل ربما أعوام ونحن لا نرى إخواننا, في حين نأوي كل يوم إلى أزواجنا وأبنائنا, والإنسان قد يترك أمه وأباه ويعيش مع زوجته وأبنائه, وهو ألصق بأبنائه من زوجه, فقد يفارق زوجه ويسرحها, ولكن لا يترك أبناءه.",
      "في المعارج لم يذكر الوالدين؛ لعظيم منزلتهما عند الله, فإنه لا يجرؤ أن يذكر الافتداء بهما, فإن ذلك مما يزيد غضب الله عليه, فإن الذي يفتدي إنما يفتدي بما يرضي صاحب الأمر, لا بما يغضبه."
    ]
