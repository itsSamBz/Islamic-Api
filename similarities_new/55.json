    "elements": [
      {
        "text_uthmani": "الشَّمْسُ وَالْقَمَرُ بِحُسْبَانٍ",
        "name_arabic": "الرحمن",
        "chapter_id": 55,
        "verse_number": 5,
        "content": [
          {
            "red": "الشَّمْسُ وَالْقَمَرُ"
          },
          {
            "dimgray": "بِحُسْبَانٍ"
          }
        ]
      },
      {
        "sim_chapter_name": "الأنعام",
        "sim_chapter_id": 6,
        "sim_verse_number": 96,
        "content": [
          {
            "black": "فَالِقُ الْإِصْبَاحِ وَجَعَلَ اللَّيْلَ سَكَنًا"
          },
          {
            "dimgray": "وَ"
          },
          {
            "red": "الشَّمْسَ وَالْقَمَرَ"
          },
          {
            "dimgray": "حُسْبَانًا"
          },
          {
            "black": "ۚ ذَٰلِكَ تَقْدِيرُ الْعَزِيزِ الْعَلِيمِ"
          }
        ]
      }
    ],
    "spotlights": [
      "﴿وَالشَّمْسَ وَالْقَمَرَ حُسْبَانًا﴾, أي: وسيلة لحساب الزمن, أما: ﴿الشَّمْسُ وَالْقَمَرُ بِحُسْبَانٍ﴾, أي: يجريان بحساب دقيق مُقدَّر معلوم من الحقِّ سبحانه وتعالى."
    ]
  },
  {
    "verse_id": 4907,
    "elements": [
      {
        "text_uthmani": "وَالنَّجْمُ وَالشَّجَرُ يَسْجُدَانِ",
        "verse_number": 6,
        "chapter_id": 55,
        "name_arabic": "الرحمن"
      }
    ]
  },
  {
    "verse_id": 4908,
    "elements": [
      {
        "text_uthmani": "وَالسَّمَاء رَفَعَهَا وَوَضَعَ الْمِيزَانَ",
        "verse_number": 7,
        "chapter_id": 55,
        "name_arabic": "الرحمن"
      }
    ]
  },
  {
    "verse_id": 4909,
    "elements": [
      {
        "text_uthmani": "أَلَّا تَطْغَوْا فِي الْمِيزَانِ",
        "verse_number": 8,
        "chapter_id": 55,
        "name_arabic": "الرحمن"
      }
    ]
  },
  {
    "verse_id": 4910,
    "elements": [
      {
        "text_uthmani": "وَأَقِيمُوا الْوَزْنَ بِالْقِسْطِ وَلَا تُخْسِرُوا الْمِيزَانَ",
        "verse_number": 9,
        "chapter_id": 55,
        "name_arabic": "الرحمن"
      }
    ]
  },
  {
