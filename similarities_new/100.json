[
  {
    "verse_id": 6147,
    "elements": [
      {
        "text_uthmani": "وَالْعَادِيَاتِ ضَبْحًا",
        "verse_number": 1,
        "chapter_id": 100,
        "name_arabic": "العاديات"
      }
    ]
  },
  {
    "verse_id": 6148,
    "elements": [
      {
        "text_uthmani": "فَالْمُورِيَاتِ قَدْحًا",
        "verse_number": 2,
        "chapter_id": 100,
        "name_arabic": "العاديات"
      }
    ]
  },
  {
    "verse_id": 6149,
    "elements": [
      {
        "text_uthmani": "فَالْمُغِيرَاتِ صُبْحًا",
        "verse_number": 3,
        "chapter_id": 100,
        "name_arabic": "العاديات"
      }
    ]
  },
  {
    "verse_id": 6150,
    "elements": [
      {
        "text_uthmani": "فَأَثَرْنَ بِهِ نَقْعًا",
        "verse_number": 4,
        "chapter_id": 100,
        "name_arabic": "العاديات"
      }
    ]
  },
  {
    "verse_id": 6151,
    "elements": [
      {
        "text_uthmani": "فَوَسَطْنَ بِهِ جَمْعًا",
        "verse_number": 5,
        "chapter_id": 100,
        "name_arabic": "العاديات"
      }
    ]
  },
  {
    "verse_id": 6152,
    "elements": [
      {
        "text_uthmani": "إِنَّ الْإِنسَانَ لِرَبِّهِ لَكَنُودٌ",
        "verse_number": 6,
        "chapter_id": 100,
        "name_arabic": "العاديات"
      }
    ]
  },
  {
    "verse_id": 6153,
    "elements": [
      {
        "text_uthmani": "وَإِنَّهُ عَلَى ذَلِكَ لَشَهِيدٌ",
        "verse_number": 7,
        "chapter_id": 100,
        "name_arabic": "العاديات"
      }
    ]
  },
  {
    "verse_id": 6154,
    "elements": [
      {
        "text_uthmani": "وَإِنَّهُ لِحُبِّ الْخَيْرِ لَشَدِيدٌ",
        "verse_number": 8,
        "chapter_id": 100,
        "name_arabic": "العاديات"
      }
    ]
  },
  {
    "verse_id": 6155,
    "elements": [
      {
        "text_uthmani": "أَفَلَا يَعْلَمُ إِذَا بُعْثِرَ مَا فِي الْقُبُورِ",
        "verse_number": 9,
        "chapter_id": 100,
        "name_arabic": "العاديات"
      }
    ]
  },
  {
    "verse_id": 6156,
    "elements": [
      {
        "text_uthmani": "وَحُصِّلَ مَا فِي الصُّدُورِ",
        "verse_number": 10,
        "chapter_id": 100,
        "name_arabic": "العاديات"
      }
    ]
  },
  {
    "verse_id": 6157,
    "elements": [
      {
        "text_uthmani": "إِنَّ رَبَّهُم بِهِمْ يَوْمَئِذٍ لَّخَبِيرٌ",
        "verse_number": 11,
        "chapter_id": 100,
        "name_arabic": "العاديات"
      }
    ]
  }
]