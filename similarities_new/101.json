  },
  {
    "verse_id": 6160,
    "elements": [
      {
        "text_uthmani": "وَمَا أَدْرَاكَ مَا الْقَارِعَةُ",
        "verse_number": 3,
        "chapter_id": 101,
        "name_arabic": "القارعة"
      },
      {
        "sim_chapter_name": "الأحزاب",
        "sim_chapter_id": 33,
        "sim_verse_number": 63,
        "content": [
          {
            "black": "يَسْأَلُكَ النَّاسُ عَنِ السَّاعَةِ ۖ قُلْ إِنَّمَا عِلْمُهَا عِندَ اللَّـهِ ۚ"
          },
          {
            "red": "وَمَا يُدْرِيكَ لَعَلَّ السَّاعَةَ"
          },
          {
            "black": "تَكُونُ"
          },
          {
            "red": "قَرِيب"
          },
          {
            "dimgray": "ًا"
          }
        ]
      },
      {
        "sim_chapter_name": "الشورى",
        "sim_chapter_id": 42,
        "sim_verse_number": 17,
        "content": [
          {
            "black": "اللَّـهُ الَّذِي أَنزَلَ الْكِتَابَ بِالْحَقِّ وَالْمِيزَانَ ۗ"
          },
          {
            "red": "وَمَا يُدْرِيكَ لَعَلَّ السَّاعَةَ قَرِيبٌ"
          }
        ]
      },
      {
        "sim_chapter_name": "عبس",
        "sim_chapter_id": 80,
        "sim_verse_number": 3,
        "content": [
          {
            "red": "وَمَا يُدْرِيكَ لَعَلَّهُ"
          },
          {
            "black": "يَزَّكَّىٰ"
          }
        ]
      },
      {
        "sim_chapter_name": "الانفطار",
        "sim_chapter_id": 82,
        "sim_verse_number": 18,
        "content": [
          {
            "red": "ثُمَّ مَا أَدْرَاكَ"
          },
          {
            "black": "مَا يَوْمُ الدِّينِ"
          }
        ]
      }
    ],
    "spotlights": [
      "وباقي المواضع: ﴿وَمَا أَدْرَاكَ﴾, تكررت 12 مرة في القرآن.",
      "ما الفرق بين: (مَا أَدْرَاكَ) و(مَا يُدْرِيكَ)؟ الجواب: إذا قال تعالى: (مَا أَدْرَاكَ)؛ فإنه يذكر هذا الشيء بعد ذلك ويفسره ويوضحه, كما في وصف أهوال القيامة: (الْقَارِعَةُ * مَا الْقَارِعَةُ * وَمَا أَدْرَاكَ مَا الْقَارِعَةُ * يَوْمَ يَكُونُ النَّاسُ), أما إذا قال: (مَا يُدْرِيكَ)؛ فإنه لا يوضحه ولا يفسره؛ لأنه لا سبيل إلى إدراكه والعلم به, كما في شأن موعد يوم القيامة, وقد وردت (مَا أَدْرَاكَ) 13 مرة, بينما وردت (وَمَا يُدْرِيكَ) 3 مرات فقط."
    ]
  },
  {
    "verse_id": 6161,
    "elements": [
      {
        "text_uthmani": "يَوْمَ يَكُونُ النَّاسُ كَالْفَرَاشِ الْمَبْثُوثِ",
        "verse_number": 4,
        "chapter_id": 101,
        "name_arabic": "القارعة"
      }
    ]
  },
  {
    "verse_id": 6162,
    "elements": [
      {
