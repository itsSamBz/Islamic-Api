  {
    "verse_id": 6232,
    "text_uthmani": "مَلِكِ النَّاسِ",
    "content": "٢- مَلِك النَّاس، قال تعالى:",
    "name_arabic": "الناس",
    "chapter_id": 114,
    "verse_number": 2
  },
  {
    "verse_id": 6233,
    "text_uthmani": "إِلَهِ النَّاسِ",
    "content": "٣- إله النَّاس، قال تعالى:",
    "name_arabic": "الناس",
    "chapter_id": 114,
    "verse_number": 3
  },
  {
    "verse_id": 6234,
    "text_uthmani": "مِن شَرِّ الْوَسْوَاسِ الْخَنَّاسِ",
    "content": "وبعد أن ذكرَ المُستعاذ به؛ ذكرَ المُستعاذ منه، فقال تعالى:",
    "name_arabic": "الناس",
    "chapter_id": 114,
    "verse_number": 4
  },
  {
    "verse_id": 6235,
    "text_uthmani": "الَّذِي يُوَسْوِسُ فِي صُدُورِ النَّاسِ",
    "content": "ولَمَّا ذَكَر صِفةَ المُستعاذِ منه؛ ذكَرَ إبرازَه لصِفتِه بالفِعلِ، فقال تعالى:",
    "name_arabic": "الناس",
    "chapter_id": 114,
    "verse_number": 5
  },
  {
    "verse_id": 6236,
    "text_uthmani": "مِنَ الْجِنَّةِ وَ النَّاسِ",
    "content": "ولَمَّا كان الَّذي يُعَلِّمُ الإنسانَ الشَّرَّ تارةً مِنَ الجِنِّ، وأُخرَى مِنَ الإنسِ؛ قال تعالى مُبَيِّنًا للوَسواسِ؛ تحذيرًا مِن شياطينِ الإنسِ كالتَّحذيرِ مِن شياطينِ الجِنِّ، مُقَدِّمًا الأهَمَّ الأضَرَّ:",
    "name_arabic": "الناس",
    "chapter_id": 114,
    "verse_number": 6
  }
