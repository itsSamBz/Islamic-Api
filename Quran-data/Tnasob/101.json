[
  {
    "verse_id": 6158,
    "text_uthmani": "الْقَارِعَةُ",
    "content": "بدأت السورةُ ببيان أهوالِ القيامةِ وشدائدِها، قال تعالى:",
    "name_arabic": "القارعة",
    "chapter_id": 101,
    "verse_number": 1
  },
  {
    "verse_id": 6159,
    "text_uthmani": "مَا الْقَارِعَةُ",
    "content": "وبعد ذكرِ القارعة؛ جاء هنا استفهام عن حقيقتها، والمقصودُ به التهويلُ من أمرِها، قال تعالى:",
    "name_arabic": "القارعة",
    "chapter_id": 101,
    "verse_number": 2
  },
  {
    "verse_id": 6160,
    "text_uthmani": "وَمَا أَدْرَاكَ مَا الْقَارِعَةُ",
    "content": "وبعد التهويل من أمرِها؛ زادَ سُبْحانَهُ في تَفْخِيمِ أمْرِها، وتَعْظِيمِ شَأْنِها، قال تعالى:",
    "name_arabic": "القارعة",
    "chapter_id": 101,
    "verse_number": 3
  },
  {
    "verse_id": 6161,
    "text_uthmani": "يَوْمَ يَكُونُ النَّاسُ كَالْفَرَاشِ الْمَبْثُوثِ",
    "content": "وبعد تَفْخِيمِ أمْرِها؛ ذكرَ اللهُ هنا حالَ النَّاس وقت وقوعها، قال تعالى:",
    "name_arabic": "القارعة",
    "chapter_id": 101,
    "verse_number": 4
  },
  {
    "verse_id": 6162,
    "text_uthmani": "وَتَكُونُ الْجِبَالُ كَالْعِهْنِ الْمَنفُوشِ",
    "content": "ولَمَّا كانت الجِبالُ أشَدَّ ما تكونُ؛ عظَّم الرَّهبةَ بالإخبارِ بما يُفعَلُ بها، قال تعالى: ",
    "name_arabic": "القارعة",
    "chapter_id": 101,
    "verse_number": 5
  },
  {
    "verse_id": 6163,
    "text_uthmani": "فَأَمَّا مَن ثَقُلَتْ مَوَازِينُهُ",
    "content": "ولَمَّا وَصَفَ اللهُ يومَ القيامةِ؛ قسَّمَ النَّاسَ فيه إلى قِسمَينِ، قال تعالى:",
    "name_arabic": "القارعة",
    "chapter_id": 101,
    "verse_number": 6
  },
  {
    "verse_id": 6164,
    "text_uthmani": "فَهُوَ فِي عِيشَةٍ رَّاضِيَةٍ",
    "content": "ولَمَّا ذكرَ القسمَ الأول؛ ذكرَ مسكنَه، قال تعالى:",
    "name_arabic": "القارعة",
    "chapter_id": 101,
    "verse_number": 7
  },
  {
    "verse_id": 6165,
    "text_uthmani": "وَأَمَّا مَنْ خَفَّتْ مَوَازِينُهُ",
    "content": "وبعد أن ذكرَ القسمَ الأول؛ ذكرَ القسمَ الثاني من النَّاس، قال تعالى:",
    "name_arabic": "القارعة",
    "chapter_id": 101,
    "verse_number": 8
  },
  {
    "verse_id": 6166,
    "text_uthmani": "فَأُمُّهُ هَاوِيَةٌ",
    "content": "ولَمَّا ذكرَ القسمَ الثاني؛ ذكرَ مسكنَه، قال تعالى:",
    "name_arabic": "القارعة",
    "chapter_id": 101,
    "verse_number": 9
  },
  {
    "verse_id": 6167,
    "text_uthmani": "وَمَا أَدْرَاكَ مَا هِيَهْ",
    "content": "ولَمَّا ذكرَ الهاوية؛ هَوَّلَها هنا، فقال تعالى:",
    "name_arabic": "القارعة",
    "chapter_id": 101,
    "verse_number": 10
  },
  {
    "verse_id": 6168,
    "text_uthmani": "نَارٌ حَامِيَةٌ",
    "content": "وبعد أن هَوَّلَها؛ بَيَّنَها هنا، قال تعالى:",
    "name_arabic": "القارعة",
    "chapter_id": 101,
    "verse_number": 11
  }
]